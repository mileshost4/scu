<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Deposit Methods | <%= websiteName %></title>

  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/admin/deposits.css" />
</head>
<body>

  <%
    locals.currentPath = '/admin/admin.depositmethods';
  %>

  <%- include('../partials/adminnav', { admin: admin }) %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="admin-dashboard fade-in">

        <!-- Page Header -->
        <div class="page-header">
          <div class="page-header-left">
            <h1 class="page-title">Deposit Methods</h1>
            <p class="page-subtitle">Manage crypto wallet addresses and QR codes shown to users.</p>
          </div>
          <div class="page-header-right">
            <a href="/admin/admin.deposit-requests" class="btn btn-ghost btn-sm">
              <i class="fa-solid fa-circle-dot"></i> Pending
            </a>
            <button class="btn btn-primary btn-sm" onclick="openModal('addMethodModal')">
              <i class="fa-solid fa-plus"></i> Add Method
            </button>
          </div>
        </div>

        <!-- Methods Grid -->
        <% if (deposits.length === 0) { %>
          <div class="empty-state">
            <div class="empty-icon"><i class="fa-solid fa-wallet"></i></div>
            <h3>No Deposit Methods</h3>
            <p>Add a crypto wallet address to allow users to make deposits.</p>
            <button class="btn btn-primary" onclick="openModal('addMethodModal')" style="margin-top:16px;">
              <i class="fa-solid fa-plus"></i> Add First Method
            </button>
          </div>
        <% } else { %>
          <div class="methods-grid">
            <% for (let method of deposits) { %>
              <div class="method-card">
                <div class="method-card-header">
                  <div class="method-icon">
                    <i class="fa-brands fa-bitcoin"></i>
                  </div>
                  <div class="method-name-wrap">
                    <h3 class="method-name"><%= method.depositmethodname %></h3>
                    <span class="badge badge-accent">Active</span>
                  </div>
                  <div class="method-actions-top">
                    <button class="btn-icon"
                      onclick="openEditModal('<%= method._id %>', '<%= method.depositmethodname %>', '<%= method.depositaddress.replace(/'/g, '\\\'') %>')"
                      title="Edit">
                      <i class="fa-solid fa-pen-to-square"></i>
                    </button>
                    <button class="btn-icon danger-icon"
                      onclick="openDeleteModal('<%= method._id %>', '<%= method.depositmethodname %>')"
                      title="Delete">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </div>
                </div>

                <div class="method-address-wrap">
                  <label class="form-label" style="margin-bottom:6px;">Wallet Address</label>
                  <div class="address-row">
                    <span class="address-text font-mono" id="addr-<%= method._id %>"><%= method.depositaddress %></span>
                    <button class="btn-icon copy-btn" onclick="copyAddress('<%= method._id %>')" title="Copy">
                      <i class="fa-regular fa-copy"></i>
                    </button>
                  </div>
                </div>

                <% if (method.depositqrcode && method.depositqrcode.length > 0) { %>
                  <div class="method-qr">
                    <img src="<%= method.depositqrcode[0].url %>" alt="QR Code" class="qr-image" />
                    <span class="qr-label">QR Code</span>
                  </div>
                <% } else { %>
                  <div class="method-qr no-qr">
                    <i class="fa-solid fa-qrcode"></i>
                    <span>No QR Code</span>
                  </div>
                <% } %>
              </div>
            <% } %>
          </div>
        <% } %>

      </div>
    </div>
  </div>

  <!-- ── Add Method Modal ── -->
  <div class="custom-modal-overlay" id="addMethodModal">
    <div class="custom-modal">
      <div class="custom-modal-header">
        <div class="custom-modal-title">
          <i class="fa-solid fa-plus"></i>
          Add Deposit Method
        </div>
        <button class="custom-modal-close" onclick="closeModal('addMethodModal')"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form action="/admin/admin.depositmethods" method="POST" enctype="multipart/form-data">
        <div class="custom-modal-body">
          <div class="form-group">
            <label class="form-label">Method Name</label>
            <input type="text" name="depositmethodname" class="form-control" placeholder="e.g. Bitcoin (BTC), USDT TRC20" required />
          </div>
          <div class="form-group">
            <label class="form-label">Wallet Address</label>
            <input type="text" name="depositaddress" class="form-control font-mono" placeholder="Enter wallet address" required />
          </div>
          <div class="form-group">
            <label class="form-label">QR Code Image <span style="color:var(--text-muted); font-weight:400; text-transform:none;">(optional)</span></label>
            <div class="file-upload-area" id="addFileArea">
              <i class="fa-solid fa-qrcode"></i>
              <span>Click to upload QR code image</span>
              <input type="file" name="depositqrcode" accept="image/*" onchange="previewFile(this, 'addPreview')" />
            </div>
            <img id="addPreview" class="qr-preview" src="" alt="preview" style="display:none;" />
          </div>
        </div>
        <div class="custom-modal-footer">
          <button type="button" class="btn btn-ghost" onclick="closeModal('addMethodModal')">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add Method</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Edit Method Modal ── -->
  <div class="custom-modal-overlay" id="editMethodModal">
    <div class="custom-modal">
      <div class="custom-modal-header">
        <div class="custom-modal-title">
          <i class="fa-solid fa-pen-to-square"></i>
          Edit Deposit Method
        </div>
        <button class="custom-modal-close" onclick="closeModal('editMethodModal')"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form id="editMethodForm" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_method" value="PUT" />
        <div class="custom-modal-body">
          <div class="form-group">
            <label class="form-label">Method Name</label>
            <input type="text" name="depositmethodname" id="editMethodName" class="form-control" required />
          </div>
          <div class="form-group">
            <label class="form-label">Wallet Address</label>
            <input type="text" name="depositaddress" id="editMethodAddress" class="form-control font-mono" required />
          </div>
          <p style="font-size:0.8rem; color: var(--text-muted); margin-top:-6px;">Note: QR code image cannot be updated here. Delete and re-add to change the image.</p>
        </div>
        <div class="custom-modal-footer">
          <button type="button" class="btn btn-ghost" onclick="closeModal('editMethodModal')">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Delete Confirm Modal ── -->
  <div class="custom-modal-overlay" id="deleteMethodModal">
    <div class="custom-modal logout-modal">
      <div class="custom-modal-header">
        <div class="custom-modal-title">
          <i class="fa-solid fa-trash"></i>
          Delete Deposit Method
        </div>
        <button class="custom-modal-close" onclick="closeModal('deleteMethodModal')"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="custom-modal-body">
        <p id="deleteMethodText" style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;"></p>
      </div>
      <div class="custom-modal-footer">
        <button class="btn btn-ghost" onclick="closeModal('deleteMethodModal')">Cancel</button>
        <form id="deleteMethodForm" method="POST" style="margin:0;">
          <input type="hidden" name="_method" value="DELETE" />
          <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Delete</button>
        </form>
      </div>
    </div>
  </div>

  <script src="/script/partials/navbar.js"></script>
  <script>
    function openModal(id) {
      document.getElementById(id).classList.add('open');
    }
    function closeModal(id) {
      document.getElementById(id).classList.remove('open');
    }

    function openEditModal(id, name, address) {
      document.getElementById('editMethodForm').action = `/admin/admin.depositmethods/${id}?_method=PUT`;
      document.getElementById('editMethodName').value = name;
      document.getElementById('editMethodAddress').value = address;
      openModal('editMethodModal');
    }

    function openDeleteModal(id, name) {
      document.getElementById('deleteMethodForm').action = `/admin/admin.depositmethods/${id}?_method=DELETE`;
      document.getElementById('deleteMethodText').textContent = `You are about to permanently delete the "${name}" deposit method. Users will no longer see this wallet address. This cannot be undone.`;
      openModal('deleteMethodModal');
    }

    function copyAddress(id) {
      const text = document.getElementById('addr-' + id).textContent;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.querySelector(`[onclick="copyAddress('${id}')"]`);
        btn.innerHTML = '<i class="fa-solid fa-check"></i>';
        btn.style.color = 'var(--success)';
        setTimeout(() => {
          btn.innerHTML = '<i class="fa-regular fa-copy"></i>';
          btn.style.color = '';
        }, 1800);
      });
    }

    function previewFile(input, previewId) {
      const preview = document.getElementById(previewId);
      if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = e => {
          preview.src = e.target.result;
          preview.style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
      }
    }

    document.querySelectorAll('.custom-modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', e => {
        if (e.target === overlay) overlay.classList.remove('open');
      });
    });
  </script>
</body>
</html>
