    <form action="/admin/admin.user/<%= user._id %>/change-transfer-pin?_method=PUT" method="POST">
      <input type="hidden" name="_method" value="PUT" />
      <div class="custom-modal-body">
        <div class="form-group">
          <label class="form-label">Current PIN</label>
          <input type="text" name="oldTransferCode" class="form-control" maxlength="4" placeholder="••••" required />
        </div>
        <div class="form-group">
          <label class="form-label">New PIN (4 digits)</label>
          <input type="text" name="transferCode" class="form-control" maxlength="4" pattern="\d{4}" placeholder="••••" required />
        </div>
        <div class="form-group">
          <label class="form-label">Confirm New PIN</label>
          <input type="text" name="confirmTransferCode" class="form-control" maxlength="4" pattern="\d{4}" placeholder="••••" required />
        </div>
      </div>
      <div class="custom-modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeModal('changePinModal')">Cancel</button>
        <button type="submit" class="btn btn-primary">Update PIN</button>
      </div>
    </form>
  </div>
</div>

  <script src="/script/partials/navbar.js"></script>
  <script>
    const CURRENCY_MAP = <%- currencyMapJSON %>;

    document.getElementById('country').addEventListener('change', function () {
      const val = this.value;
      const data = CURRENCY_MAP[val] || {};
      document.getElementById('basecurrency').value  = data.currency || '';
      document.getElementById('currencySymbol').value = data.symbol  || '';
    });
  </script>
  <script>
    const userId = '<%= user._id %>';

    function openModal(id) { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    document.querySelectorAll('.custom-modal-overlay').forEach(o => {
      o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
    });

    // Transaction tabs
    document.querySelectorAll('.txn-tab').forEach(tab => {
      tab.addEventListener('click', function() {
        document.querySelectorAll('.txn-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.txn-panel').forEach(p => p.classList.remove('active'));
        this.classList.add('active');
        document.getElementById('tab-' + this.dataset.tab).classList.add('active');
      });
    });

    // Generic action confirm (activate, suspend, verify, etc.)
    function confirmAction(action, title, desc) {
      document.getElementById('confirmActionTitle').textContent = title;
      document.getElementById('confirmActionDesc').textContent = desc;
      document.getElementById('confirmActionForm').action = '/admin/admin.users/' + userId + '/' + action + '?_method=PUT';
      openModal('confirmActionModal');
    }

    // Delete account confirm
    function confirmDeleteAccount(accountId, userId, accountName) {
      document.getElementById('deleteAccountName').textContent = accountName;
      document.getElementById('deleteAccountForm').action = '/admin/admin.removeaccount/' + accountId + '/from/' + userId + '?_method=DELETE';
      openModal('deleteAccountModal');
    }

    // Credit score confirm
    function confirmCreditScore() {
      const val = document.getElementById('creditscoreInput').value;
      if (!val) return;
      document.getElementById('creditScorePreview').textContent = val;
      document.getElementById('creditScoreHidden').value = val;
      openModal('creditScoreModal');
    }

    // Currency confirm
    function confirmCurrency() {
      const cur = document.getElementById('basecurrencySelect').value;
      const sym = document.getElementById('basecurrencysymbolInput').value;
      document.getElementById('currencyPreview').textContent = cur + ' (' + sym + ')';
      document.getElementById('basecurrencyHidden').value = cur;
      document.getElementById('basecurrencysymbolHidden').value = sym;
      openModal('currencyModal');
    }

    // Backdate confirm
    function confirmBackdate() {
      const val = document.getElementById('backdateInput').value;
      if (!val) { alert('Please select a date.'); return; }
      document.getElementById('backdatePreview').textContent = new Date(val).toDateString();
      document.getElementById('backdateHidden').value = val;
      openModal('backdateModal');
    }
  </script>
</body>
</html>