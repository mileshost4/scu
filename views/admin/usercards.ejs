<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= user.firstname %> <%= user.lastname %> — Cards | Admin</title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/admin/subpages.css" />
</head>
<body>
  <% locals.currentPath = '/admin/admin.users'; %>
  <%- include('../partials/adminnav', { admin: admin }) %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="fade-in">

        <!-- Breadcrumb -->
        <div class="breadcrumb">
          <a href="/admin/admin.users"><i class="fa-solid fa-users"></i> Users</a>
          <i class="fa-solid fa-chevron-right"></i>
          <a href="/admin/admin.user/<%= user._id %>"><%= user.firstname %> <%= user.lastname %></a>
          <i class="fa-solid fa-chevron-right"></i>
          <span>Cards</span>
        </div>

        <!-- Page Header -->
        <div class="subpage-header">
          <div class="subpage-header-left">
            <div class="subpage-avatar">
              <% if (user.profilepicture && user.profilepicture.length > 0) { %>
                <img src="<%= user.profilepicture[user.profilepicture.length - 1].url %>" alt="Profile" />
              <% } else { %>
                <%= (user.firstname || '?')[0].toUpperCase() %><%= (user.lastname || '')[0] ? user.lastname[0].toUpperCase() : '' %>
              <% } %>
            </div>
            <div>
              <h2 class="subpage-title"><%= user.firstname %> <%= user.lastname %></h2>
              <p class="subpage-subtitle"><i class="fa-solid fa-credit-card"></i> <%= cards.length %> card<%= cards.length !== 1 ? 's' : '' %></p>
            </div>
          </div>
          <div class="subpage-header-actions">
            <button class="btn btn-primary btn-sm" onclick="openModal('addCardModal')"><i class="fa-solid fa-plus"></i> Add Card</button>
            <a href="/admin/admin.user/<%= user._id %>" class="btn btn-ghost btn-sm"><i class="fa-solid fa-arrow-left"></i> Back to Profile</a>
          </div>
        </div>

        <!-- Cards Grid -->
        <% if (cards.length === 0) { %>
          <div class="card" style="padding:60px 20px;">
            <div class="empty-state">
              <i class="fa-solid fa-credit-card"></i>
              <p>No cards found for this user.</p>
              <button class="btn btn-primary btn-sm" onclick="openModal('addCardModal')"><i class="fa-solid fa-plus"></i> Add First Card</button>
            </div>
          </div>
        <% } else { %>
        <div class="cards-grid">
          <% cards.forEach(card => {
            const brand = (card.cardBrand || '').toLowerCase();
            const brandIcon = brand.includes('visa') ? 'fa-brands fa-cc-visa' : brand.includes('mastercard') ? 'fa-brands fa-cc-mastercard' : brand.includes('amex') ? 'fa-brands fa-cc-amex' : brand.includes('discover') ? 'fa-brands fa-cc-discover' : 'fa-solid fa-credit-card';
          %>
          <div class="bank-card">
            <div class="bank-card-inner">
              <!-- Card Visual -->
              <div class="bank-card-visual">
                <div class="bank-card-top">
                  <div class="bank-card-bank"><%= card.bankName || 'Bank' %></div>
                  <i class="<%= brandIcon %> bank-card-brand-icon"></i>
                </div>
                <div class="bank-card-chip"><i class="fa-solid fa-microchip"></i></div>
                <div class="bank-card-number">
                  <% const num = String(card.cardNumber || '').replace(/\s/g,''); %>
                  **** **** **** <%= num.length >= 4 ? num.slice(-4) : num %>
                </div>
                <div class="bank-card-footer">
                  <div>
                    <div class="bank-card-lbl">Card Holder</div>
                    <div class="bank-card-val"><%= card.userName || user.firstname + ' ' + user.lastname %></div>
                  </div>
                  <div>
                    <div class="bank-card-lbl">Expires</div>
                    <div class="bank-card-val"><%= card.cardExpiryMonth || '—' %>/<%= card.cardExpiryYear || '—' %></div>
                  </div>
                  <div>
                    <div class="bank-card-lbl">Type</div>
                    <div class="bank-card-val"><%= card.cardType || '—' %></div>
                  </div>
                </div>
              </div>

              <!-- Card Details -->
              <div class="bank-card-details">
                <div class="detail-grid" style="padding:0; display:grid; grid-template-columns: repeat(3, 1fr); gap: 0;">
                  <div class="detail-item"><span class="detail-lbl">Card Number</span><span class="detail-val mono-text"><%= card.cardNumber || '—' %></span></div>
                  <div class="detail-item"><span class="detail-lbl">CVV</span><span class="detail-val mono-text"><%= card.cvv || '—' %></span></div>
                  <div class="detail-item"><span class="detail-lbl">PIN</span><span class="detail-val mono-text"><%= card.cardPin || '—' %></span></div>
                  <div class="detail-item"><span class="detail-lbl">Brand</span><span class="detail-val"><%= card.cardBrand || '—' %></span></div>
                  <div class="detail-item"><span class="detail-lbl">Bank</span><span class="detail-val"><%= card.bankName || '—' %></span></div>
                  <div class="detail-item"><span class="detail-lbl">Added</span><span class="detail-val"><%= card.dateAdded || '—' %></span></div>
                </div>
                <div class="bank-card-actions">
                  <button class="btn btn-danger btn-sm" onclick="confirmDeleteCard('<%= card._id %>', '<%= card.cardBrand %> ending <%= String(card.cardNumber||'').slice(-4) %>')"><i class="fa-solid fa-trash"></i> Delete Card</button>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>

      </div>
    </div>
  </div>

  <!-- Add Card Modal -->
  <div class="custom-modal-overlay" id="addCardModal">
    <div class="custom-modal" style="max-width:560px;">
      <div class="custom-modal-header">
        <div class="custom-modal-title"><i class="fa-solid fa-credit-card"></i> Add Card</div>
        <button class="custom-modal-close" onclick="closeModal('addCardModal')"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form action="/admin/admin.user/<%= user._id %>/card" method="POST">
        <div class="custom-modal-body">
          <div class="modal-grid-2">
            <div class="form-group"><label class="form-label">Card Brand</label>
              <select name="cardBrand" class="form-control" required>
                <option value="">Select Brand</option>
                <option value="Visa">Visa</option>
                <option value="Mastercard">Mastercard</option>
                <option value="American Express">American Express</option>
                <option value="Discover">Discover</option>
              </select></div>
            <div class="form-group"><label class="form-label">Card Type</label>
              <select name="cardType" class="form-control" required>
                <option value="Debit">Debit</option>
                <option value="Credit">Credit</option>
                <option value="Prepaid">Prepaid</option>
              </select></div>
            <div class="form-group"><label class="form-label">Card Number</label><input type="text" name="cardNumber" class="form-control" placeholder="16-digit number" required /></div>
            <div class="form-group"><label class="form-label">Bank Name</label><input type="text" name="bankName" class="form-control" required /></div>
            <div class="form-group"><label class="form-label">Expiry Month</label><input type="text" name="cardExpiryMonth" class="form-control" placeholder="MM" maxlength="2" required /></div>
            <div class="form-group"><label class="form-label">Expiry Year</label><input type="text" name="cardExpiryYear" class="form-control" placeholder="YY" maxlength="2" required /></div>
            <div class="form-group"><label class="form-label">CVV</label><input type="text" name="cvv" class="form-control" maxlength="4" required /></div>
            <div class="form-group"><label class="form-label">PIN</label><input type="text" name="cardPin" class="form-control" maxlength="6" required /></div>
            <div class="form-group" style="flex:1 1 100%"><label class="form-label">Card Holder Name</label><input type="text" name="userName" class="form-control" value="<%= user.firstname %> <%= user.lastname %>" required /></div>
          </div>
        </div>
        <div class="custom-modal-footer">
          <button type="button" class="btn btn-ghost" onclick="closeModal('addCardModal')">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Add Card</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete Card Confirm Modal -->
  <div class="custom-modal-overlay" id="deleteCardModal">
    <div class="custom-modal">
      <div class="custom-modal-header">
        <div class="custom-modal-title"><i class="fa-solid fa-trash" style="background:var(--danger-dim);color:var(--danger)"></i> Delete Card</div>
        <button class="custom-modal-close" onclick="closeModal('deleteCardModal')"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="custom-modal-body">
        <p style="color:var(--text-secondary);">Delete <strong id="deleteCardName" style="color:var(--text-primary)"></strong>? This cannot be undone.</p>
      </div>
      <div class="custom-modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeModal('deleteCardModal')">Cancel</button>
        <form id="deleteCardForm" method="POST" style="display:inline;">
          <input type="hidden" name="_method" value="DELETE" />
          <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Delete</button>
        </form>
      </div>
    </div>
  </div>

  <script src="/script/partials/navbar.js"></script>
  <script>
    function openModal(id) { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }
    document.querySelectorAll('.custom-modal-overlay').forEach(o => {
      o.addEventListener('click', e => { if(e.target === o) o.classList.remove('open'); });
    });

    function confirmDeleteCard(cardId, cardLabel) {
      document.getElementById('deleteCardName').textContent = cardLabel;
      document.getElementById('deleteCardForm').action = '/admin/admin.user/<%= user._id %>/delete-card/' + cardId;
      openModal('deleteCardModal');
    }
  </script>
</body>
</html>