<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Profile | <%= websiteName %></title>

  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/admin/profile.css" />
</head>
<body>

  <%
    locals.currentPath = '/admin/admin.profile';
    const _initials = ((admin.firstname || '?')[0] + (admin.lastname || '?')[0]).toUpperCase();
  %>

  <%- include('../partials/adminnav', { admin: admin }) %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="admin-profile fade-in">

        <!-- ── Page Header ── -->
        <div class="page-header">
          <div class="page-header-left">
            <h1 class="page-title">My Profile</h1>
            <p class="page-subtitle">Manage your administrator account details and security.</p>
          </div>
          <div class="page-header-right">
            <a href="/admin/admin.dashboard" class="btn btn-ghost btn-sm">
              <i class="fa-solid fa-arrow-left"></i> Dashboard
            </a>
          </div>
        </div>

        <!-- ── Profile layout: sidebar + main ── -->
        <div class="profile-layout">

          <!-- ══════════════ LEFT: Identity card ══════════════ -->
          <aside class="profile-aside">

            <!-- Avatar card -->
            <div class="profile-card identity-card">

              <!-- Avatar display -->
              <div class="avatar-wrap">
                <div class="avatar-ring">
                  <% if (admin.profilepicture && admin.profilepicture.length > 0) { %>
                    <img src="<%= admin.profilepicture[0].url %>" alt="Profile picture" class="avatar-img" id="avatarImg" />
                  <% } else { %>
                    <div class="avatar-initials" id="avatarInitials"><%= _initials %></div>
                  <% } %>
                </div>
                <div class="avatar-badge">
                  <i class="fa-solid fa-shield-halved"></i>
                </div>
              </div>

              <div class="identity-name"><%= admin.firstname %> <%= admin.lastname %></div>
              <div class="identity-role">Administrator</div>
              <div class="identity-email"><%= admin.email %></div>

              <div class="identity-divider"></div>

              <!-- Upload picture -->
              <form action="/admin/admin.upload-profile-picture?_method=PUT" method="POST" enctype="multipart/form-data" id="uploadForm">
                <label for="picInput" class="btn btn-outline btn-sm w-full" style="justify-content:center; cursor:pointer;">
                  <i class="fa-solid fa-camera"></i> Change Photo
                </label>
                <input type="file" id="picInput" name="profilepicture" accept="image/*" style="display:none;" onchange="submitUploadForm()" />
              </form>

              <!-- Delete picture (only shown if one exists) -->
              <% if (admin.profilepicture && admin.profilepicture.length > 0) { %>
                <form action="/admin/admin.delete-profile-picture?_method=PUT" method="POST" style="margin-top:8px;">
                  <button type="submit" class="btn btn-ghost btn-sm w-full" onclick="return confirm('Remove profile picture?')" style="justify-content:center; color:var(--danger);">
                    <i class="fa-solid fa-trash"></i> Remove Photo
                  </button>
                </form>
              <% } %>

              <div class="identity-divider"></div>

              <!-- Quick stats -->
              <div class="identity-stats">
                <div class="id-stat">
                  <span class="id-stat-label">Role</span>
                  <span class="badge badge-danger">Admin</span>
                </div>
                <div class="id-stat">
                  <span class="id-stat-label">Member Since</span>
                  <span class="id-stat-value">
                    <%= admin.accountcreatedat ? new Date(admin.accountcreatedat).toLocaleDateString('en-US', {month:'short', year:'numeric'}) : '—' %>
                  </span>
                </div>
                <% if (admin.country) { %>
                <div class="id-stat">
                  <span class="id-stat-label">Country</span>
                  <span class="id-stat-value"><%= admin.country %></span>
                </div>
                <% } %>
                <% if (admin.phonenumber) { %>
                <div class="id-stat">
                  <span class="id-stat-label">Phone</span>
                  <span class="id-stat-value"><%= admin.phonenumber %></span>
                </div>
                <% } %>
              </div>

            </div><!-- /.identity-card -->

          </aside><!-- /.profile-aside -->

          <!-- ══════════════ RIGHT: Edit sections ══════════════ -->
          <div class="profile-main">

            <!-- ── Section 1: Edit Profile Details ── -->
            <div class="profile-card" id="section-details">
              <div class="profile-card-header">
                <div class="profile-card-title">
                  <div class="profile-card-icon profile-card-icon--accent">
                    <i class="fa-regular fa-user"></i>
                  </div>
                  Personal Information
                </div>
                <button type="button" class="btn btn-ghost btn-sm" onclick="toggleEdit('details')">
                  <i class="fa-solid fa-pen" id="editIcon-details"></i>
                  <span id="editLabel-details">Edit</span>
                </button>
              </div>

              <form action="/admin/admin.edit-profile?_method=PUT" method="POST" id="form-details">
                <div class="form-grid" id="grid-details">

                  <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input type="text" name="firstname" class="form-control" value="<%= admin.firstname || '' %>" readonly />
                  </div>

                  <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <input type="text" name="lastname" class="form-control" value="<%= admin.lastname || '' %>" readonly />
                  </div>

                  <div class="form-group">
                    <label class="form-label">Middle Name</label>
                    <input type="text" name="middlename" class="form-control" value="<%= admin.middlename || '' %>" readonly />
                  </div>

                  <div class="form-group">
                    <label class="form-label">Username</label>
                    <input type="text" name="username" class="form-control" value="<%= admin.username || '' %>" readonly />
                  </div>

                  <div class="form-group form-group--full">
                    <label class="form-label">Email Address</label>
                    <input type="email" name="email" class="form-control" value="<%= admin.email || '' %>" readonly />
                  </div>

                  <div class="form-group">
                    <label class="form-label">Phone Number</label>
                    <input type="text" name="phonenumber" class="form-control" value="<%= admin.phonenumber || '' %>" readonly />
                  </div>

                  <div class="form-group">
                    <label class="form-label">Gender</label>
                    <select name="gender" class="form-control" disabled>
                      <option value="">— Select —</option>
                      <option value="Male"   <%= admin.gender === 'Male'   ? 'selected' : '' %>>Male</option>
                      <option value="Female" <%= admin.gender === 'Female' ? 'selected' : '' %>>Female</option>
                      <option value="Other"  <%= admin.gender === 'Other'  ? 'selected' : '' %>>Other</option>
                    </select>
                  </div>

                </div><!-- /.form-grid -->

                <!-- Address sub-section -->
                <div class="form-section-divider">
                  <span>Address</span>
                </div>

                <div class="form-grid" id="grid-address">

                  <div class="form-group form-group--full">
                    <label class="form-label">Street Address</label>
                    <input type="text" name="address" class="form-control" value="<%= admin.address || '' %>" readonly />
                  </div>

                  <div class="form-group">
                    <label class="form-label">City</label>
                    <input type="text" name="city" class="form-control" value="<%= admin.city || '' %>" readonly />
                  </div>

                  <div class="form-group">
                    <label class="form-label">State / Province</label>
                    <input type="text" name="state" class="form-control" value="<%= admin.state || '' %>" readonly />
                  </div>

                  <div class="form-group">
                    <label class="form-label">Country</label>
                    <input type="text" name="country" class="form-control" value="<%= admin.country || '' %>" readonly />
                  </div>

                  <div class="form-group">
                    <label class="form-label">ZIP / Postal Code</label>
                    <input type="text" name="zipcode" class="form-control" value="<%= admin.zipcode || '' %>" readonly />
                  </div>

                  <div class="form-group">
                    <label class="form-label">Country Code</label>
                    <input type="text" name="countryCode" class="form-control" value="<%= admin.countryCode || '' %>" readonly />
                  </div>

                </div><!-- /.form-grid -->

                <!-- Save button — hidden until edit mode -->
                <div class="form-actions" id="actions-details" style="display:none;">
                  <button type="button" class="btn btn-ghost btn-sm" onclick="cancelEdit('details')">
                    <i class="fa-solid fa-xmark"></i> Cancel
                  </button>
                  <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-check"></i> Save Changes
                  </button>
                </div>

              </form>
            </div><!-- /.profile-card details -->

            <!-- ── Section 2: Change Password ── -->
            <div class="profile-card" id="section-password">
              <div class="profile-card-header">
                <div class="profile-card-title">
                  <div class="profile-card-icon profile-card-icon--warning">
                    <i class="fa-solid fa-lock"></i>
                  </div>
                  Change Password
                </div>
              </div>

              <form action="/admin/admin.changepassword?_method=PUT" method="POST" id="form-password" onsubmit="return validatePasswordForm()">

                <div class="form-grid form-grid--single">

                  <div class="form-group">
                    <label class="form-label">Current Password</label>
                    <div class="input-wrap">
                      <input type="password" name="currentpassword" id="currentpassword" class="form-control input-with-icon" placeholder="Enter current password" required autocomplete="current-password" />
                      <button type="button" class="input-eye" onclick="togglePwd('currentpassword', this)" tabindex="-1" aria-label="Show password">
                        <i class="fa-regular fa-eye"></i>
                      </button>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="form-label">New Password</label>
                    <div class="input-wrap">
                      <input type="password" name="password" id="newpassword" class="form-control input-with-icon" placeholder="Minimum 8 characters" required autocomplete="new-password" oninput="checkStrength(this.value)" />
                      <button type="button" class="input-eye" onclick="togglePwd('newpassword', this)" tabindex="-1" aria-label="Show password">
                        <i class="fa-regular fa-eye"></i>
                      </button>
                    </div>
                    <!-- Strength meter -->
                    <div class="strength-meter" id="strengthMeter" style="display:none;">
                      <div class="strength-bar">
                        <div class="strength-fill" id="strengthFill"></div>
                      </div>
                      <span class="strength-label" id="strengthLabel"></span>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="form-label">Confirm New Password</label>
                    <div class="input-wrap">
                      <input type="password" name="confirmpassword" id="confirmpassword" class="form-control input-with-icon" placeholder="Repeat new password" required autocomplete="new-password" oninput="checkMatch()" />
                      <button type="button" class="input-eye" onclick="togglePwd('confirmpassword', this)" tabindex="-1" aria-label="Show password">
                        <i class="fa-regular fa-eye"></i>
                      </button>
                    </div>
                    <span class="match-hint" id="matchHint"></span>
                  </div>

                </div><!-- /.form-grid -->

                <!-- Password requirements -->
                <div class="pwd-rules">
                  <div class="pwd-rule" id="rule-len">
                    <i class="fa-solid fa-circle-dot"></i> At least 8 characters
                  </div>
                  <div class="pwd-rule" id="rule-upper">
                    <i class="fa-solid fa-circle-dot"></i> One uppercase letter
                  </div>
                  <div class="pwd-rule" id="rule-num">
                    <i class="fa-solid fa-circle-dot"></i> One number
                  </div>
                  <div class="pwd-rule" id="rule-special">
                    <i class="fa-solid fa-circle-dot"></i> One special character
                  </div>
                </div>

                <div class="form-actions">
                  <button type="reset" class="btn btn-ghost btn-sm" onclick="resetPasswordForm()">
                    <i class="fa-solid fa-rotate-left"></i> Clear
                  </button>
                  <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-lock"></i> Update Password
                  </button>
                </div>

              </form>
            </div><!-- /.profile-card password -->

          </div><!-- /.profile-main -->

        </div><!-- /.profile-layout -->

      </div><!-- /.admin-profile -->
    </div><!-- /.page-inner -->
  </div><!-- /.main-content -->

  <script src="/script/partials/navbar.js"></script>
  <script>

    /* ── Submit photo on file select ── */
    function submitUploadForm() {
      const input = document.getElementById('picInput');
      if (input.files && input.files[0]) {
        document.getElementById('uploadForm').submit();
      }
    }

    /* ── Toggle edit mode for a section ── */
    function toggleEdit(section) {
      const form    = document.getElementById('form-' + section);
      const actions = document.getElementById('actions-' + section);
      const icon    = document.getElementById('editIcon-' + section);
      const label   = document.getElementById('editLabel-' + section);
      const inputs  = form.querySelectorAll('input, select, textarea');

      const isEditing = inputs[0].readOnly === false || inputs[0].disabled === false;

      if (isEditing) {
        cancelEdit(section);
      } else {
        inputs.forEach(el => {
          if (el.tagName === 'SELECT') el.disabled = false;
          else el.removeAttribute('readonly');
          el.classList.add('editable');
        });
        if (actions) actions.style.display = 'flex';
        icon.className  = 'fa-solid fa-xmark';
        label.textContent = 'Cancel';
      }
    }

    function cancelEdit(section) {
      const form    = document.getElementById('form-' + section);
      const actions = document.getElementById('actions-' + section);
      const icon    = document.getElementById('editIcon-' + section);
      const label   = document.getElementById('editLabel-' + section);
      const inputs  = form.querySelectorAll('input, select, textarea');

      inputs.forEach(el => {
        if (el.tagName === 'SELECT') el.disabled = true;
        else el.setAttribute('readonly', '');
        el.classList.remove('editable');
      });
      if (actions) actions.style.display = 'none';
      icon.className  = 'fa-solid fa-pen';
      label.textContent = 'Edit';
    }

    /* ── Password visibility toggle ── */
    function togglePwd(id, btn) {
      const input = document.getElementById(id);
      const icon  = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'fa-regular fa-eye-slash';
      } else {
        input.type = 'password';
        icon.className = 'fa-regular fa-eye';
      }
    }

    /* ── Password strength ── */
    function checkStrength(val) {
      const meter  = document.getElementById('strengthMeter');
      const fill   = document.getElementById('strengthFill');
      const label  = document.getElementById('strengthLabel');

      meter.style.display = val.length ? 'flex' : 'none';

      const rules = [
        val.length >= 8,
        /[A-Z]/.test(val),
        /[0-9]/.test(val),
        /[^A-Za-z0-9]/.test(val)
      ];

      /* Update rule indicators */
      const ruleIds = ['rule-len','rule-upper','rule-num','rule-special'];
      rules.forEach((pass, i) => {
        const el = document.getElementById(ruleIds[i]);
        el.classList.toggle('rule-pass', pass);
      });

      const score = rules.filter(Boolean).length;
      const levels = [
        { pct: '20%', cls: 'strength--weak',   text: 'Weak'      },
        { pct: '40%', cls: 'strength--weak',   text: 'Weak'      },
        { pct: '65%', cls: 'strength--fair',   text: 'Fair'      },
        { pct: '85%', cls: 'strength--good',   text: 'Good'      },
        { pct: '100%',cls: 'strength--strong', text: 'Strong'    }
      ];
      const lv = levels[score];
      fill.style.width = lv.pct;
      fill.className   = 'strength-fill ' + lv.cls;
      label.textContent = lv.text;
      label.className   = 'strength-label ' + lv.cls;

      checkMatch();
    }

    /* ── Password match check ── */
    function checkMatch() {
      const np = document.getElementById('newpassword').value;
      const cp = document.getElementById('confirmpassword').value;
      const hint = document.getElementById('matchHint');
      if (!cp) { hint.textContent = ''; return; }
      if (np === cp) {
        hint.textContent = '✓ Passwords match';
        hint.className   = 'match-hint match-ok';
      } else {
        hint.textContent = '✗ Passwords do not match';
        hint.className   = 'match-hint match-fail';
      }
    }

    /* ── Form validation before submit ── */
    function validatePasswordForm() {
      const np = document.getElementById('newpassword').value;
      const cp = document.getElementById('confirmpassword').value;
      if (np !== cp) {
        alert('New passwords do not match.');
        return false;
      }
      if (np.length < 8) {
        alert('Password must be at least 8 characters.');
        return false;
      }
      return true;
    }

    function resetPasswordForm() {
      document.getElementById('strengthMeter').style.display = 'none';
      document.getElementById('matchHint').textContent = '';
      ['rule-len','rule-upper','rule-num','rule-special'].forEach(id => {
        document.getElementById(id).classList.remove('rule-pass');
      });
    }

  </script>
</body>
</html>
