<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard | <%= websiteName %></title>

  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/admin/dashboard.css" />
</head>
<body>

  <%
    locals.currentPath = '/admin/admin.dashboard';
  %>

  <%- include('../partials/adminnav', { admin: admin }) %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="admin-dashboard fade-in">

        <!-- ── Page Header ── -->
        <div class="page-header">
          <div class="page-header-left">
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">Welcome back, <%= admin.firstname %>. Here's what's happening.</p>
          </div>
          <div class="page-header-right">
            <a href="/admin/admin.users" class="btn btn-primary btn-sm">
              <i class="fa-solid fa-users"></i> Manage Users
            </a>
          </div>
        </div>

        <!-- ── KPI Row 1: Users ── -->
        <div class="section-label">Users</div>
        <div class="stats-row">

          <div class="stat-card">
            <div class="stat-icon stat-icon--accent">
              <i class="fa-solid fa-users"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= users.length %></span>
              <span class="stat-label">Total Users</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon--success">
              <i class="fa-solid fa-circle-check"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= verifiedusers.length %></span>
              <span class="stat-label">Verified</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon--warning">
              <i class="fa-solid fa-clock"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= verificationrequest.length %></span>
              <span class="stat-label">Pending KYC</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon--muted">
              <i class="fa-solid fa-user-xmark"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= unverifiedusers.length %></span>
              <span class="stat-label">Unverified</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon--danger">
              <i class="fa-solid fa-ban"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= suspendedusers.length %></span>
              <span class="stat-label">Suspended</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon--info">
              <i class="fa-solid fa-building-columns"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= activeAcct.length %></span>
              <span class="stat-label">Active Accounts</span>
            </div>
          </div>

        </div><!-- /.stats-row -->

        <!-- ── KPI Row 2: Transactions & Investments ── -->
        <div class="section-label">Transactions &amp; Investments</div>
        <div class="stats-row">

          <div class="stat-card">
            <div class="stat-icon stat-icon--accent">
              <i class="fa-solid fa-arrow-right-arrow-left"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= totaltransactions.length %></span>
              <span class="stat-label">Total Transactions</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon--warning">
              <i class="fa-solid fa-hourglass-half"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= pendingtransactions.length %></span>
              <span class="stat-label">Pending</span>
              <% if (pendingtransactions.length > 0) { %>
                <a href="/admin/admin.pending-transactions" class="stat-link">Review →</a>
              <% } %>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon--warning">
              <i class="fa-solid fa-inbox"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= pendingcryptodeposits.length %></span>
              <span class="stat-label">Pending Deposits</span>
              <% if (pendingcryptodeposits.length > 0) { %>
                <a href="/admin/admin.deposit-requests" class="stat-link">Review →</a>
              <% } %>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon--success">
              <i class="fa-solid fa-chart-line"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= activeinvestments.length %></span>
              <span class="stat-label">Active Investments</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon--muted">
              <i class="fa-solid fa-chart-bar"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= inactiveinvestments.length %></span>
              <span class="stat-label">Closed Investments</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-icon stat-icon--info">
              <i class="fa-solid fa-coins"></i>
            </div>
            <div class="stat-body">
              <span class="stat-value"><%= totalcryptodeposits.length %></span>
              <span class="stat-label">Total Deposits</span>
            </div>
          </div>

        </div><!-- /.stats-row -->

        <!-- ── Charts Row ── -->
        <div class="section-label">Cash Flow</div>
        <div class="charts-row">

          <!-- Credit chart -->
          <div class="chart-card">
            <div class="chart-card-header">
              <div class="chart-card-title">
                <span class="chart-dot chart-dot--credit"></span>
                Cash In
              </div>
              <span class="chart-card-sub">Last 20 credit transactions</span>
            </div>
            <div class="chart-canvas-wrap">
              <canvas id="creditChart"></canvas>
            </div>
          </div>

          <!-- Debit chart -->
          <div class="chart-card">
            <div class="chart-card-header">
              <div class="chart-card-title">
                <span class="chart-dot chart-dot--debit"></span>
                Cash Out
              </div>
              <span class="chart-card-sub">Last 20 debit transactions</span>
            </div>
            <div class="chart-canvas-wrap">
              <canvas id="debitChart"></canvas>
            </div>
          </div>

          <!-- Pie chart -->
          <div class="chart-card chart-card--narrow">
            <div class="chart-card-header">
              <div class="chart-card-title">
                <span class="chart-dot chart-dot--accent"></span>
                Overview
              </div>
              <span class="chart-card-sub">Credit vs Debit ratio</span>
            </div>
            <div class="chart-canvas-wrap chart-canvas-wrap--pie">
              <canvas id="pieChart"></canvas>
            </div>
          </div>

        </div><!-- /.charts-row -->

        <!-- ── Bottom Row: Recent Users + Pending Actions ── -->
        <div class="section-label">Activity</div>
        <div class="bottom-row">

          <!-- Recent users -->
          <div class="list-card">
            <div class="list-card-header">
              <span class="list-card-title">Recent Users</span>
              <a href="/admin/admin.users" class="list-card-action">View all →</a>
            </div>
            <div class="list-card-body">
              <% if (users && users.length > 0) { %>
                <% users.slice(0, 8).forEach(function(u) {
                  const initials = ((u.firstname || '?')[0] + (u.lastname || '?')[0]).toUpperCase();
                  const isVerified = u.verificationstatus === 'Verified';
                  const isPending  = u.verificationstatus === 'Pending';
                  const isSuspended = u.accountStatus === 'Suspended';
                %>
                <a href="/admin/admin.user/<%= u._id %>" class="list-row">
                  <div class="list-avatar"><%= initials %></div>
                  <div class="list-info">
                    <span class="list-name"><%= u.firstname %> <%= u.lastname %></span>
                    <span class="list-meta"><%= u.email %></span>
                  </div>
                  <span class="list-badge
                    <%= isSuspended ? 'list-badge--danger' : isVerified ? 'list-badge--success' : isPending ? 'list-badge--warning' : 'list-badge--muted' %>">
                    <%= isSuspended ? 'Suspended' : isVerified ? 'Verified' : isPending ? 'Pending' : 'Unverified' %>
                  </span>
                </a>
                <% }); %>
              <% } else { %>
                <div class="list-empty">No users yet.</div>
              <% } %>
            </div>
          </div>

          <!-- Pending actions panel -->
          <div class="actions-col">

            <!-- Pending KYC -->
            <div class="list-card">
              <div class="list-card-header">
                <span class="list-card-title">KYC Requests</span>
                <a href="/admin/admin.verification-requests" class="list-card-action">View all →</a>
              </div>
              <div class="list-card-body">
                <% if (verificationrequest && verificationrequest.length > 0) { %>
                  <% verificationrequest.slice(0, 4).forEach(function(u) {
                    const initials = ((u.firstname || '?')[0] + (u.lastname || '?')[0]).toUpperCase();
                  %>
                  <a href="/admin/admin.verification-requests/<%= u._id %>" class="list-row">
                    <div class="list-avatar list-avatar--warning"><%= initials %></div>
                    <div class="list-info">
                      <span class="list-name"><%= u.firstname %> <%= u.lastname %></span>
                      <span class="list-meta"><%= u.country || 'Unknown' %></span>
                    </div>
                    <span class="list-badge list-badge--warning">Pending</span>
                  </a>
                  <% }); %>
                <% } else { %>
                  <div class="list-empty"><i class="fa-solid fa-circle-check" style="color:var(--success); margin-right:6px;"></i>All clear.</div>
                <% } %>
              </div>
            </div>

            <!-- Pending crypto deposits -->
            <div class="list-card">
              <div class="list-card-header">
                <span class="list-card-title">Pending Deposits</span>
                <a href="/admin/admin.deposit-requests" class="list-card-action">View all →</a>
              </div>
              <div class="list-card-body">
                <% if (pendingcryptodeposits && pendingcryptodeposits.length > 0) { %>
                  <% pendingcryptodeposits.slice(0, 4).forEach(function(dep) { %>
                  <a href="/admin/admin.view-deposit/<%= dep._id %>" class="list-row">
                    <div class="list-avatar list-avatar--info">
                      <i class="fa-brands fa-bitcoin" style="font-size:0.85rem;"></i>
                    </div>
                    <div class="list-info">
                      <span class="list-name"><%= dep.transactionmethod || dep.transactionType %></span>
                      <span class="list-meta amount">$<%= parseFloat(dep.amount || 0).toLocaleString('en-US', {minimumFractionDigits: 2}) %></span>
                    </div>
                    <span class="list-badge list-badge--warning">Review</span>
                  </a>
                  <% }); %>
                <% } else { %>
                  <div class="list-empty"><i class="fa-solid fa-circle-check" style="color:var(--success); margin-right:6px;"></i>No pending deposits.</div>
                <% } %>
              </div>
            </div>

            <!-- Pending transactions -->
            <div class="list-card">
              <div class="list-card-header">
                <span class="list-card-title">Pending Transfers</span>
                <a href="/admin/admin.pending-transactions" class="list-card-action">View all →</a>
              </div>
              <div class="list-card-body">
                <% if (pendingtransactions && pendingtransactions.length > 0) { %>
                  <% pendingtransactions.slice(0, 4).forEach(function(tx) { %>
                  <a href="/admin/<%= tx._id %>/admin.receipt" class="list-row">
                    <div class="list-avatar list-avatar--warning">
                      <i class="fa-solid fa-paper-plane" style="font-size:0.85rem;"></i>
                    </div>
                    <div class="list-info">
                      <span class="list-name"><%= tx.transferType || tx.transactionType %></span>
                      <span class="list-meta amount">$<%= parseFloat(tx.amount || 0).toLocaleString('en-US', {minimumFractionDigits: 2}) %></span>
                    </div>
                    <span class="list-badge list-badge--warning">Pending</span>
                  </a>
                  <% }); %>
                <% } else { %>
                  <div class="list-empty"><i class="fa-solid fa-circle-check" style="color:var(--success); margin-right:6px;"></i>No pending transfers.</div>
                <% } %>
              </div>
            </div>

          </div><!-- /.actions-col -->

        </div><!-- /.bottom-row -->

      </div><!-- /.admin-dashboard -->
    </div><!-- /.page-inner -->
  </div><!-- /.main-content -->

  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
  <script>
    const creditChartData = <%- creditChartData %>;
    const debitChartData  = <%- debitChartData %>;
    const pieChartData    = <%- pieChartData %>;

    /* ── Resolve theme colours from CSS vars ── */
    function cssVar(name) {
      return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
    }

    /* ── Shared chart defaults ── */
    Chart.defaults.font.family   = cssVar('--font-ui') || "'DM Sans', sans-serif";
    Chart.defaults.color         = cssVar('--text-muted') || '#4d5568';
    Chart.defaults.borderColor   = cssVar('--border') || 'rgba(255,255,255,0.07)';

    function gridColor() { return cssVar('--border'); }
    function textColor() { return cssVar('--text-secondary'); }

    /* ── Bar chart builder ── */
    function buildBar(id, data) {
      const ctx = document.getElementById(id);
      if (!ctx) return null;
      return new Chart(ctx, {
        type: 'bar',
        data: data,
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: cssVar('--bg-card'),
              borderColor: cssVar('--border-strong'),
              borderWidth: 1,
              titleColor: cssVar('--text-primary'),
              bodyColor: cssVar('--text-secondary'),
              padding: 10,
              callbacks: {
                label: ctx => ' $' + ctx.parsed.y.toLocaleString('en-US', {minimumFractionDigits: 2})
              }
            }
          },
          scales: {
            x: {
              grid: { color: gridColor(), drawBorder: false },
              ticks: { color: textColor(), maxRotation: 0, font: { size: 10 } }
            },
            y: {
              grid: { color: gridColor(), drawBorder: false },
              ticks: {
                color: textColor(),
                font: { size: 10 },
                callback: v => '$' + (v >= 1000 ? (v/1000).toFixed(0) + 'k' : v)
              }
            }
          }
        }
      });
    }

    /* ── Pie chart builder ── */
    function buildPie(id, data) {
      const ctx = document.getElementById(id);
      if (!ctx) return null;
      return new Chart(ctx, {
        type: 'doughnut',
        data: data,
        options: {
          responsive: true,
          maintainAspectRatio: false,
          cutout: '62%',
          plugins: {
            legend: {
              position: 'bottom',
              labels: {
                color: textColor(),
                padding: 16,
                font: { size: 11 },
                usePointStyle: true,
                pointStyleWidth: 10
              }
            },
            tooltip: {
              backgroundColor: cssVar('--bg-card'),
              borderColor: cssVar('--border-strong'),
              borderWidth: 1,
              titleColor: cssVar('--text-primary'),
              bodyColor: cssVar('--text-secondary'),
              padding: 10,
              callbacks: {
                label: ctx => ' $' + ctx.parsed.toLocaleString('en-US', {minimumFractionDigits: 2})
              }
            }
          }
        }
      });
    }

    const creditChart = buildBar('creditChart', creditChartData);
    const debitChart  = buildBar('debitChart',  debitChartData);
    const pieChart    = buildPie('pieChart',     pieChartData);

    /* Register for theme switcher re-render */
    window.__charts = [creditChart, debitChart, pieChart].filter(Boolean);
  </script>
</body>
</html>
