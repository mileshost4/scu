  <!-- WEALTH INTERACTIVE CALCULATOR -->
  <section class="svc-calculator">
    <div class="svc-container">
      <div class="section-header text-center reveal-up">
        <span class="section-tag"><i class="fa-solid fa-calculator"></i> Savings Calculator</span>
        <h2 class="section-title">See What Your Money<br/><em>Could Become</em></h2>
        <p class="section-sub" style="margin:0 auto;">Move the sliders. Watch your wealth grow.</p>
      </div>
      <div class="calc-card reveal-up d1">
        <div class="calc-inputs">
          <div class="calc-field">
            <label>Initial Deposit</label>
            <div class="calc-amount-display" id="depositDisplay">$10,000</div>
            <input type="range" id="depositRange" min="1000" max="500000" value="10000" step="1000"/>
            <div class="calc-range-labels"><span>$1,000</span><span>$500,000</span></div>
          </div>
          <div class="calc-field">
            <label>Monthly Contribution</label>
            <div class="calc-amount-display" id="monthlyDisplay">$500</div>
            <input type="range" id="monthlyRange" min="0" max="10000" value="500" step="100"/>
            <div class="calc-range-labels"><span>$0</span><span>$10,000</span></div>
          </div>
          <div class="calc-field">
            <label>Investment Period</label>
            <div class="calc-amount-display" id="yearsDisplay">5 years</div>
            <input type="range" id="yearsRange" min="1" max="30" value="5" step="1"/>
            <div class="calc-range-labels"><span>1 yr</span><span>30 yrs</span></div>
          </div>
          <div class="calc-field">
            <label>Interest Rate</label>
            <div class="calc-tabs">
              <button class="calc-tab active" data-rate="8">Savings<br/><span>8%</span></button>
              <button class="calc-tab" data-rate="11">Bonds<br/><span>11%</span></button>
              <button class="calc-tab" data-rate="15">Fixed Dep.<br/><span>15%</span></button>
            </div>
          </div>
        </div>
        <div class="calc-result">
          <div class="calc-res-label">Projected Total Value</div>
          <div class="calc-res-amount" id="totalResult">$0</div>
          <div class="calc-res-breakdown">
            <div class="crb-item">
              <span>Principal</span>
              <strong id="principalAmt">$0</strong>
            </div>
            <div class="crb-sep"></div>
            <div class="crb-item">
              <span>Interest Earned</span>
              <strong id="interestAmt" class="txt-gold">$0</strong>
            </div>
            <div class="crb-sep"></div>
            <div class="crb-item">
              <span>Return</span>
              <strong id="returnPct" class="txt-teal">0%</strong>
            </div>
          </div>
          <div class="calc-bar-wrap">
            <div class="calc-bar-principal" id="barPrincipal" style="width:50%"></div>
            <div class="calc-bar-interest" id="barInterest" style="width:50%"></div>
          </div>
          <a href="/register" class="btn-primary" style="margin-top:1.5rem;width:100%;justify-content:center;">Start Earning Now <i class="fa-solid fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

