  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // ── Scroll Reveal ──
    const revEls = document.querySelectorAll('.reveal-up');
    const revObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); revObs.unobserve(e.target); }});
    }, { threshold: 0.07 });
    revEls.forEach(el => revObs.observe(el));

    // ── Savings Calculator ──
    let calcRate = 8;
    const depositRange = document.getElementById('depositRange');
    const monthlyRange = document.getElementById('monthlyRange');
    const yearsRange = document.getElementById('yearsRange');

    function formatNum(n) {
      if (n >= 1000000) return '$' + (n/1000000).toFixed(2) + 'M';
      if (n >= 1000) return '$' + Math.round(n).toLocaleString();
      return '$' + n.toFixed(0);
    }

    function calcUpdate() {
      const P = parseFloat(depositRange.value);
      const M = parseFloat(monthlyRange.value);
      const Y = parseFloat(yearsRange.value);
      const r = calcRate / 100 / 12;
      const n = Y * 12;

      document.getElementById('depositDisplay').textContent = '$' + P.toLocaleString();
      document.getElementById('monthlyDisplay').textContent = '$' + M.toLocaleString();
      document.getElementById('yearsDisplay').textContent = Y + (Y === 1 ? ' year' : ' years');

      const fv = P * Math.pow(1 + r, n) + (r > 0 ? M * (Math.pow(1 + r, n) - 1) / r : M * n);
      const principal = P + M * n;
      const interest = fv - principal;
      const returnPct = ((fv - principal) / principal * 100);

      document.getElementById('totalResult').textContent = formatNum(fv);
      document.getElementById('principalAmt').textContent = formatNum(principal);
      document.getElementById('interestAmt').textContent = formatNum(interest);
      document.getElementById('returnPct').textContent = returnPct.toFixed(0) + '%';

      const pPct = Math.max(5, (principal / fv * 100));
      const iPct = 100 - pPct;
      document.getElementById('barPrincipal').style.width = pPct + '%';
      document.getElementById('barInterest').style.width = iPct + '%';
    }

    [depositRange, monthlyRange, yearsRange].forEach(el => el.addEventListener('input', calcUpdate));

    document.querySelectorAll('.calc-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.calc-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        calcRate = parseFloat(tab.dataset.rate);
        calcUpdate();
      });
    });

    calcUpdate();

    // ── Hero scroll indicator ──
    document.querySelector('.svc-hero-scroll')?.addEventListener('click', () => {
      document.querySelector('#personal')?.scrollIntoView({ behavior: 'smooth' });
    });

    // ── Smooth scroll for chips ──
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const t = document.querySelector(a.getAttribute('href'));
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); }
      });
    });
