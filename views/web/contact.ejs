  <!-- ══════════════════════════════════════
       BOTTOM CTA
  ══════════════════════════════════════════ -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner reveal-up">
        <h2 class="cta-headline">Not Yet a Customer? <em>Let's Change That.</em></h2>
        <p class="cta-sub">Open a free account in under 5 minutes. No branch visit. No paperwork. No minimum balance. 3 million customers already trust us — join them.</p>
        <div class="cta-actions">
          <a href="/register" class="btn-cta-primary">Open Free Account <i class="fa-solid fa-arrow-right"></i></a>
          <a href="/services" class="btn-cta-outline"><i class="fa-solid fa-grid-2"></i> Explore Services</a>
        </div>
        <p class="cta-note"><i class="fa-solid fa-circle-info"></i> FDIC Insured · FCA Regulated · ISO 27001 Certified</p>
