  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // ── Scroll Reveal ──
    const revEls = document.querySelectorAll('.reveal-up');
    const revObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('revealed'); revObs.unobserve(e.target); }});
    }, { threshold: 0.07 });
    revEls.forEach(el => revObs.observe(el));

    // ── Smooth scroll for anchors ──
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const t = document.querySelector(a.getAttribute('href'));
        if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); }
      });
    });

    // ── FAQ Accordion ──
    document.querySelectorAll('.faq-trigger').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.faq-item');
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        if (!isOpen) item.classList.add('open');
      });
    });

    // ── Character count ──
    const msgTextarea = document.getElementById('ctMessage');
    const charCount = document.getElementById('charCount');
    if (msgTextarea) {
      msgTextarea.addEventListener('input', () => {
        const len = msgTextarea.value.length;
        charCount.textContent = len;
        charCount.style.color = len > 1800 ? 'var(--coral)' : 'var(--text-muted)';
      });
    }

    // ── Input focus effects ──
    document.querySelectorAll('.ct-input-wrap input, .ct-input-wrap select, .ct-textarea-wrap textarea').forEach(el => {
      el.addEventListener('focus', () => el.closest('.ct-input-wrap, .ct-textarea-wrap')?.classList.add('focused'));
      el.addEventListener('blur', () => el.closest('.ct-input-wrap, .ct-textarea-wrap')?.classList.remove('focused'));
    });

    // ── Range slider color update for calculator if present ──
    function updateRange(input) {
      const min = parseFloat(input.min);
      const max = parseFloat(input.max);
      const val = parseFloat(input.value);
      const pct = ((val - min) / (max - min)) * 100;
      input.style.background = `linear-gradient(to right, var(--teal) 0%, var(--teal) ${pct}%, var(--border) ${pct}%, var(--border) 100%)`;
    }

    // ── CONTACT FORM — Submit via mailto ──
    document.getElementById('ctSubmitBtn')?.addEventListener('click', function () {
      let valid = true;

      const firstName = document.getElementById('ctFirstName').value.trim();
      const lastName  = document.getElementById('ctLastName').value.trim();
      const email     = document.getElementById('ctEmail').value.trim();
      const phone     = document.getElementById('ctPhone').value.trim();
      const subjectEl = document.getElementById('ctSubject');
      const subject   = subjectEl.value;
      const message   = document.getElementById('ctMessage').value.trim();
      const consent   = document.getElementById('ctConsent').checked;
      const acctType  = document.querySelector('input[name="acctType"]:checked')?.value || 'Not specified';
      const priority  = document.querySelector('input[name="priority"]:checked')?.value || 'Normal';

      // Validate
      const setErr = (id, msg) => { document.getElementById(id).textContent = msg; };
      const clearErr = (id) => { document.getElementById(id).textContent = ''; };

      if (!firstName) { setErr('errFirst', 'Please enter your first name.'); valid = false; }
      else clearErr('errFirst');

      if (!lastName) { setErr('errLast', 'Please enter your last name.'); valid = false; }
      else clearErr('errLast');

      const emailReg = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!email) { setErr('errEmail', 'Please enter your email address.'); valid = false; }
      else if (!emailReg.test(email)) { setErr('errEmail', 'Please enter a valid email address.'); valid = false; }
      else clearErr('errEmail');

      if (!subject) { setErr('errSubject', 'Please select a subject.'); valid = false; }
      else clearErr('errSubject');

      if (!message) { setErr('errMsg', 'Please enter your message.'); valid = false; }
      else if (message.length < 20) { setErr('errMsg', 'Please provide a more detailed message (min 20 characters).'); valid = false; }
      else clearErr('errMsg');

      if (!consent) { setErr('errConsent', 'You must agree to the Privacy Policy to submit.'); valid = false; }
      else clearErr('errConsent');

      if (!valid) {
        // Scroll to first error
        const firstErr = document.querySelector('.ct-err:not(:empty)');
        if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      // Build mailto
      const toEmail = 'support@sterlingcrestunion.com';
      const emailSubject = encodeURIComponent(`[${priority}] ${subject} — Sterling Crest Union`);
      const body = [
        `Dear Sterling Crest Union Support Team,`,
        ``,
        `I am writing to you regarding the following matter:`,
        ``,
        `------------------------------------------------------------`,
        `SUBJECT:    ${subject}`,
        `PRIORITY:   ${priority}`,
        `ACCOUNT TYPE: ${acctType}`,
        `------------------------------------------------------------`,
        ``,
        `${message}`,
        ``,
        `------------------------------------------------------------`,
        ``,
        `Kind regards,`,
        `${firstName} ${lastName}`,
        `Email: ${email}`,
        phone ? `Phone: ${phone}` : null,
        ``,
        `[This message was composed via the Sterling Crest Union contact form]`
      ].filter(line => line !== null).join('\n');

      const mailtoLink = `mailto:${toEmail}?subject=${emailSubject}&body=${encodeURIComponent(body)}`;

      // Open mailto
      window.location.href = mailtoLink;

      // Show success after short delay
      setTimeout(() => {
        document.getElementById('ctFormBody').style.display = 'none';
        document.getElementById('ctFormSuccess').style.display = 'flex';
      }, 800);
    });

    // Reset form
    document.getElementById('ctResetBtn')?.addEventListener('click', function () {
      document.getElementById('ctFirstName').value = '';
      document.getElementById('ctLastName').value = '';
      document.getElementById('ctEmail').value = '';
      document.getElementById('ctPhone').value = '';
      document.getElementById('ctSubject').value = '';
      document.getElementById('ctMessage').value = '';
      document.getElementById('ctConsent').checked = false;
      document.getElementById('charCount').textContent = '0';
      document.querySelectorAll('.ct-err').forEach(e => e.textContent = '');
      document.getElementById('ctFormBody').style.display = '';
      document.getElementById('ctFormSuccess').style.display = 'none';
    });
  </script>
</body>
</html>
