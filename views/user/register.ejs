<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <title>Create Account</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://www.google.com/recaptcha/api.js" async defer></script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <link rel="stylesheet" href="/stylesheets/partials/flash.css">
  <link rel="stylesheet" href="/stylesheets/partials/theme.css">

  <style>
    /* ── Auth page layout ─────────────────────────────────────── */
    .auth-root {
      min-height: 100vh;
      display: flex;
      align-items: stretch;
      background: var(--bg-root);
      position: relative;
      overflow: hidden;
    }

    /* Subtle grid overlay */
    .auth-root::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(var(--border) 1px, transparent 1px),
        linear-gradient(90deg, var(--border) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      z-index: 0;
    }

    /* Accent glow blobs */
    .auth-root::after {
      content: '';
      position: fixed;
      width: 600px;
      height: 600px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
      top: -200px;
      right: -150px;
      pointer-events: none;
      z-index: 0;
    }

    .glow-blob-2 {
      position: fixed;
      width: 400px;
      height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(77,159,255,0.10) 0%, transparent 70%);
      bottom: -100px;
      left: -100px;
      pointer-events: none;
      z-index: 0;
    }

    /* ── Scroll wrapper ───────────────────────────────────────── */
    .auth-scroll {
      position: relative;
      z-index: 1;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 16px;
    }

    /* ── Card ─────────────────────────────────────────────────── */
    .auth-card {
      width: 100%;
      max-width: 460px;
      background: var(--bg-card);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-xl);
      padding: 40px 36px 36px;
      box-shadow: var(--shadow-lg);
      animation: fadeIn 0.4s ease both;
    }

    @media (max-width: 520px) {
      .auth-card { padding: 28px 20px 24px; }
    }

    /* ── Header ───────────────────────────────────────────────── */
    .auth-logo-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: 24px;
    }

    .auth-logo {
      height: 44px;
      width: auto;
    }

    .auth-header { margin-bottom: 28px; }

    .auth-title {
      font-family: var(--font-display);
      font-size: 1.65rem;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.2;
      margin-bottom: 6px;
    }

    .auth-subtitle {
      font-size: 0.85rem;
      color: var(--text-secondary);
    }

    /* ── Section divider ──────────────────────────────────────── */
    .form-section-label {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 20px 0 12px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .form-section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── Input group ──────────────────────────────────────────── */
    .field {
      margin-bottom: 14px;
    }

    .field-label {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 6px;
    }

    .input-wrap {
      position: relative;
    }

    .input-wrap .field-icon {
      position: absolute;
      left: 13px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-muted);
      font-size: 13px;
      pointer-events: none;
      transition: color 0.2s;
    }

    .field-input,
    .field-select {
      width: 100%;
      padding: 10px 14px 10px 38px;
      background: var(--bg-input);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      color: var(--text-primary);
      font-family: var(--font-ui);
      font-size: 0.88rem;
      outline: none;
      transition: var(--transition);
      appearance: none;
      -webkit-appearance: none;
    }

    .field-input::placeholder { color: var(--text-muted); }

    .field-input:focus,
    .field-select:focus {
      border-color: var(--border-focus);
      box-shadow: 0 0 0 3px var(--accent-dim);
    }

    .input-wrap:focus-within .field-icon {
      color: var(--accent);
    }

    .field-select option {
      background: var(--bg-surface);
      color: var(--text-primary);
    }

    /* Read-only currency fields */
    .field-input[readonly] {
      opacity: 0.7;
      cursor: default;
      background: var(--bg-surface);
    }

    /* ── Two-col row ──────────────────────────────────────────── */
    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    @media (max-width: 420px) {
      .field-row { grid-template-columns: 1fr; }
    }

    /* ── reCAPTCHA wrapper ────────────────────────────────────── */
    .recaptcha-wrap {
      margin: 18px 0;
      display: flex;
      justify-content: center;
    }

    /* ── Submit button ────────────────────────────────────────── */
    .auth-btn {
      width: 100%;
      padding: 13px;
      border: none;
      border-radius: var(--radius-md);
      background: var(--accent);
      color: var(--text-inverse);
      font-family: var(--font-ui);
      font-size: 0.92rem;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      letter-spacing: 0.03em;
      transition: var(--transition);
    }

    .auth-btn:hover:not(:disabled) {
      background: var(--accent-dark);
      box-shadow: var(--shadow-accent);
      transform: translateY(-1px);
    }

    .auth-btn:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      transform: none;
    }

    /* ── Footer link ──────────────────────────────────────────── */
    .auth-footer {
      text-align: center;
      font-size: 0.82rem;
      color: var(--text-secondary);
      margin-top: 20px;
    }

    .auth-footer a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }

    .auth-footer a:hover { text-decoration: underline; }

    /* ── Theme toggle (top-right) ─────────────────────────────── */
    .theme-fab {
      position: fixed;
      top: 18px;
      right: 18px;
      z-index: 100;
      display: flex;
      gap: 6px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-full);
      padding: 4px;
      box-shadow: var(--shadow-sm);
    }

    .theme-fab button {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      border: none;
      background: transparent;
      color: var(--text-secondary);
      cursor: pointer;
      font-size: 13px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: var(--transition);
    }

    .theme-fab button:hover,
    .theme-fab button.active {
      background: var(--accent-dim);
      color: var(--accent);
    }
  </style>
</head>
<body>

<div class="glow-blob-2"></div>

<!-- Theme toggle -->
<div class="theme-fab">
  <button onclick="setTheme('dark')"  title="Dark"  data-theme-opt="dark">
    <i class="fa-solid fa-moon"></i>
  </button>
  <button onclick="setTheme('light')" title="Light" data-theme-opt="light">
    <i class="fa-solid fa-sun"></i>
  </button>
</div>

<div class="auth-root">
  <div class="auth-scroll">
    <div class="auth-card">

      <!-- Logo -->
      <div class="auth-logo-wrap">
        <a href="/"><img src="/images/logo.png" class="auth-logo" alt="Logo"></a>
      </div>

      <!-- Header -->
      <div class="auth-header">
        <h1 class="auth-title">Create Account</h1>
        <p class="auth-subtitle">Open your account in under 3 minutes.</p>
      </div>

      <!-- Flash messages -->
      <%- partial('../partials/flash') %>

      <form action="/register" method="post" id="registerForm">

        <!-- ── Personal Info ────────────────────────────────── -->
        <div class="form-section-label">Personal Info</div>

        <div class="field-row">
          <div class="field">
            <label class="field-label">First Name</label>
            <div class="input-wrap">
              <i class="fas fa-user field-icon"></i>
              <input class="field-input" type="text" name="firstname" placeholder="First name" required>
            </div>
          </div>
          <div class="field">
            <label class="field-label">Last Name</label>
            <div class="input-wrap">
              <i class="fas fa-user field-icon"></i>
              <input class="field-input" type="text" name="lastname" placeholder="Last name" required>
            </div>
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label class="field-label">Date of Birth</label>
            <div class="input-wrap">
              <i class="fa-solid fa-calendar field-icon"></i>
              <input class="field-input" type="date" name="dob" id="dob" required>
            </div>
          </div>
          <div class="field">
            <label class="field-label">Sex</label>
            <div class="input-wrap">
              <i class="fas fa-venus field-icon"></i>
              <select class="field-select" name="gender" required>
                <option value="">Select sex</option>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>
        </div>

        <!-- ── Contact ─────────────────────────────────────── -->
        <div class="form-section-label">Contact</div>

        <div class="field">
          <label class="field-label">Email Address</label>
          <div class="input-wrap">
            <i class="fas fa-envelope field-icon"></i>
            <input class="field-input" type="email" name="email" placeholder="you@example.com" required>
          </div>
        </div>

        <div class="field">
          <label class="field-label">Phone Number</label>
          <div class="input-wrap">
            <i class="fas fa-phone field-icon"></i>
            <input class="field-input" type="tel" name="phonenumber" placeholder="+1 555 000 0000" required>
          </div>
        </div>

        <!-- ── Location & Currency ─────────────────────────── -->
        <div class="form-section-label">Location &amp; Currency</div>

        <div class="field">
          <label class="field-label">Country</label>
          <div class="input-wrap">
            <i class="fas fa-flag field-icon"></i>
            <select class="field-select" name="country" id="country" required>
              <option value="">Select country</option>
              <% countries.forEach(function(c) { %>
                <option value="<%= c.name %>"><%= c.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label class="field-label">Currency Code</label>
            <div class="input-wrap">
              <i class="fas fa-money-bill field-icon"></i>
              <input class="field-input" type="text" id="basecurrency" name="basecurrency" placeholder="Auto-filled" readonly>
            </div>
          </div>
          <div class="field">
            <label class="field-label">Currency Symbol</label>
            <div class="input-wrap">
              <i class="fas fa-dollar-sign field-icon"></i>
              <input class="field-input" type="text" id="currencySymbol" name="basecurrencysymbol" placeholder="Auto-filled" readonly>
            </div>
          </div>
        </div>

        <!-- ── Account ─────────────────────────────────────── -->
        <div class="form-section-label">Account</div>

        <div class="field">
          <label class="field-label">Account Type</label>
          <div class="input-wrap">
            <i class="fa-solid fa-id-card field-icon"></i>
            <select class="field-select" name="accountType" id="accountType" required>
              <option value="">Select account type</option>
              <option value="Savings">Savings</option>
              <option value="Current">Current</option>
              <option value="Checkings">Checkings</option>
              <option value="Business">Business</option>
              <option value="Fixed Deposit">Fixed Deposit</option>
            </select>
          </div>
        </div>

        <div class="field">
          <label class="field-label">Password</label>
          <div class="input-wrap">
            <i class="fas fa-lock field-icon"></i>
            <input class="field-input" type="password" name="password" placeholder="Create a password" required>
          </div>
        </div>

        <div class="field">
          <label class="field-label">Confirm Password</label>
          <div class="input-wrap">
            <i class="fas fa-lock field-icon"></i>
            <input class="field-input" type="password" name="confirmpassword" placeholder="Repeat password" required>
          </div>
        </div>

        <!-- reCAPTCHA -->
        <div class="recaptcha-wrap">
          <div class="g-recaptcha" data-sitekey="6LfYZCorAAAAACEDFju2KGwYQVWjGep-M0VSDzP0"></div>
        </div>

        <button class="auth-btn" type="submit" id="submitBtn">
          <i class="fas fa-user-plus"></i>
          <span id="btnLabel">Create Account</span>
        </button>

      </form>

      <div class="auth-footer">
        Already have an account? <a href="/login">Sign In</a>
      </div>

    </div><!-- /auth-card -->
  </div>
</div>

<!-- Currency map (server-injected, no network round-trip) -->
<script>
  const CURRENCY_MAP = <%- currencyMapJSON %>;

  document.getElementById('country').addEventListener('change', function () {
    const val = this.value;
    const data = CURRENCY_MAP[val] || {};
    document.getElementById('basecurrency').value  = data.currency || '';
    document.getElementById('currencySymbol').value = data.symbol  || '';
  });
</script>

<!-- Form loading state -->
<script>
  const form    = document.getElementById('registerForm');
  const btn     = document.getElementById('submitBtn');
  const btnLbl  = document.getElementById('btnLabel');

  form.addEventListener('submit', function () {
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating account…';
  });
</script>

<!-- Theme logic -->
<script>
  function setTheme(mode) {
    let resolved = mode;
    if (mode === 'system') {
      resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    document.documentElement.setAttribute('data-theme', resolved);
    localStorage.setItem('theme', mode);
    document.querySelectorAll('.theme-fab button').forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.themeOpt === mode);
    });
  }

  // Apply saved theme immediately
  (function() {
    setTheme(localStorage.getItem('theme') || 'dark');
  })();
</script>

</body>
</html>
