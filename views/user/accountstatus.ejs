<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Account Status | <%= websiteName %></title>

  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/user/accountstatus.css" />
</head>
<body>

  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="status-page fade-in">

        <%
          // Determine state config
          let stateConfig = {};
          if (user.accountStatus === 'Suspended') {
            stateConfig = {
              icon: 'fa-ban',
              iconClass: 'icon--danger',
              title: 'Account Suspended',
              headline: 'Your account has been suspended',
              description: 'Your account access has been temporarily restricted due to a policy violation or security concern. Please contact our support team to resolve this.',
              badgeClass: 'badge-danger',
              badgeText: 'Suspended',
              showContact: true,
              showDashboard: false
            };
          } else if (user.accountStatus === 'Disabled') {
            stateConfig = {
              icon: 'fa-lock',
              iconClass: 'icon--warning',
              title: 'Account Disabled',
              headline: 'Your account has been disabled',
              description: 'Your account is currently disabled. This may be temporary or require action on your part. Please reach out to our support team for assistance.',
              badgeClass: 'badge-warning',
              badgeText: 'Disabled',
              showContact: true,
              showDashboard: false
            };
          } else if (user.accountStatus === 'Not Active') {
            stateConfig = {
              icon: 'fa-circle-pause',
              iconClass: 'icon--info',
              title: 'Account Not Active',
              headline: 'Your account is not yet active',
              description: 'Your account has been created but is pending activation. Please complete your identity verification or contact support if this persists.',
              badgeClass: 'badge-info',
              badgeText: 'Not Active',
              showContact: true,
              showDashboard: false
            };
          } else {
            stateConfig = {
              icon: 'fa-circle-check',
              iconClass: 'icon--success',
              title: 'Account Active',
              headline: 'Your account is active',
              description: 'Everything looks good. Your account is fully active and in good standing.',
              badgeClass: 'badge-success',
              badgeText: 'Active',
              showContact: false,
              showDashboard: true
            };
          }
        %>

        <div class="status-center">
          <!-- Icon -->
          <div class="status-icon-wrap <%= stateConfig.iconClass %>">
            <i class="fa-solid <%= stateConfig.icon %>"></i>
          </div>

          <!-- Badge -->
          <span class="badge <%= stateConfig.badgeClass %> status-badge">
            <%= stateConfig.badgeText %>
          </span>

          <!-- Text -->
          <h1 class="status-headline"><%= stateConfig.headline %></h1>
          <p class="status-description"><%= stateConfig.description %></p>

          <!-- User info strip -->
          <div class="status-user-strip">
            <div class="strip-item">
              <span class="strip-label">Account Holder</span>
              <span class="strip-value"><%= user.firstname %> <%= user.lastname %></span>
            </div>
            <div class="strip-divider"></div>
            <div class="strip-item">
              <span class="strip-label">Account Number</span>
              <span class="strip-value font-mono"><%= user.accountNumber %></span>
            </div>
            <div class="strip-divider"></div>
            <div class="strip-item">
              <span class="strip-label">Email</span>
              <span class="strip-value"><%= user.email %></span>
            </div>
          </div>

          <!-- Actions -->
          <div class="status-actions">
            <% if (stateConfig.showContact) { %>
              <a href="/user/support" class="btn btn-primary">
                <i class="fa-regular fa-headset"></i>
                Contact Support
              </a>
              <a href="/logout" class="btn btn-ghost">
                <i class="fa-solid fa-right-from-bracket"></i>
                Sign Out
              </a>
            <% } %>
            <% if (stateConfig.showDashboard) { %>
              <a href="/dashboard" class="btn btn-primary">
                <i class="fa-solid fa-house"></i>
                Go to Dashboard
              </a>
            <% } %>
          </div>

          <!-- Help block (only for restricted accounts) -->
          <% if (stateConfig.showContact) { %>
          <div class="status-help">
            <p class="help-title"><i class="fa-regular fa-circle-question"></i> What can I do?</p>
            <ul class="help-list">
              <li>Contact our support team via the link above</li>
              <li>Provide your account number and a description of the issue</li>
              <li>Our team typically responds within 1–2 business days</li>
            </ul>
          </div>
          <% } %>

        </div>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
</body>
</html>
