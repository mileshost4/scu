<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Intra-Bank Transfer | <%= websiteName %></title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/user/transfer.css" />
</head>
<body>

  <% locals.currentPath = '/user/transactions'; %>
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="transfer-page fade-in">

        <!-- PAGE HEADER -->
        <div class="page-header">
          <div class="page-header-left">
            <h1>
              <span class="ph-icon" style="background:var(--accent-dim);color:var(--accent)">
                <i class="fa-solid fa-building-columns"></i>
              </span>
              Intra-Bank Transfer
            </h1>
            <p>Transfer funds instantly between accounts within this bank.</p>
          </div>
          <div style="display:flex;gap:10px">
            <a href="/user/transactions" class="btn btn-ghost btn-sm"><i class="fa-solid fa-grid-2"></i> All Transfers</a>
            <a href="/user/transaction-history" class="btn btn-ghost btn-sm"><i class="fa-solid fa-clock-rotate-left"></i> History</a>
          </div>
        </div>

        <div class="transfer-body">
          <div class="transfer-main">

            <!-- HERO -->
            <div class="transfer-hero">
              <div class="transfer-hero-label">You are sending</div>
              <div class="transfer-hero-amount">
                <span class="currency-sym"><%= user.basecurrencysymbol || '$' %></span><span id="intra-hero-amount">0.00</span>
              </div>
              <div class="transfer-hero-meta">
                <div class="transfer-hero-pill"><i class="fa-solid fa-bolt"></i> Instant settlement</div>
                <div class="transfer-hero-pill"><i class="fa-solid fa-building-columns"></i> Same bank</div>
                <div class="transfer-hero-pill"><i class="fa-solid fa-shield-halved"></i> PIN secured</div>
              </div>
            </div>

            <!-- TRANSFER FORM -->
            <div class="section-card">
              <div class="section-head">
                <div class="section-title">
                  <i class="fa-solid fa-building-columns"></i>
                  Transfer Details
                </div>
                <span class="badge badge-accent">Intra-Bank</span>
              </div>
              <div class="section-body">

                <!-- STEP 1: Source account -->
                <div style="margin-bottom:22px">
                  <div class="form-label" style="margin-bottom:12px">
                    <i class="fa-solid fa-1" style="background:var(--accent);color:var(--text-inverse);width:20px;height:20px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:0.65rem;margin-right:8px"></i>
                    Select source account
                  </div>
                  <div class="account-selector" id="intra-account-selector">
                    <% allaccounts.forEach(function(acct, idx) { %>
                      <label class="account-option <%= idx === 0 ? 'selected' : '' %>" for="intra-acct-<%= acct._id %>">
                        <input type="radio" name="intra_account_select" id="intra-acct-<%= acct._id %>"
                          value="<%= acct._id %>"
                          data-balance="<%= parseFloat(acct.accountWallet) %>"
                          data-number="<%= acct.accountNumber %>"
                          <%= idx === 0 ? 'checked' : '' %>
                          onchange="selectIntraAccount(this)" />
                        <div class="account-option-radio"></div>
                        <div class="account-option-icon"><i class="fa-solid fa-building-columns"></i></div>
                        <div class="account-option-info">
                          <div class="account-option-name"><%= acct.displayName || acct.accountType %></div>
                          <div class="account-option-meta">
                            <span>•••• <%= String(acct.accountNumber).slice(-4) %></span>
                            <span>·</span>
                            <span><%= acct.accountType %></span>
                          </div>
                        </div>
                        <div class="account-option-balance">
                          <%= user.basecurrencysymbol || '$' %><%= parseFloat(acct.accountWallet).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %>
                        </div>
                      </label>
                    <% }); %>
                  </div>
                </div>

                <!-- STEP 2: Transfer details form -->
                <div class="form-label" style="margin-bottom:16px">
                  <i class="fa-solid fa-2" style="background:var(--accent);color:var(--text-inverse);width:20px;height:20px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:0.65rem;margin-right:8px"></i>
                  Recipient & amount
                </div>

                <!-- Hidden form — submitted via PIN modal confirm -->
                <form id="intraTransferForm" action="/user/intrabank-transfer" method="POST" class="transfer-form">
                  <input type="hidden" name="account" id="intra-account-hidden" value="<%= allaccounts.length ? allaccounts[0]._id : '' %>" />
                  <input type="hidden" name="transferPin" id="intra-pin-hidden" />

                  <div class="form-row" style="margin-bottom:18px">
                    <div class="form-group">
                      <label class="form-label" for="intra-receiver-name">Recipient full name</label>
                      <input type="text" class="form-control" id="intra-receiver-name" name="receiverAccountName"
                        placeholder="e.g. John Doe" required autocomplete="off"
                        oninput="updateIntraSummary()" />
                    </div>
                    <div class="form-group">
                      <label class="form-label" for="intra-receiver-acct">Recipient account number</label>
                      <input type="number" class="form-control" id="intra-receiver-acct" name="receiverAccountNumber"
                        placeholder="10-digit account number" required autocomplete="off"
                        oninput="updateIntraSummary()" />
                    </div>
                  </div>

                  <div class="form-group" style="margin-bottom:18px">
                    <label class="form-label" for="intra-amount">Amount</label>
                    <div class="amount-input-wrap">
                      <span class="amount-currency-prefix"><%= user.basecurrencysymbol || '$' %></span>
                      <input type="number" class="form-control" id="intra-amount" name="amount"
                        placeholder="0.00" min="1" step="0.01" required
                        oninput="updateIntraHero(this.value); updateIntraSummary()" />
                    </div>
                    <div class="balance-hint">
                      <span class="avail">
                        <i class="fa-solid fa-circle-check"></i>
                        Available: <strong id="intra-avail-bal"><%= user.basecurrencysymbol || '$' %><%= allaccounts.length ? parseFloat(allaccounts[0].accountWallet).toLocaleString(undefined,{minimumFractionDigits:2}) : '0.00' %></strong>
                      </span>
                      <button type="button" class="use-all-btn" onclick="useIntraMaxBal()">Use max</button>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="form-label" for="intra-description">Narration / description <span style="color:var(--text-muted);font-weight:400">(optional)</span></label>
                    <input type="text" class="form-control" id="intra-description" name="description"
                      placeholder="e.g. Rent payment, Invoice #123" maxlength="120"
                      oninput="updateIntraSummary()" />
                  </div>

                  <!-- Summary -->
                  <div class="transfer-summary">
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-solid fa-user"></i> Recipient</span>
                      <span class="summary-value" id="intra-sum-name">—</span>
                    </div>
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-solid fa-hashtag"></i> Account</span>
                      <span class="summary-value" id="intra-sum-acct">—</span>
                    </div>
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-solid fa-building-columns"></i> Transfer type</span>
                      <span class="summary-value">Intra-Bank</span>
                    </div>
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-solid fa-bolt"></i> Settlement</span>
                      <span class="summary-value" style="color:var(--success)">Instant</span>
                    </div>
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-solid fa-dollar-sign"></i> Amount</span>
                      <span class="summary-value amount" id="intra-sum-amount">—</span>
                    </div>
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-regular fa-comment"></i> Narration</span>
                      <span class="summary-value" id="intra-sum-desc" style="font-family:var(--font-ui);font-style:italic;color:var(--text-muted)">—</span>
                    </div>
                  </div>

                  <div class="transfer-submit-row">
                    <a href="/user/transactions" class="btn btn-ghost btn-sm">
                      <i class="fa-solid fa-arrow-left"></i> Back
                    </a>
                    <button type="button" class="btn btn-primary" onclick="openPinModal('intraTransferForm', 'intra')">
                      <i class="fa-solid fa-shield-halved"></i> Authorise & Send
                    </button>
                  </div>
                </form>

              </div>
            </div>

          </div>

          <!-- ASIDE -->
          <div class="transfer-aside">
            <!-- Type badge -->
            <div class="widget">
              <div class="widget-head">
                <span class="widget-title"><i class="fa-solid fa-circle-info"></i> Transfer Type</span>
              </div>
              <div class="widget-body">
                <div class="transfer-type-badge">
                  <div class="ttb-icon"><i class="fa-solid fa-building-columns"></i></div>
                  <div class="ttb-info">
                    <div class="ttb-name">Intra-Bank</div>
                    <div class="ttb-desc">Same-bank transfers. Funds move instantly between accounts.</div>
                  </div>
                </div>
                <div class="tip-list">
                  <div class="tip-item"><i class="fa-solid fa-bolt"></i>Instant — no processing delay.</div>
                  <div class="tip-item"><i class="fa-solid fa-shield-halved"></i>Your PIN authorises every transfer.</div>
                  <div class="tip-item"><i class="fa-solid fa-triangle-exclamation"></i>Ensure account number is correct before submitting.</div>
                </div>
              </div>
            </div>

            <!-- Balance -->
            <div class="widget">
              <div class="widget-head">
                <span class="widget-title"><i class="fa-solid fa-wallet"></i> My Accounts</span>
              </div>
              <div class="widget-body">
                <div class="balance-account-list">
                  <% allaccounts.forEach(function(acct) { %>
                    <div class="balance-account-item">
                      <span class="bal-acct-name">
                        <span class="bal-acct-dot"></span>
                        <%= acct.displayName || acct.accountType %>
                      </span>
                      <span class="bal-acct-value">
                        <%= user.basecurrencysymbol || '$' %><%= parseFloat(acct.accountWallet).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %>
                      </span>
                    </div>
                  <% }); %>
                </div>
              </div>
            </div>

            <!-- Recent -->
            <div class="widget">
              <div class="widget-head">
                <span class="widget-title"><i class="fa-solid fa-clock-rotate-left"></i> Recent</span>
                <a href="/user/transaction-history" style="font-size:0.75rem;color:var(--accent);text-decoration:none;font-weight:600">All →</a>
              </div>
              <div class="tx-list">
                <% const intraTx = transactions.filter(t => t.transferType === 'Intra-Bank').slice(0,4); %>
                <% if (intraTx.length > 0) { %>
                  <% intraTx.forEach(function(tx) { %>
                    <a href="/user/transaction/<%= tx._id %>/receipt" class="tx-item">
                      <div class="tx-icon <%= tx.status === 'Pending' ? 'pending' : 'transfer' %>">
                        <i class="fa-solid fa-building-columns"></i>
                      </div>
                      <div class="tx-info">
                        <div class="tx-name"><%= (tx.receiverAccountName || '—').substring(0,20) %></div>
                        <div class="tx-meta">
                          <span class="badge badge-<%= tx.status === 'Successful' ? 'success' : tx.status === 'Pending' ? 'warning' : 'danger' %>" style="padding:1px 5px;font-size:0.6rem"><%= tx.status %></span>
                        </div>
                      </div>
                      <div class="tx-right">
                        <div class="tx-amount">-<%= user.basecurrencysymbol || '$' %><%= parseFloat(tx.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %></div>
                        <div class="tx-date"><%= new Date(tx.date).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %></div>
                      </div>
                    </a>
                  <% }); %>
                <% } else { %>
                  <div class="tx-empty"><i class="fa-solid fa-building-columns"></i>No intra-bank transfers</div>
                <% } %>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- PIN MODAL -->
  <div class="custom-modal-overlay" id="pinModal" onclick="handlePinOverlayClick(event)">
    <div class="pin-modal">
      <div class="pin-modal-header">
        <div class="pin-modal-title">
          <span class="pin-modal-icon"><i class="fa-solid fa-lock"></i></span>
          Confirm Transfer
        </div>
        <button class="pin-modal-close" onclick="closePinModal()"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="pin-modal-body">
        <div class="pin-confirm-summary" id="pin-summary">
          <div class="pin-confirm-row">
            <span class="pcr-label">To</span>
            <span class="pcr-value" id="pin-sum-name">—</span>
          </div>
          <div class="pin-confirm-row">
            <span class="pcr-label">Account</span>
            <span class="pcr-value" id="pin-sum-acct">—</span>
          </div>
          <div class="pin-confirm-row">
            <span class="pcr-label">Amount</span>
            <span class="pcr-value highlight" id="pin-sum-amount">—</span>
          </div>
          <div class="pin-confirm-row">
            <span class="pcr-label">Type</span>
            <span class="pcr-value" id="pin-sum-type">Intra-Bank</span>
          </div>
        </div>

        <div class="pin-dots-wrap" id="pinDots">
          <% for(let i=0;i<4;i++) { %>
            <div class="pin-dot" id="pinDot<%= i %>"></div>
          <% } %>
        </div>

        <div class="pin-input-wrap">
          <input type="password" class="form-control" id="pinInput"
            placeholder="Enter your transaction PIN"
            maxlength="4" inputmode="numeric" autocomplete="off"
            oninput="onPinInput(this.value)" />
          <button type="button" class="pin-input-toggle" onclick="togglePinVisibility()">
            <i class="fa-solid fa-eye" id="pinEyeIcon"></i>
          </button>
        </div>
        <div class="pin-error-msg" id="pinErrorMsg">Incorrect PIN. Please try again.</div>
      </div>
      <div class="pin-modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closePinModal()">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="submitWithPin()">
          <i class="fa-solid fa-paper-plane"></i> Confirm Transfer
        </button>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
  <script>
    /* ── Account selector ── */
    let intraSelectedBalance = <%= allaccounts.length ? parseFloat(allaccounts[0].accountWallet) : 0 %>;

    document.querySelectorAll('#intra-account-selector .account-option').forEach(function(opt) {
      opt.addEventListener('click', function() {
        document.querySelectorAll('#intra-account-selector .account-option').forEach(o => o.classList.remove('selected'));
        this.classList.add('selected');
      });
    });

    function selectIntraAccount(radio) {
      intraSelectedBalance = parseFloat(radio.dataset.balance) || 0;
      document.getElementById('intra-account-hidden').value = radio.value;
      document.getElementById('intra-avail-bal').textContent =
        '<%= user.basecurrencysymbol || "$" %>' + intraSelectedBalance.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2});
      updateIntraSummary();
    }

    function useIntraMaxBal() {
      document.getElementById('intra-amount').value = intraSelectedBalance.toFixed(2);
      updateIntraHero(intraSelectedBalance);
      updateIntraSummary();
    }

    function updateIntraHero(val) {
      const n = parseFloat(val) || 0;
      document.getElementById('intra-hero-amount').textContent =
        n.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2});
    }

    function updateIntraSummary() {
      const name   = document.getElementById('intra-receiver-name').value || '—';
      const acct   = document.getElementById('intra-receiver-acct').value || '—';
      const amount = parseFloat(document.getElementById('intra-amount').value) || 0;
      const desc   = document.getElementById('intra-description').value || '—';
      const sym    = '<%= user.basecurrencysymbol || "$" %>';

      document.getElementById('intra-sum-name').textContent   = name;
      document.getElementById('intra-sum-acct').textContent   = acct;
      document.getElementById('intra-sum-amount').textContent = amount > 0 ? sym + amount.toLocaleString(undefined,{minimumFractionDigits:2}) : '—';
      document.getElementById('intra-sum-desc').textContent   = desc;
    }

    /* ── PIN modal ── */
    let activeFormId = null;

    function openPinModal(formId) {
      const form = document.getElementById(formId);
      if (!form.checkValidity()) { form.reportValidity(); return; }

      activeFormId = formId;
      const name   = document.getElementById('intra-receiver-name').value;
      const acct   = document.getElementById('intra-receiver-acct').value;
      const amount = parseFloat(document.getElementById('intra-amount').value) || 0;
      const sym    = '<%= user.basecurrencysymbol || "$" %>';

      document.getElementById('pin-sum-name').textContent   = name || '—';
      document.getElementById('pin-sum-acct').textContent   = acct || '—';
      document.getElementById('pin-sum-amount').textContent = sym + amount.toLocaleString(undefined,{minimumFractionDigits:2});
      document.getElementById('pin-sum-type').textContent   = 'Intra-Bank';
      document.getElementById('pinInput').value = '';
      document.getElementById('pinErrorMsg').classList.remove('visible');
      resetPinDots();
      document.getElementById('pinModal').classList.add('open');
      document.body.style.overflow = 'hidden';
      setTimeout(() => document.getElementById('pinInput').focus(), 200);
    }

    function closePinModal() {
      document.getElementById('pinModal').classList.remove('open');
      document.body.style.overflow = '';
      document.getElementById('pinInput').value = '';
      resetPinDots();
    }

    function handlePinOverlayClick(e) {
      if (e.target === e.currentTarget) closePinModal();
    }

    function onPinInput(val) {
      for (let i = 0; i < 4; i++) {
        document.getElementById('pinDot' + i).classList.toggle('filled', i < val.length);
      }
      document.getElementById('pinErrorMsg').classList.remove('visible');
    }

    function resetPinDots() {
      for (let i = 0; i < 4; i++) document.getElementById('pinDot' + i).classList.remove('filled');
    }

    function togglePinVisibility() {
      const input = document.getElementById('pinInput');
      const icon  = document.getElementById('pinEyeIcon');
      input.type  = input.type === 'password' ? 'text' : 'password';
      icon.className = input.type === 'password' ? 'fa-solid fa-eye' : 'fa-solid fa-eye-slash';
    }

    function submitWithPin() {
      const pin = document.getElementById('pinInput').value.trim();
      if (!pin) {
        document.getElementById('pinErrorMsg').textContent = 'Please enter your PIN.';
        document.getElementById('pinErrorMsg').classList.add('visible');
        document.getElementById('pinDots').classList.add('pin-shake');
        setTimeout(() => document.getElementById('pinDots').classList.remove('pin-shake'), 500);
        return;
      }
      document.getElementById('intra-pin-hidden').value = pin;
      document.getElementById('intraTransferForm').submit();
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closePinModal();
      if (e.key === 'Enter' && document.getElementById('pinModal').classList.contains('open')) submitWithPin();
    });
  </script>
</body>
</html>
