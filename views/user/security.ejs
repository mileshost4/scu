<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Security | <%= websiteName %></title>

  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/user/security.css" />
</head>
<body>

  <%
    locals.currentPath = '/user/security';
    const hasPin = user.transferCode !== undefined && user.transferCode !== null;
  %>

  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="security-page fade-in">

        <!-- ── PAGE HEADER ── -->
        <div class="page-header">
          <div class="page-header-left">
            <h1><i class="fa-solid fa-shield-halved"></i> Security</h1>
            <p>Manage your password and transaction PIN to keep your account safe.</p>
          </div>
          <a href="/user/profile" class="btn btn-ghost btn-sm">
            <i class="fa-solid fa-user"></i> My Profile
          </a>
        </div>

        <div class="security-grid">

          <!-- LEFT: Sidebar nav -->
          <div>
            <div class="sec-nav">
              <div class="sec-nav-head">Security Settings</div>
              <button class="sec-nav-item active" onclick="showSection('password')">
                <i class="fa-solid fa-key"></i>
                Change Password
                <i class="fa-solid fa-chevron-right nav-arrow"></i>
              </button>
              <button class="sec-nav-item" onclick="showSection('pin')">
                <i class="fa-solid fa-hashtag"></i>
                <%= hasPin ? 'Update Transaction PIN' : 'Set Transaction PIN' %>
                <i class="fa-solid fa-chevron-right nav-arrow"></i>
              </button>
              <button class="sec-nav-item" onclick="showSection('overview')">
                <i class="fa-solid fa-lock"></i>
                Security Overview
                <i class="fa-solid fa-chevron-right nav-arrow"></i>
              </button>
            </div>
          </div>

          <!-- RIGHT: Content panels -->
          <div style="display:flex;flex-direction:column;gap:20px">

            <!-- ═════════ CHANGE PASSWORD SECTION ═════════ -->
            <div class="section-card" id="sec-password">
              <div class="section-head">
                <div class="section-title"><i class="fa-solid fa-key"></i> Change Password</div>
                <span class="badge badge-info">Security</span>
              </div>
              <div class="section-body">
                <div class="callout callout-info">
                  <i class="fa-solid fa-circle-info"></i>
                  <p>Use a strong password with at least 8 characters, including uppercase letters, numbers, and symbols. You will remain logged in after changing your password.</p>
                </div>

                <form action="/user/changepassword?_method=PUT" method="POST" id="passwordForm">
                  <div class="form-group" style="margin-bottom:16px">
                    <label class="form-label">Current Password</label>
                    <div class="password-wrap">
                      <input type="password" class="form-control" name="currentpassword" id="currentpassword" placeholder="Enter your current password" required autocomplete="current-password" />
                      <button type="button" class="password-toggle" onclick="togglePw('currentpassword', this)">
                        <i class="fa-solid fa-eye"></i>
                      </button>
                    </div>
                  </div>

                  <div class="form-row" style="margin-bottom:16px">
                    <div class="form-group">
                      <label class="form-label">New Password</label>
                      <div class="password-wrap">
                        <input type="password" class="form-control" name="password" id="newpassword" placeholder="New password" required autocomplete="new-password" oninput="updateStrength(this.value)" />
                        <button type="button" class="password-toggle" onclick="togglePw('newpassword', this)">
                          <i class="fa-solid fa-eye"></i>
                        </button>
                      </div>
                      <div class="strength-bar-wrap" id="strengthWrap" style="display:none">
                        <div class="strength-bar-track">
                          <div class="strength-bar-fill" id="strengthBar"></div>
                        </div>
                        <span class="strength-label" id="strengthLabel"></span>
                      </div>
                    </div>
                    <div class="form-group">
                      <label class="form-label">Confirm New Password</label>
                      <div class="password-wrap">
                        <input type="password" class="form-control" name="confirmpassword" id="confirmpassword" placeholder="Repeat new password" required autocomplete="new-password" oninput="checkMatch()" />
                        <button type="button" class="password-toggle" onclick="togglePw('confirmpassword', this)">
                          <i class="fa-solid fa-eye"></i>
                        </button>
                      </div>
                      <div id="matchHint" style="font-size:0.75rem;margin-top:5px;display:none"></div>
                    </div>
                  </div>

                  <!-- Password rules checklist -->
                  <div style="background:var(--bg-input);border:1px solid var(--border);border-radius:var(--radius-md);padding:14px 16px;margin-bottom:4px">
                    <div style="font-size:0.75rem;font-weight:700;color:var(--text-muted);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:10px">Password Requirements</div>
                    <div style="display:flex;flex-direction:column;gap:7px">
                      <div class="pw-rule" id="rule-len"  style="font-size:0.8rem;color:var(--text-muted);display:flex;align-items:center;gap:8px"><i class="fa-solid fa-circle-xmark" style="font-size:0.7rem;color:var(--danger)"></i> At least 8 characters</div>
                      <div class="pw-rule" id="rule-upper" style="font-size:0.8rem;color:var(--text-muted);display:flex;align-items:center;gap:8px"><i class="fa-solid fa-circle-xmark" style="font-size:0.7rem;color:var(--danger)"></i> One uppercase letter</div>
                      <div class="pw-rule" id="rule-num"   style="font-size:0.8rem;color:var(--text-muted);display:flex;align-items:center;gap:8px"><i class="fa-solid fa-circle-xmark" style="font-size:0.7rem;color:var(--danger)"></i> One number</div>
                      <div class="pw-rule" id="rule-sym"   style="font-size:0.8rem;color:var(--text-muted);display:flex;align-items:center;gap:8px"><i class="fa-solid fa-circle-xmark" style="font-size:0.7rem;color:var(--danger)"></i> One special character</div>
                    </div>
                  </div>

                  <div class="form-actions">
                    <button type="reset" class="btn btn-ghost btn-sm">Clear</button>
                    <button type="submit" class="btn btn-primary btn-sm">
                      <i class="fa-solid fa-floppy-disk"></i> Update Password
                    </button>
                  </div>
                </form>
              </div>
            </div>

            <!-- ═════════ TRANSACTION PIN SECTION ═════════ -->
            <div class="section-card" id="sec-pin" style="display:none">
              <div class="section-head">
                <div class="section-title">
                  <i class="fa-solid fa-hashtag"></i>
                  <%= hasPin ? 'Update Transaction PIN' : 'Set Transaction PIN' %>
                </div>
                <span class="badge badge-<%= hasPin ? 'success' : 'warning' %>">
                  <%= hasPin ? 'Active' : 'Not Set' %>
                </span>
              </div>
              <div class="section-body">

                <% if (!hasPin) { %>
                  <!-- SET NEW PIN -->
                  <div class="callout callout-warning">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <p>You haven't set a transaction PIN yet. A PIN is required to authorise any transfers from your account. Choose 4 digits.</p>
                  </div>

                  <form action="/user/transfer-code?_method=PUT" method="POST">
                    <div style="text-align:center;margin-bottom:20px">
                      <div style="font-size:0.82rem;color:var(--text-secondary);margin-bottom:8px">PIN preview</div>
                      <div class="pin-preview" id="setPinDots">
                        <% for(let i=0;i<4;i++) { %>
                          <div class="pin-dot" id="setPinDot-<%= i %>"></div>
                        <% } %>
                      </div>
                    </div>

                    <div class="form-row-3" style="margin-bottom:16px">
                      <div class="form-group" style="grid-column:1/3">
                        <label class="form-label">New PIN (4 digits)</label>
                        <div class="password-wrap">
                          <input type="password" class="form-control" name="transferCode" id="setPinInput"
                            placeholder="e.g. 1234" pattern="\d{4}" maxlength="4" inputmode="numeric"
                            required oninput="updatePinDots(this.value,'setPinDot')" autocomplete="off" />
                          <button type="button" class="password-toggle" onclick="togglePw('setPinInput',this)">
                            <i class="fa-solid fa-eye"></i>
                          </button>
                        </div>
                      </div>
                    </div>

                    <div class="form-group" style="margin-bottom:4px">
                      <label class="form-label">Confirm PIN</label>
                      <div class="password-wrap">
                        <input type="password" class="form-control" name="confirmTransferCode" id="setConfirmPinInput"
                          placeholder="Repeat PIN" pattern="\d{4}" maxlength="4" inputmode="numeric"
                          required oninput="checkPinMatch('setPinInput','setConfirmPinInput','setPinMatchHint')" autocomplete="off" />
                        <button type="button" class="password-toggle" onclick="togglePw('setConfirmPinInput',this)">
                          <i class="fa-solid fa-eye"></i>
                        </button>
                      </div>
                      <div id="setPinMatchHint" style="font-size:0.75rem;margin-top:5px;display:none"></div>
                    </div>

                    <div class="form-actions">
                      <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-check-circle"></i> Set PIN
                      </button>
                    </div>
                  </form>

                <% } else { %>
                  <!-- CHANGE EXISTING PIN -->
                  <div class="callout callout-info">
                    <i class="fa-solid fa-circle-info"></i>
                    <p>Your transaction PIN is currently active. Enter your current PIN and choose a new one. PIN must be 4 digits only.</p>
                  </div>

                  <form action="/user/change-code?_method=PUT" method="POST">
                    <div style="text-align:center;margin-bottom:20px">
                      <div style="font-size:0.82rem;color:var(--text-secondary);margin-bottom:8px">New PIN preview</div>
                      <div class="pin-preview" id="changePinDots">
                        <% for(let i=0;i<4;i++) { %>
                          <div class="pin-dot" id="setPinDot-<%= i %>"></div>
                        <% } %>
                      </div>
                    </div>

                    <div class="form-group" style="margin-bottom:16px">
                      <label class="form-label">Current PIN</label>
                      <div class="password-wrap">
                        <input type="password" class="form-control" name="oldTransferCode" id="oldPinInput"
                          placeholder="Your current PIN" pattern="\d{4}" maxlength="4"
                          inputmode="numeric" required autocomplete="off" />
                        <button type="button" class="password-toggle" onclick="togglePw('oldPinInput',this)">
                          <i class="fa-solid fa-eye"></i>
                        </button>
                      </div>
                    </div>

                    <div class="form-row" style="margin-bottom:4px">
                      <div class="form-group">
                        <label class="form-label">New PIN</label>
                        <div class="password-wrap">
                          <input type="password" class="form-control" name="transferCode" id="newPinInput"
                            placeholder="New PIN" pattern="\d{4}" maxlength="4"
                            inputmode="numeric" required oninput="updatePinDots(this.value,'chPinDot')" autocomplete="off" />
                          <button type="button" class="password-toggle" onclick="togglePw('newPinInput',this)">
                            <i class="fa-solid fa-eye"></i>
                          </button>
                        </div>
                      </div>
                      <div class="form-group">
                        <label class="form-label">Confirm New PIN</label>
                        <div class="password-wrap">
                          <input type="password" class="form-control" name="confirmTransferCode" id="confirmNewPinInput"
                            placeholder="Repeat new PIN" pattern="\d{4}" maxlength="4"
                            inputmode="numeric" required oninput="checkPinMatch('newPinInput','confirmNewPinInput','chPinMatchHint')" autocomplete="off" />
                          <button type="button" class="password-toggle" onclick="togglePw('confirmNewPinInput',this)">
                            <i class="fa-solid fa-eye"></i>
                          </button>
                        </div>
                        <div id="chPinMatchHint" style="font-size:0.75rem;margin-top:5px;display:none"></div>
                      </div>
                    </div>

                    <div class="form-actions">
                      <button type="reset" class="btn btn-ghost btn-sm">Clear</button>
                      <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-floppy-disk"></i> Update PIN
                      </button>
                    </div>
                  </form>
                <% } %>

              </div>
            </div>

            <!-- ═════════ SECURITY OVERVIEW SECTION ═════════ -->
            <div class="section-card" id="sec-overview" style="display:none">
              <div class="section-head">
                <div class="section-title"><i class="fa-solid fa-lock"></i> Security Overview</div>
              </div>
              <div class="section-body">
                <div class="sec-status-list">

                  <!-- Password -->
                  <div class="sec-status-item">
                    <div class="sec-status-icon ok"><i class="fa-solid fa-key"></i></div>
                    <div class="sec-status-body">
                      <div class="sec-status-title">Password</div>
                      <div class="sec-status-desc">Your account is protected by a password. Last changed: unknown.</div>
                    </div>
                    <div class="sec-status-action">
                      <button class="btn btn-ghost btn-sm" onclick="showSection('password')">
                        Change
                      </button>
                    </div>
                  </div>

                  <!-- Transaction PIN -->
                  <div class="sec-status-item">
                    <div class="sec-status-icon <%= hasPin ? 'ok' : 'warning' %>">
                      <i class="fa-solid fa-hashtag"></i>
                    </div>
                    <div class="sec-status-body">
                      <div class="sec-status-title">Transaction PIN</div>
                      <div class="sec-status-desc">
                        <% if (hasPin) { %>PIN is set — required for all transfers.<% } else { %>No PIN set. You won't be able to initiate transfers.<% } %>
                      </div>
                    </div>
                    <div class="sec-status-action">
                      <button class="btn btn-<%= hasPin ? 'ghost' : 'primary' %> btn-sm" onclick="showSection('pin')">
                        <%= hasPin ? 'Update' : 'Set PIN' %>
                      </button>
                    </div>
                  </div>

                  <!-- KYC -->
                  <div class="sec-status-item">
                    <div class="sec-status-icon <%= user.verificationstatus === 'Verified' ? 'ok' : 'warning' %>">
                      <i class="fa-solid fa-id-card"></i>
                    </div>
                    <div class="sec-status-body">
                      <div class="sec-status-title">Identity Verification (KYC)</div>
                      <div class="sec-status-desc">
                        Status: <strong style="color:var(<%= user.verificationstatus === 'Verified' ? '--success' : '--warning' %>)"><%= user.verificationstatus %></strong>
                      </div>
                    </div>
                    <div class="sec-status-action">
                      <a href="/user/kyc" class="btn btn-ghost btn-sm">Manage</a>
                    </div>
                  </div>

                  <!-- Account Status -->
                  <div class="sec-status-item">
                    <div class="sec-status-icon <%= user.accountStatus === 'Active' ? 'ok' : 'danger' %>">
                      <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <div class="sec-status-body">
                      <div class="sec-status-title">Account Status</div>
                      <div class="sec-status-desc">
                        Your account is currently
                        <strong style="color:var(<%= user.accountStatus === 'Active' ? '--success' : '--danger' %>)"><%= user.accountStatus %></strong>.
                      </div>
                    </div>
                    <div class="sec-status-action">
                      <a href="/user/support" class="btn btn-ghost btn-sm">Support</a>
                    </div>
                  </div>

                  <!-- Transactions toggle -->
                  <div class="sec-status-item">
                    <div class="sec-status-icon <%= user.allowTransactions === 'Yes' ? 'ok' : 'danger' %>">
                      <i class="fa-solid fa-paper-plane"></i>
                    </div>
                    <div class="sec-status-body">
                      <div class="sec-status-title">Transaction Access</div>
                      <div class="sec-status-desc">
                        Transfers are
                        <strong style="color:var(<%= user.allowTransactions === 'Yes' ? '--success' : '--danger' %>)">
                          <%= user.allowTransactions === 'Yes' ? 'enabled' : 'disabled' %>
                        </strong>
                        on your account.
                      </div>
                    </div>
                    <div class="sec-status-action">
                      <a href="/user/support" class="btn btn-ghost btn-sm">Contact</a>
                    </div>
                  </div>

                </div>
              </div>
            </div>

          </div><!-- /right panels -->
        </div><!-- /.security-grid -->

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
  <script>
    /* ── Section switcher ── */
    const SECTIONS = { password: 'sec-password', pin: 'sec-pin', overview: 'sec-overview' };
    const NAV_BTNS = document.querySelectorAll('.sec-nav-item');

    function showSection(key) {
      Object.values(SECTIONS).forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.display = 'none';
      });
      const target = document.getElementById(SECTIONS[key]);
      if (target) target.style.display = 'block';

      NAV_BTNS.forEach((btn, i) => {
        const keys = ['password','pin','overview'];
        btn.classList.toggle('active', keys[i] === key);
      });
    }

    /* ── Password visibility toggle ── */
    function togglePw(id, btn) {
      const input = document.getElementById(id);
      const icon  = btn.querySelector('i');
      if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'fa-solid fa-eye-slash';
      } else {
        input.type = 'password';
        icon.className = 'fa-solid fa-eye';
      }
    }

    /* ── Password strength ── */
    function updateStrength(val) {
      const wrap  = document.getElementById('strengthWrap');
      const bar   = document.getElementById('strengthBar');
      const label = document.getElementById('strengthLabel');
      wrap.style.display = val.length ? 'block' : 'none';

      const checks = [
        val.length >= 8,
        /[A-Z]/.test(val),
        /\d/.test(val),
        /[^a-zA-Z0-9]/.test(val)
      ];
      const score = checks.filter(Boolean).length;
      const pct   = score * 25;

      const levels = [
        { label: 'Very Weak', color: '#ff4d6a' },
        { label: 'Weak',      color: '#ff8c00' },
        { label: 'Fair',      color: '#ffb020' },
        { label: 'Good',      color: '#00a882' },
        { label: 'Strong',    color: '#00d4aa' }
      ];
      const lvl = levels[score] || levels[0];
      bar.style.width     = pct + '%';
      bar.style.background = lvl.color;
      label.textContent   = lvl.label;
      label.style.color   = lvl.color;

      // Rules
      const rules = [
        { id: 'rule-len',   pass: val.length >= 8 },
        { id: 'rule-upper', pass: /[A-Z]/.test(val) },
        { id: 'rule-num',   pass: /\d/.test(val) },
        { id: 'rule-sym',   pass: /[^a-zA-Z0-9]/.test(val) }
      ];
      rules.forEach(r => {
        const el   = document.getElementById(r.id);
        const icon = el.querySelector('i');
        if (r.pass) {
          el.style.color   = 'var(--success)';
          icon.className   = 'fa-solid fa-circle-check';
          icon.style.color = 'var(--success)';
        } else {
          el.style.color   = 'var(--text-muted)';
          icon.className   = 'fa-solid fa-circle-xmark';
          icon.style.color = 'var(--danger)';
        }
      });
    }

    /* ── Password match check ── */
    function checkMatch() {
      const hint = document.getElementById('matchHint');
      const pw1  = document.getElementById('newpassword').value;
      const pw2  = document.getElementById('confirmpassword').value;
      if (!pw2) { hint.style.display = 'none'; return; }
      hint.style.display = 'block';
      if (pw1 === pw2) {
        hint.textContent  = '✓ Passwords match';
        hint.style.color  = 'var(--success)';
      } else {
        hint.textContent  = '✗ Passwords do not match';
        hint.style.color  = 'var(--danger)';
      }
    }

    /* ── PIN dot visualiser ── */
    function updatePinDots(val, prefix) {
      for (let i = 0; i < 6; i++) {
        const dot = document.getElementById(prefix + '-' + i);
        if (dot) dot.classList.toggle('filled', i < val.length);
      }
    }

    /* ── PIN match check ── */
    function checkPinMatch(inputId1, inputId2, hintId) {
      const hint = document.getElementById(hintId);
      const v1   = document.getElementById(inputId1).value;
      const v2   = document.getElementById(inputId2).value;
      if (!v2) { hint.style.display = 'none'; return; }
      hint.style.display = 'block';
      if (v1 === v2) {
        hint.textContent = '✓ PINs match';
        hint.style.color = 'var(--success)';
      } else {
        hint.textContent = '✗ PINs do not match';
        hint.style.color = 'var(--danger)';
      }
    }
  </script>
</body>
</html>
