<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Investment Details | <%= websiteName %></title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/user/viewinvestment.css" />
</head>
<body>
  <% locals.currentPath = '/user/investments'; %>
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="vinv-page fade-in">

        <a href="/user/investments" class="vinv-back">
          <i class="fa-solid fa-arrow-left"></i> Back to Investments
        </a>

        <div class="vinv-layout">

          <!-- Main Card -->
          <div class="vinv-main">

            <!-- Hero -->
            <div class="vinv-hero">
              <div class="vinv-hero-icon">
                <i class="fa-solid fa-seedling"></i>
              </div>
              <div class="vinv-hero-info">
                <h1 class="vinv-plan-name"><%= investment.packagetype %></h1>
                <div class="vinv-status-row">
                  <span class="badge badge-<%= investment.status === 'Active' ? 'success' : investment.status === 'Completed' ? 'accent' : 'warning' %>">
                    <% if (investment.status === 'Active') { %><span class="vinv-pulse-dot"></span><% } %>
                    <%= investment.status %>
                  </span>
                  <span class="vinv-started">Started <%= new Date(investment.startDate).toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'}) %></span>
                </div>
              </div>
            </div>

            <!-- Profit Banner (for Active) -->
            <% if (investment.status === 'Active') { %>
            <div class="vinv-profit-banner">
              <div class="vinv-profit-section">
                <span class="vinv-profit-label">Current Profit</span>
                <span class="vinv-profit-value">+<%= user.basecurrencysymbol || '$' %><%= parseFloat(investment.investmentprofit || 0).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}) %></span>
              </div>
              <div class="vinv-profit-divider"></div>
              <div class="vinv-profit-section">
                <span class="vinv-profit-label">Expected Return</span>
                <span class="vinv-profit-value text-accent"><%= investment.roi %></span>
              </div>
            </div>
            <% } %>

            <!-- Stats Grid -->
            <div class="vinv-stats">
              <div class="vinv-stat-card">
                <div class="vinv-stat-icon gold">
                  <i class="fa-solid fa-coins"></i>
                </div>
                <span class="vinv-stat-label">Invested Amount</span>
                <span class="vinv-stat-val font-mono"><%= user.basecurrencysymbol || '$' %><%= parseFloat(investment.investedamount).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}) %></span>
              </div>
              <div class="vinv-stat-card">
                <div class="vinv-stat-icon accent">
                  <i class="fa-solid fa-percent"></i>
                </div>
                <span class="vinv-stat-label">ROI</span>
                <span class="vinv-stat-val text-accent"><%= investment.roi %></span>
              </div>
              <div class="vinv-stat-card">
                <div class="vinv-stat-icon info">
                  <i class="fa-regular fa-clock"></i>
                </div>
                <span class="vinv-stat-label">Duration</span>
                <span class="vinv-stat-val"><%= investment.duration %></span>
              </div>
              <div class="vinv-stat-card">
                <div class="vinv-stat-icon success">
                  <i class="fa-solid fa-arrow-trend-up"></i>
                </div>
                <span class="vinv-stat-label">Total Profit</span>
                <span class="vinv-stat-val text-accent font-mono">+<%= user.basecurrencysymbol || '$' %><%= parseFloat(investment.investmentprofit || 0).toLocaleString('en-US', {minimumFractionDigits:2}) %></span>
              </div>
            </div>

            <!-- Progress -->
            <% if (investment.status === 'Active') { %>
            <%
              const daysElapsed = Math.round((new Date() - new Date(investment.startDate)) / (1000*60*60*24));
              const totalDays = parseInt(investment.duration) || 30;
              const progressPct = Math.min(100, Math.round(daysElapsed / totalDays * 100));
            %>
            <div class="vinv-progress-section">
              <div class="vinv-progress-header">
                <span class="vinv-progress-title">Investment Progress</span>
                <span class="vinv-progress-pct"><%= progressPct %>%</span>
              </div>
              <div class="vinv-progress-track">
                <div class="vinv-progress-fill" style="width: <%= progressPct %>%"></div>
              </div>
              <div class="vinv-progress-meta">
                <span><%= daysElapsed %> day<%= daysElapsed !== 1 ? 's' : '' %> elapsed</span>
                <span><%= Math.max(0, totalDays - daysElapsed) %> day<%= (Math.max(0, totalDays - daysElapsed)) !== 1 ? 's' : '' %> remaining</span>
              </div>
            </div>
            <% } %>

          </div><!-- /.vinv-main -->

          <!-- Sidebar -->
          <div class="vinv-sidebar">

            <!-- Timeline -->
            <div class="vinv-info-card">
              <h3 class="vinv-card-title">Timeline</h3>
              <div class="vinv-timeline">
                <div class="vinv-tl-item">
                  <div class="vinv-tl-dot active"></div>
                  <div class="vinv-tl-content">
                    <span class="vinv-tl-label">Start Date</span>
                    <span class="vinv-tl-val"><%= new Date(investment.startDate).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %></span>
                  </div>
                </div>
                <div class="vinv-tl-line"></div>
                <% if (investment.endDate) { %>
                <div class="vinv-tl-item">
                  <div class="vinv-tl-dot <%= investment.status === 'Completed' ? 'active' : '' %>"></div>
                  <div class="vinv-tl-content">
                    <span class="vinv-tl-label">End Date</span>
                    <span class="vinv-tl-val"><%= new Date(investment.endDate).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %></span>
                  </div>
                </div>
                <% } else { %>
                <div class="vinv-tl-item">
                  <div class="vinv-tl-dot"></div>
                  <div class="vinv-tl-content">
                    <span class="vinv-tl-label">Expected End</span>
                    <span class="vinv-tl-val text-muted">—</span>
                  </div>
                </div>
                <% } %>
              </div>
            </div>

            <!-- Summary Card -->
            <div class="vinv-info-card">
              <h3 class="vinv-card-title">Summary</h3>
              <div class="vinv-summary-rows">
                <div class="vinv-sum-row">
                  <span class="vinv-sum-label">Package</span>
                  <span class="vinv-sum-val"><%= investment.packagetype %></span>
                </div>
                <div class="vinv-sum-row">
                  <span class="vinv-sum-label">Status</span>
                  <span class="vinv-sum-val">
                    <span class="badge badge-<%= investment.status === 'Active' ? 'success' : investment.status === 'Completed' ? 'accent' : 'warning' %>" style="font-size:0.7rem;"><%= investment.status %></span>
                  </span>
                </div>
                <div class="vinv-sum-row">
                  <span class="vinv-sum-label">ROI</span>
                  <span class="vinv-sum-val text-accent font-weight-bold"><%= investment.roi %></span>
                </div>
                <div class="vinv-sum-row">
                  <span class="vinv-sum-label">Duration</span>
                  <span class="vinv-sum-val"><%= investment.duration %></span>
                </div>
                <div class="vinv-sum-row">
                  <span class="vinv-sum-label">Invested</span>
                  <span class="vinv-sum-val font-mono"><%= user.basecurrencysymbol || '$' %><%= parseFloat(investment.investedamount).toLocaleString('en-US', {minimumFractionDigits:2}) %></span>
                </div>
                <div class="vinv-sum-row">
                  <span class="vinv-sum-label">Profit</span>
                  <span class="vinv-sum-val text-accent font-mono">+<%= user.basecurrencysymbol || '$' %><%= parseFloat(investment.investmentprofit || 0).toLocaleString('en-US', {minimumFractionDigits:2}) %></span>
                </div>
              </div>
            </div>

            <a href="/user/investments" class="btn btn-ghost w-full" style="justify-content:center;">
              <i class="fa-solid fa-grid-2"></i> All Investments
            </a>

          </div><!-- /.vinv-sidebar -->
        </div><!-- /.vinv-layout -->

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
</body>
</html>
