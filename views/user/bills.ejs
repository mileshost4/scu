<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pay Bills | <%= websiteName %></title>

  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/user/bills.css" />
</head>
<body>

  <%
    locals.currentPath = '/user/pay-bills';
  %>

  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="bills-page fade-in">

        <!-- Page Header -->
        <div class="page-header">
          <div class="page-header-left">
            <div class="page-icon">
              <i class="fa-solid fa-file-invoice-dollar"></i>
            </div>
            <div>
              <h1 class="page-title">Pay Bills</h1>
              <p class="page-subtitle">Manage and pay your utility bills securely</p>
            </div>
          </div>
          <div class="header-balance">
            <span class="balance-label">Available Balance</span>
            <span class="balance-amount amount"><%= user.basecurrencysymbol %><%= totalBalance %></span>
          </div>
        </div>

        <!-- Bill Categories Quick Select -->
        <div class="category-strip">
          <button class="category-btn active" data-category="electricity">
            <i class="fa-solid fa-bolt"></i>
            <span>Electricity</span>
          </button>
          <button class="category-btn" data-category="water">
            <i class="fa-solid fa-droplet"></i>
            <span>Water</span>
          </button>
          <button class="category-btn" data-category="internet">
            <i class="fa-solid fa-wifi"></i>
            <span>Internet</span>
          </button>
          <button class="category-btn" data-category="cable">
            <i class="fa-solid fa-tv"></i>
            <span>Cable TV</span>
          </button>
          <button class="category-btn" data-category="phone">
            <i class="fa-solid fa-mobile-screen"></i>
            <span>Phone</span>
          </button>
          <button class="category-btn" data-category="insurance">
            <i class="fa-solid fa-shield-halved"></i>
            <span>Insurance</span>
          </button>
          <button class="category-btn" data-category="gas">
            <i class="fa-solid fa-fire-flame-simple"></i>
            <span>Gas</span>
          </button>
          <button class="category-btn" data-category="rent">
            <i class="fa-solid fa-house"></i>
            <span>Rent</span>
          </button>
        </div>

        <!-- Main Layout -->
        <div class="bills-layout">

          <!-- Left: Bill Form -->
          <div class="bills-form-card card">
            <div class="card-inner">
              <h2 class="section-title">
                <i class="fa-regular fa-credit-card"></i>
                Bill Payment Details
              </h2>

              <form action="/user/pay-bills" method="POST" id="billsForm">

                <!-- Pay From Account -->
                <div class="form-group">
                  <label class="form-label" for="account">Pay From Account</label>
                  <div class="select-wrapper">
                    <select class="form-control" name="account" id="account" required>
                      <option value="" disabled selected>Select account</option>
                      <% allaccounts.forEach(function(acc) { %>
                        <option value="<%= acc._id %>">
                          <%= acc.displayName %> — <%= acc.accountType %> •••• <%= String(acc.accountNumber).slice(-4) %>
                          (<%= user.basecurrencysymbol %><%= acc.accountWallet.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>)
                        </option>
                      <% }) %>
                    </select>
                    <i class="fa-solid fa-chevron-down select-arrow"></i>
                  </div>
                </div>

                <!-- Bill Category -->
                <div class="form-group">
                  <label class="form-label" for="billCategory">Bill Category</label>
                  <div class="select-wrapper">
                    <select class="form-control" name="billCategory" id="billCategory" required>
                      <option value="" disabled selected>Select category</option>
                      <option value="electricity">Electricity</option>
                      <option value="water">Water &amp; Sewage</option>
                      <option value="internet">Internet / Broadband</option>
                      <option value="cable">Cable / Satellite TV</option>
                      <option value="phone">Mobile Phone</option>
                      <option value="insurance">Insurance</option>
                      <option value="gas">Gas / Heating</option>
                      <option value="rent">Rent / Mortgage</option>
                      <option value="streaming">Streaming Services</option>
                      <option value="gym">Gym / Fitness</option>
                      <option value="other">Other</option>
                    </select>
                    <i class="fa-solid fa-chevron-down select-arrow"></i>
                  </div>
                </div>

                <!-- Service Provider -->
                <div class="form-group">
                  <label class="form-label" for="provider">Service Provider</label>
                  <div class="select-wrapper">
                    <select class="form-control" name="provider" id="provider" required>
                      <option value="" disabled selected>Select provider</option>
                      <optgroup label="Electricity">
                        <option value="duke-energy">Duke Energy</option>
                        <option value="pg-e">Pacific Gas &amp; Electric (PG&amp;E)</option>
                        <option value="con-ed">Con Edison</option>
                        <option value="aps">Arizona Public Service (APS)</option>
                        <option value="xcel-energy">Xcel Energy</option>
                        <option value="dominion-energy">Dominion Energy</option>
                        <option value="southern-company">Southern Company</option>
                        <option value="eversource">Eversource Energy</option>
                      </optgroup>
                      <optgroup label="Water">
                        <option value="american-water">American Water Works</option>
                        <option value="california-water">California Water Service</option>
                        <option value="essential-utilities">Essential Utilities</option>
                        <option value="york-water">York Water</option>
                        <option value="middlesex-water">Middlesex Water</option>
                      </optgroup>
                      <optgroup label="Internet / Broadband">
                        <option value="xfinity">Xfinity (Comcast)</option>
                        <option value="spectrum">Spectrum (Charter)</option>
                        <option value="att-internet">AT&amp;T Internet</option>
                        <option value="verizon-fios">Verizon Fios</option>
                        <option value="cox">Cox Communications</option>
                        <option value="centurylink">CenturyLink / Quantum Fiber</option>
                        <option value="t-mobile-home">T-Mobile Home Internet</option>
                        <option value="optimum">Optimum</option>
                      </optgroup>
                      <optgroup label="Cable / TV">
                        <option value="directv">DirecTV</option>
                        <option value="dish">DISH Network</option>
                        <option value="xfinity-tv">Xfinity TV</option>
                        <option value="spectrum-tv">Spectrum TV</option>
                        <option value="youtube-tv">YouTube TV</option>
                        <option value="hulu-live">Hulu Live TV</option>
                        <option value="fubo">FuboTV</option>
                      </optgroup>
                      <optgroup label="Mobile Phone">
                        <option value="att">AT&amp;T</option>
                        <option value="verizon">Verizon Wireless</option>
                        <option value="t-mobile">T-Mobile</option>
                        <option value="sprint">Sprint</option>
                        <option value="cricket">Cricket Wireless</option>
                        <option value="metro">Metro by T-Mobile</option>
                        <option value="boost">Boost Mobile</option>
                        <option value="mint">Mint Mobile</option>
                        <option value="visible">Visible</option>
                        <option value="consumer-cellular">Consumer Cellular</option>
                      </optgroup>
                      <optgroup label="Gas / Heating">
                        <option value="atmos-energy">Atmos Energy</option>
                        <option value="nicor-gas">Nicor Gas</option>
                        <option value="peoples-gas">Peoples Gas</option>
                        <option value="spire">Spire Energy</option>
                        <option value="columbia-gas">Columbia Gas</option>
                        <option value="national-grid">National Grid</option>
                        <option value="laclede-gas">Laclede Gas</option>
                      </optgroup>
                      <optgroup label="Insurance">
                        <option value="state-farm">State Farm</option>
                        <option value="geico">GEICO</option>
                        <option value="progressive">Progressive</option>
                        <option value="allstate">Allstate</option>
                        <option value="liberty-mutual">Liberty Mutual</option>
                        <option value="usaa">USAA</option>
                        <option value="farmers">Farmers Insurance</option>
                        <option value="travelers">Travelers</option>
                        <option value="nationwide">Nationwide</option>
                        <option value="aig">AIG</option>
                      </optgroup>
                      <optgroup label="Streaming">
                        <option value="netflix">Netflix</option>
                        <option value="disney-plus">Disney+</option>
                        <option value="hbo-max">Max (HBO)</option>
                        <option value="amazon-prime">Amazon Prime Video</option>
                        <option value="apple-tv">Apple TV+</option>
                        <option value="peacock">Peacock</option>
                        <option value="paramount">Paramount+</option>
                        <option value="spotify">Spotify</option>
                        <option value="apple-music">Apple Music</option>
                      </optgroup>
                    </select>
                    <i class="fa-solid fa-chevron-down select-arrow"></i>
                  </div>
                </div>

                <!-- Account / Customer Number -->
                <div class="form-group">
                  <label class="form-label" for="billerAccount">Account / Customer Number</label>
                  <input
                    type="text"
                    class="form-control"
                    name="billerAccount"
                    id="billerAccount"
                    placeholder="Enter your account number with the provider"
                    required
                  />
                </div>

                <!-- Amount -->
                <div class="form-group">
                  <label class="form-label" for="amount">Amount</label>
                  <div class="amount-input-wrapper">
                    <span class="currency-prefix"><%= user.basecurrencysymbol %></span>
                    <input
                      type="number"
                      class="form-control amount-input"
                      name="amount"
                      id="amount"
                      placeholder="0.00"
                      step="0.01"
                      min="1"
                      required
                    />
                  </div>
                </div>

                <!-- Reference / Narration -->
                <div class="form-group">
                  <label class="form-label" for="reference">Reference / Narration <span class="optional-tag">Optional</span></label>
                  <input
                    type="text"
                    class="form-control"
                    name="reference"
                    id="reference"
                    placeholder="e.g. October electricity bill"
                    maxlength="100"
                  />
                </div>

                <!-- Schedule -->
                <div class="form-group">
                  <label class="form-label" for="scheduleDate">Schedule Date <span class="optional-tag">Optional</span></label>
                  <input
                    type="date"
                    class="form-control"
                    name="scheduleDate"
                    id="scheduleDate"
                  />
                  <p class="form-hint">Leave blank to pay immediately.</p>
                </div>

                <!-- Summary strip -->
                <div class="pay-summary" id="paySummary" style="display:none;">
                  <div class="summary-row">
                    <span>Provider</span>
                    <span id="summaryProvider">—</span>
                  </div>
                  <div class="summary-row">
                    <span>Amount</span>
                    <span id="summaryAmount">—</span>
                  </div>
                  <div class="summary-row">
                    <span>Fee</span>
                    <span class="text-accent">Free</span>
                  </div>
                  <div class="summary-row summary-total">
                    <span>Total Debit</span>
                    <span id="summaryTotal">—</span>
                  </div>
                </div>

                <button type="submit" class="btn btn-primary w-full pay-btn">
                  <i class="fa-solid fa-lock"></i>
                  Pay Bill Securely
                </button>
              </form>
            </div>
          </div>

          <!-- Right: Recent / Info panel -->
          <div class="bills-side">

            <!-- Tip card -->
            <div class="info-card card">
              <div class="info-card-icon">
                <i class="fa-solid fa-circle-info"></i>
              </div>
              <div>
                <p class="info-card-title">Secure Payments</p>
                <p class="info-card-text">All bill payments are encrypted and processed through our secure payment gateway. Allow up to 24 hours for confirmation.</p>
              </div>
            </div>

            <!-- Saved billers -->
            <div class="saved-billers card">
              <div class="saved-billers-header">
                <span class="section-title-sm">Saved Billers</span>
                <button class="btn btn-sm btn-ghost">
                  <i class="fa-solid fa-plus"></i> Add
                </button>
              </div>
              <!-- <div class="biller-list">
                <div class="biller-item" data-provider="xfinity" data-account="12384729">
                  <div class="biller-icon internet">
                    <i class="fa-solid fa-wifi"></i>
                  </div>
                  <div class="biller-info">
                    <span class="biller-name">Xfinity Internet</span>
                    <span class="biller-acct">Acct: •••• 4729</span>
                  </div>
