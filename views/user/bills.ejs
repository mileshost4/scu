                  </div>
                  <button class="biller-pay-btn">Pay</button>
                </div>
              </div> -->
            </div>

            <!-- Recent payments -->
            <div class="recent-bills card">
              <p class="section-title-sm">Recent Bill Payments</p>
              <!-- <div class="recent-list">
                <div class="recent-item">
                  <div class="recent-icon electricity">
                    <i class="fa-solid fa-bolt"></i>
                  </div>
                  <div class="recent-info">
                    <span class="recent-name">Duke Energy</span>
                    <span class="recent-date">Oct 1, 2025</span>
                  </div>
                  <div class="recent-right">
                    <span class="recent-amount"><%= user.basecurrencysymbol %>124.50</span>
