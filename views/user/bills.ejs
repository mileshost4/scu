            </div>
          </div>
        </div>

      </div><!-- /.bills-page -->
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
  <script>
    // Category strip sync with the select
    const categoryBtns = document.querySelectorAll('.category-btn');
    const categorySelect = document.getElementById('billCategory');

    categoryBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        categoryBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const val = btn.dataset.category;
        if (categorySelect.querySelector(`option[value="${val}"]`)) {
          categorySelect.value = val;
        }
      });
    });

    // Live summary
    const providerSelect = document.getElementById('provider');
    const amountInput = document.getElementById('amount');
    const paySummary = document.getElementById('paySummary');
    const summaryProvider = document.getElementById('summaryProvider');
    const summaryAmount = document.getElementById('summaryAmount');
    const summaryTotal = document.getElementById('summaryTotal');
    const currencySymbol = '<%= user.basecurrencysymbol %>';

    function updateSummary() {
      const provider = providerSelect.options[providerSelect.selectedIndex]?.text;
      const amount = parseFloat(amountInput.value);
      if (provider && amount > 0) {
        paySummary.style.display = 'block';
        summaryProvider.textContent = provider;
        summaryAmount.textContent = currencySymbol + amount.toLocaleString(undefined, {minimumFractionDigits: 2});
        summaryTotal.textContent = currencySymbol + amount.toLocaleString(undefined, {minimumFractionDigits: 2});
      } else {
        paySummary.style.display = 'none';
      }
    }

    providerSelect.addEventListener('change', updateSummary);
    amountInput.addEventListener('input', updateSummary);

    // Saved biller quick-fill
    document.querySelectorAll('.biller-pay-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.biller-item');
        const provider = item.dataset.provider;
        const account = item.dataset.account;
        if (providerSelect.querySelector(`option[value="${provider}"]`)) {
          providerSelect.value = provider;
        }
        document.getElementById('billerAccount').value = account;
        updateSummary();
        document.getElementById('billsForm').scrollIntoView({ behavior: 'smooth' });
      });
    });
  </script>
</body>
</html>
