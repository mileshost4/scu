<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Transaction History | <%= websiteName %></title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/user/transactionhistory.css" />
</head>
<body>
  <% locals.currentPath = '/user/transaction-history'; %>
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="txh-page fade-in">

        <!-- Page Header -->
        <div class="txh-header">
          <div class="txh-header-left">
            <h1 class="txh-title">Transaction History</h1>
            <p class="txh-subtitle">All activity across your accounts</p>
          </div>
          <div class="txh-header-right">
            <button class="btn btn-ghost btn-sm" id="statementToggle">
              <i class="fa-solid fa-file-arrow-down"></i> Statement
            </button>
          </div>
        </div>

        <!-- Statement Download Panel -->
        <div class="statement-panel" id="statementPanel">
          <form action="/user/statement/download" method="GET" class="statement-form">
            <div class="statement-row">
              <div class="form-group">
                <label class="form-label">From</label>
                <input type="date" name="from" class="form-control" />
              </div>
              <div class="form-group">
                <label class="form-label">To</label>
                <input type="date" name="to" class="form-control" />
              </div>
              <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-download"></i> Download PDF
              </button>
            </div>
          </form>
        </div>

        <!-- Filters Bar -->
        <div class="txh-filters">
          <div class="filter-search">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="txSearch" placeholder="Search by description, ref, name…" class="filter-input" />
          </div>
          <div class="filter-group">
            <select id="filterType" class="filter-select">
              <option value="">All Types</option>
              <option value="Credit">Credit</option>
              <option value="Debit">Debit</option>
              <option value="Transfer">Transfer</option>
              <option value="Deposit">Deposit</option>
            </select>
            <select id="filterStatus" class="filter-select">
              <option value="">All Status</option>
              <option value="Successful">Successful</option>
              <option value="Pending">Pending</option>
              <option value="Unsuccessful">Unsuccessful</option>
              <option value="Unconfirmed">Unconfirmed</option>
            </select>
            <select id="sortOrder" class="filter-select">
              <option value="desc">Newest First</option>
              <option value="asc">Oldest First</option>
            </select>
          </div>
        </div>

        <!-- Stats Row -->
        <div class="txh-stats">
          <div class="stat-pill">
            <span class="stat-label">Total</span>
            <span class="stat-val" id="statTotal"><%= transactions.length %></span>
          </div>
          <div class="stat-pill success">
            <span class="stat-dot"></span>
            <span class="stat-label">Successful</span>
            <span class="stat-val" id="statSuccess">0</span>
          </div>
          <div class="stat-pill warning">
            <span class="stat-dot"></span>
            <span class="stat-label">Pending</span>
            <span class="stat-val" id="statPending">0</span>
          </div>
          <div class="stat-pill danger">
            <span class="stat-dot"></span>
            <span class="stat-label">Failed</span>
            <span class="stat-val" id="statFailed">0</span>
          </div>
        </div>

        <!-- Transaction Table -->
        <div class="txh-table-wrap">
          <table class="txh-table" id="txTable">
            <thead>
              <tr>
                <th>Date</th>
                <th>Description</th>
                <th>Type</th>
                <th>Reference</th>
                <th class="text-right">Amount</th>
                <th>Status</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="txTableBody">
              <% if (transactions && transactions.length > 0) { %>
                <% transactions.forEach(function(tx) { %>
                  <tr class="tx-row"
                      data-type="<%= tx.transactionType %>"
                      data-status="<%= tx.status %>"
                      data-date="<%= new Date(tx.date).getTime() %>"
                      data-search="<%= ((tx.description || '') + ' ' + (tx.receiverAccountName || '') + ' ' + (tx.refCode || '') + ' ' + (tx.senderAccountName || '')).toLowerCase() %>">
                    <td class="tx-date">
                      <span class="tx-date-main"><%= new Date(tx.date).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %></span>
                      <span class="tx-date-time"><%= new Date(tx.date).toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'}) %></span>
                    </td>
                    <td class="tx-desc">
                      <span class="tx-desc-main"><%= tx.description || tx.receiverAccountName || tx.senderAccountName || '—' %></span>
                      <% if (tx.transferType) { %>
                        <span class="tx-sub"><%= tx.transferType %></span>
                      <% } %>
                    </td>
                    <td>
                      <span class="tx-type-badge tx-type-<%= tx.transactionType.toLowerCase() %>">
                        <% if (tx.transactionType === 'Credit') { %><i class="fa-solid fa-arrow-down-left"></i>
                        <% } else if (tx.transactionType === 'Debit') { %><i class="fa-solid fa-arrow-up-right"></i>
                        <% } else if (tx.transactionType === 'Transfer') { %><i class="fa-solid fa-arrow-right-arrow-left"></i>
                        <% } else { %><i class="fa-solid fa-circle-arrow-down"></i><% } %>
                        <%= tx.transactionType %>
                      </span>
                    </td>
                    <td class="tx-ref font-mono"><%= tx.refCode || '—' %></td>
                    <td class="text-right">
                      <span class="tx-amount <%= ['Credit','Deposit'].includes(tx.transactionType) ? 'tx-credit' : 'tx-debit' %>">
                        <%= ['Credit','Deposit'].includes(tx.transactionType) ? '+' : '-' %><%= user.basecurrencysymbol || '$' %><%= parseFloat(tx.amount).toLocaleString('en-US', {minimumFractionDigits:2}) %>
                      </span>
                    </td>
                    <td>
                      <span class="badge badge-<%= tx.status === 'Successful' ? 'success' : tx.status === 'Pending' ? 'warning' : 'danger' %>">
                        <%= tx.status %>
                      </span>
                    </td>
                    <td>
                      <a href="/user/transaction/<%= tx._id %>/receipt" class="btn-icon btn-sm" title="View Receipt">
                        <i class="fa-solid fa-receipt"></i>
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="tx-empty">
                    <div class="empty-state">
                      <i class="fa-regular fa-folder-open"></i>
                      <p>No transactions yet</p>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <div class="txh-pagination">
          <% if (currentPage > 1) { %>
            <a href="?page=<%= currentPage - 1 %>" class="page-btn"><i class="fa-solid fa-chevron-left"></i></a>
          <% } %>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="?page=<%= i %>" class="page-btn <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
          <% } %>
          <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %>" class="page-btn"><i class="fa-solid fa-chevron-right"></i></a>
          <% } %>
        </div>
        <% } %>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
  <script>
    // Statement panel toggle
    const statementToggle = document.getElementById('statementToggle');
    const statementPanel  = document.getElementById('statementPanel');
    statementToggle.addEventListener('click', () => statementPanel.classList.toggle('open'));

    // Live filter + sort
    const rows       = Array.from(document.querySelectorAll('.tx-row'));
    const searchInput  = document.getElementById('txSearch');
    const typeFilter   = document.getElementById('filterType');
    const statusFilter = document.getElementById('filterStatus');
    const sortOrder    = document.getElementById('sortOrder');
    const tbody        = document.getElementById('txTableBody');

    function filterAndSort() {
      const search = searchInput.value.toLowerCase();
      const type   = typeFilter.value;
      const status = statusFilter.value;
      const order  = sortOrder.value;

      let visible = rows.filter(r => {
        const matchSearch = !search || r.dataset.search.includes(search);
        const matchType   = !type   || r.dataset.type   === type;
        const matchStatus = !status || r.dataset.status === status;
        return matchSearch && matchType && matchStatus;
      });

      visible.sort((a, b) => order === 'asc'
        ? a.dataset.date - b.dataset.date
        : b.dataset.date - a.dataset.date);

      // Hide all, re-append visible in order
      rows.forEach(r => r.style.display = 'none');
      visible.forEach(r => { r.style.display = ''; tbody.appendChild(r); });

      updateStats(visible);
    }

    function updateStats(visible) {
      document.getElementById('statTotal').textContent   = visible.length;
      document.getElementById('statSuccess').textContent = visible.filter(r => r.dataset.status === 'Successful').length;
      document.getElementById('statPending').textContent = visible.filter(r => r.dataset.status === 'Pending').length;
      document.getElementById('statFailed').textContent  = visible.filter(r => ['Unsuccessful','Unconfirmed'].includes(r.dataset.status)).length;
    }

    [searchInput, typeFilter, statusFilter, sortOrder].forEach(el =>
      el.addEventListener('input', filterAndSort));

    // Initial stats
    updateStats(rows);
  </script>
</body>
</html>
