<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Receipt | <%= websiteName %></title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/user/receipt.css" />
</head>
<body>
  <% locals.currentPath = '/user/transaction-history'; %>
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="receipt-page fade-in">

        <!-- Back link -->
        <a href="/user/transaction-history" class="receipt-back">
          <i class="fa-solid fa-arrow-left"></i> Back to History
        </a>

        <!-- Receipt Card -->
        <div class="receipt-wrap" id="receiptCard">

          <!-- Receipt Header -->
          <div class="receipt-header">
            <div class="receipt-logo">
              <img src="/images/logo.png" alt="Logo" />
            </div>
            <div class="receipt-header-meta">
              <span class="receipt-label">Transaction Receipt</span>
              <span class="receipt-date">
                <%= new Date(transaction.date).toLocaleString('en-US', {month:'long', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit'}) %>
              </span>
            </div>
            <span class="receipt-status-badge badge badge-<%= transaction.status === 'Successful' ? 'success' : transaction.status === 'Pending' ? 'warning' : 'danger' %>">
              <i class="fa-solid <%= transaction.status === 'Successful' ? 'fa-circle-check' : transaction.status === 'Pending' ? 'fa-clock' : 'fa-circle-xmark' %>"></i>
              <%= transaction.status %>
            </span>
          </div>

          <!-- Amount Hero -->
          <div class="receipt-amount-hero">
            <span class="receipt-amount-label">
              <%= ['Credit','Deposit'].includes(transaction.transactionType) ? 'Amount Received' : 'Amount Sent' %>
            </span>
            <div class="receipt-amount-value <%= ['Credit','Deposit'].includes(transaction.transactionType) ? 'credit' : 'debit' %>">
              <%= ['Credit','Deposit'].includes(transaction.transactionType) ? '+' : '-' %><%= user.basecurrencysymbol || '$' %><%= parseFloat(transaction.amount).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2}) %>
            </div>
            <% if (transaction.newBalance !== undefined && transaction.newBalance !== null) { %>
            <span class="receipt-balance-note">New balance: <%= user.basecurrencysymbol || '$' %><%= parseFloat(transaction.newBalance).toLocaleString('en-US', {minimumFractionDigits:2}) %></span>
            <% } %>
          </div>

          <!-- Divider -->
          <div class="receipt-dashed-divider">
            <span class="dashed-circle left"></span>
            <div class="dashed-line"></div>
            <span class="dashed-circle right"></span>
          </div>

          <!-- Details Grid -->
          <div class="receipt-details">
            <div class="receipt-row">
              <span class="rd-label">Transaction Type</span>
              <span class="rd-value">
                <span class="tx-type-badge tx-type-<%= transaction.transactionType.toLowerCase() %>">
                  <%= transaction.transactionType %><% if (transaction.transferType) { %> / <%= transaction.transferType %><% } %>
                </span>
              </span>
            </div>
            <% if (transaction.refCode) { %>
            <div class="receipt-row">
              <span class="rd-label">Reference Code</span>
              <span class="rd-value font-mono"><%= transaction.refCode %></span>
            </div>
            <% } %>
            <% if (transaction.receiverAccountName) { %>
            <div class="receipt-row">
              <span class="rd-label">Recipient Name</span>
              <span class="rd-value"><%= transaction.receiverAccountName %></span>
            </div>
            <% } %>
            <% if (transaction.receiverAccountNumber) { %>
            <div class="receipt-row">
              <span class="rd-label">Recipient Account</span>
              <span class="rd-value font-mono"><%= transaction.receiverAccountNumber %></span>
            </div>
            <% } %>
            <% if (transaction.senderAccountName) { %>
            <div class="receipt-row">
              <span class="rd-label">Sender Name</span>
              <span class="rd-value"><%= transaction.senderAccountName %></span>
            </div>
            <% } %>
            <% if (transaction.senderAccountNumber) { %>
            <div class="receipt-row">
              <span class="rd-label">Sender Account</span>
              <span class="rd-value font-mono"><%= transaction.senderAccountNumber %></span>
            </div>
            <% } %>
            <% if (transaction.bankTo) { %>
            <div class="receipt-row">
              <span class="rd-label">Bank (To)</span>
              <span class="rd-value"><%= transaction.bankTo %></span>
            </div>
            <% } %>
            <% if (transaction.bankFrom) { %>
            <div class="receipt-row">
              <span class="rd-label">Bank (From)</span>
              <span class="rd-value"><%= transaction.bankFrom %></span>
            </div>
            <% } %>
            <% if (transaction.swiftcode) { %>
            <div class="receipt-row">
              <span class="rd-label">SWIFT / BIC</span>
              <span class="rd-value font-mono"><%= transaction.swiftcode %></span>
            </div>
            <% } %>
            <% if (transaction.receiverCountry) { %>
            <div class="receipt-row">
              <span class="rd-label">Recipient Country</span>
              <span class="rd-value"><%= transaction.receiverCountry %></span>
            </div>
            <% } %>
            <% if (transaction.description) { %>
            <div class="receipt-row">
              <span class="rd-label">Description</span>
              <span class="rd-value"><%= transaction.description %></span>
            </div>
            <% } %>
            <div class="receipt-row">
              <span class="rd-label">Date & Time</span>
              <span class="rd-value"><%= new Date(transaction.date).toLocaleString('en-US', {dateStyle:'long', timeStyle:'short'}) %></span>
            </div>
          </div>

          <!-- Footer note -->
          <div class="receipt-footer-note">
            <i class="fa-solid fa-shield-halved"></i>
            This receipt is auto-generated and serves as proof of transaction submission.
          </div>

        </div><!-- /.receipt-wrap -->

        <!-- Actions -->
        <div class="receipt-actions">
          <button class="btn btn-primary" id="printReceiptBtn">
            <i class="fa-solid fa-print"></i> Print Receipt
          </button>
          <button class="btn btn-ghost" id="downloadReceiptBtn">
            <i class="fa-solid fa-download"></i> Download PDF
          </button>
          <a href="/user/transaction-history" class="btn btn-outline">
            <i class="fa-solid fa-list"></i> View All Transactions
          </a>
        </div>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
  <script>
    document.getElementById('printReceiptBtn').addEventListener('click', () => window.print());
    document.getElementById('downloadReceiptBtn').addEventListener('click', () => {
      // Trigger server-side PDF by linking to statement download with refCode filter
      // For now, print to PDF via browser
      window.print();
    });
  </script>
</body>
</html>
