<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Notifications | <%= websiteName %></title>

  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/user/notifications.css" />
</head>
<body>

  <%
    locals.currentPath = '/user/notification';
  %>

  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="notif-page fade-in">

        <!-- Page Header -->
        <div class="page-header">
          <div class="page-header-left">
            <div class="page-icon">
              <i class="fa-regular fa-bell"></i>
            </div>
            <div>
              <h1 class="page-title">Notifications</h1>
              <p class="page-subtitle">
                <% const unreadCount = msg.filter(n => n.status === 'Unread').length; %>
                <% if (unreadCount > 0) { %>
                  <span class="unread-count-text"><%= unreadCount %> unread message<%= unreadCount !== 1 ? 's' : '' %></span>
                <% } else { %>
                  All caught up
                <% } %>
              </p>
            </div>
          </div>
          <% if (unreadCount > 0) { %>
          <form action="/user/notifications/mark-all-read?_method=PUT" method="POST">
            <button type="submit" class="btn btn-ghost btn-sm">
              <i class="fa-regular fa-circle-check"></i>
              Mark all as read
            </button>
          </form>
          <% } %>
        </div>

        <!-- Filter tabs -->
        <div class="notif-tabs">
          <button class="notif-tab active" data-filter="all">
            All
            <span class="tab-count"><%= msg.length %></span>
          </button>
          <button class="notif-tab" data-filter="unread">
            Unread
            <span class="tab-count"><%= unreadCount %></span>
          </button>
          <button class="notif-tab" data-filter="read">
            Read
            <span class="tab-count"><%= openedmsg.length %></span>
          </button>
        </div>

        <!-- Notifications List -->
        <div class="notif-list" id="notifList">
          <% if (msg.length === 0) { %>
            <div class="notif-empty">
              <div class="empty-icon">
                <i class="fa-regular fa-bell-slash"></i>
              </div>
              <p class="empty-title">No notifications yet</p>
              <p class="empty-sub">We'll let you know when something important happens.</p>
            </div>
          <% } else { %>
            <% msg.forEach(function(notification) { %>
              <div class="notif-item <%= notification.status === 'Unread' ? 'is-unread' : '' %>" data-status="<%= notification.status.toLowerCase() %>">
                <div class="notif-dot-col">
                  <% if (notification.status === 'Unread') { %>
                    <span class="notif-dot"></span>
                  <% } else { %>
                    <span class="notif-dot-read"></span>
                  <% } %>
                </div>
                <div class="notif-icon-col">
                  <div class="notif-icon <%= notification.status === 'Unread' ? 'notif-icon--unread' : '' %>">
                    <i class="fa-regular fa-bell"></i>
                  </div>
                </div>
                <a href="/user/notification/<%= notification._id %>" class="notif-body">
                  <div class="notif-title-row">
                    <span class="notif-title"><%= notification.title %></span>
                    <span class="notif-time"><%= new Date(notification.notificationdate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                  </div>
                  <p class="notif-message"><%= notification.message.substring(0, 120) %><%= notification.message.length > 120 ? '...' : '' %></p>
                  <% if (notification.status === 'Unread') { %>
                    <span class="badge badge-accent notif-badge-label">New</span>
                  <% } %>
                </a>
                <div class="notif-actions">
                  <form action="/user/notification/<%= notification._id %>/delete?_method=DELETE" method="POST" onsubmit="return confirm('Delete this notification?')">
                    <button type="submit" class="btn-icon notif-delete-btn" title="Delete">
                      <i class="fa-regular fa-trash-can"></i>
                    </button>
                  </form>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
  <script>
    // Filter tabs
    const tabs = document.querySelectorAll('.notif-tab');
    const items = document.querySelectorAll('.notif-item');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = tab.dataset.filter;
        items.forEach(item => {
          if (filter === 'all') {
            item.style.display = '';
          } else {
            item.style.display = item.dataset.status === filter ? '' : 'none';
          }
        });
      });
    });
  </script>
</body>
</html>
