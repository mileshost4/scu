<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Inter-Bank Transfer | <%= websiteName %></title>
  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/user/transfer.css" />
</head>
<body>

  <% locals.currentPath = '/user/transactions'; %>
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="transfer-page fade-in">

        <!-- PAGE HEADER -->
        <div class="page-header">
          <div class="page-header-left">
            <h1>
              <span class="ph-icon" style="background:var(--info-dim);color:var(--info)">
                <i class="fa-solid fa-right-left"></i>
              </span>
              Inter-Bank Transfer
            </h1>
            <p>Send funds to any account at another bank. Processed within 1–2 business days.</p>
          </div>
          <div style="display:flex;gap:10px">
            <a href="/user/transactions" class="btn btn-ghost btn-sm"><i class="fa-solid fa-grid-2"></i> All Transfers</a>
            <a href="/user/transaction-history" class="btn btn-ghost btn-sm"><i class="fa-solid fa-clock-rotate-left"></i> History</a>
          </div>
        </div>

        <div class="transfer-body">
          <div class="transfer-main">

            <!-- HERO -->
            <div class="transfer-hero" style="background:linear-gradient(135deg,#091828 0%,#0a1f4e 55%,#091828 100%);border-color:rgba(77,159,255,0.15)">
              <div class="transfer-hero-label">You are sending</div>
              <div class="transfer-hero-amount">
                <span class="currency-sym"><%= user.basecurrencysymbol || '$' %></span><span id="inter-hero-amount">0.00</span>
              </div>
              <div class="transfer-hero-meta">
                <div class="transfer-hero-pill" style="border-color:rgba(77,159,255,0.2)">
                  <i class="fa-solid fa-clock" style="color:var(--info)"></i> 1–2 business days
                </div>
                <div class="transfer-hero-pill" style="border-color:rgba(77,159,255,0.2)">
                  <i class="fa-solid fa-right-left" style="color:var(--info)"></i> Local bank
                </div>
                <div class="transfer-hero-pill" style="border-color:rgba(77,159,255,0.2)">
                  <i class="fa-solid fa-shield-halved" style="color:var(--info)"></i> PIN secured
                </div>
              </div>
            </div>

            <!-- FORM -->
            <div class="section-card">
              <div class="section-head">
                <div class="section-title">
                  <i class="fa-solid fa-right-left" style="background:var(--info-dim);color:var(--info)"></i>
                  Transfer Details
                </div>
                <span class="badge badge-info">Inter-Bank</span>
              </div>
              <div class="section-body">

                <!-- Source account -->
                <div style="margin-bottom:22px">
                  <div class="form-label" style="margin-bottom:12px">
                    <i class="fa-solid fa-1" style="background:var(--info);color:var(--text-inverse);width:20px;height:20px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:0.65rem;margin-right:8px"></i>
                    Select source account
                  </div>
                  <div class="account-selector" id="inter-account-selector">
                    <% allaccounts.forEach(function(acct, idx) { %>
                      <label class="account-option <%= idx === 0 ? 'selected' : '' %>" for="inter-acct-<%= acct._id %>"
                        style="<%= idx === 0 ? 'border-color:var(--info);background:var(--info-dim)' : '' %>">
                        <input type="radio" name="inter_account_select" id="inter-acct-<%= acct._id %>"
                          value="<%= acct._id %>"
                          data-balance="<%= parseFloat(acct.accountWallet) %>"
                          <%= idx === 0 ? 'checked' : '' %>
                          onchange="selectInterAccount(this)" />
                        <div class="account-option-radio" style="<%= idx === 0 ? 'border-color:var(--info);background:var(--info)' : '' %>">
                          <% if (idx === 0) { %><span style="width:6px;height:6px;border-radius:50%;background:#fff;display:block"></span><% } %>
                        </div>
                        <div class="account-option-icon" style="background:var(--info-dim);color:var(--info)"><i class="fa-solid fa-building-columns"></i></div>
                        <div class="account-option-info">
                          <div class="account-option-name"><%= acct.displayName || acct.accountType %></div>
                          <div class="account-option-meta">
                            <span>•••• <%= String(acct.accountNumber).slice(-4) %></span>
                            <span>·</span>
                            <span><%= acct.accountType %></span>
                          </div>
                        </div>
                        <div class="account-option-balance" style="color:var(--info)">
                          <%= user.basecurrencysymbol || '$' %><%= parseFloat(acct.accountWallet).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %>
                        </div>
                      </label>
                    <% }); %>
                  </div>
                </div>

                <div class="form-label" style="margin-bottom:16px">
                  <i class="fa-solid fa-2" style="background:var(--info);color:var(--text-inverse);width:20px;height:20px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:0.65rem;margin-right:8px"></i>
                  Recipient & destination bank
                </div>

                <form id="interTransferForm" action="/user/interbank-transfer" method="POST" class="transfer-form">
                  <input type="hidden" name="account" id="inter-account-hidden" value="<%= allaccounts.length ? allaccounts[0]._id : '' %>" />
                  <input type="hidden" name="transferPin" id="inter-pin-hidden" />

                  <div class="form-row" style="margin-bottom:18px">
                    <div class="form-group">
                      <label class="form-label" for="inter-receiver-name">Recipient full name</label>
                      <input type="text" class="form-control" id="inter-receiver-name" name="receiverAccountName"
                        placeholder="e.g. Jane Smith" required autocomplete="off"
                        oninput="updateInterSummary()" />
                    </div>
                    <div class="form-group">
                      <label class="form-label" for="inter-receiver-acct">Recipient account number</label>
                      <input type="number" class="form-control" id="inter-receiver-acct" name="receiverAccountNumber"
                        placeholder="10-digit account number" required autocomplete="off"
                        oninput="updateInterSummary()" />
                    </div>
                  </div>

                  <!-- Destination bank selector -->
                  <div class="form-group" style="margin-bottom:18px">
                    <label class="form-label" for="inter-bank-to">Destination bank</label>
                    <div class="bank-select-wrap">
                      <i class="bank-icon fa-solid fa-building-columns"></i>
                      <select class="form-control" id="inter-bank-to" name="bankTo"
                        required onchange="handleInterBankChange(this)">
                        <option value="">— Select bank —</option>
                        <option value="Access Bank">Access Bank</option>
                        <option value="First Bank">First Bank</option>
                        <option value="GTBank">GTBank</option>
                        <option value="UBA">UBA</option>
                        <option value="Zenith Bank">Zenith Bank</option>
                        <option value="Fidelity Bank">Fidelity Bank</option>
                        <option value="Union Bank">Union Bank</option>
                        <option value="Sterling Bank">Sterling Bank</option>
                        <option value="Keystone Bank">Keystone Bank</option>
                        <option value="Polaris Bank">Polaris Bank</option>
                        <option value="Wema Bank">Wema Bank</option>
                        <option value="FCMB">FCMB</option>
                        <option value="Stanbic IBTC">Stanbic IBTC</option>
                        <option value="Citibank">Citibank</option>
                        <option value="Heritage Bank">Heritage Bank</option>
                        <option value="others">Other bank...</option>
                      </select>
                      <i class="select-arrow fa-solid fa-chevron-down"></i>
                    </div>
                    <div class="other-bank-wrap" id="inter-other-bank-wrap">
                      <input type="text" class="form-control" id="inter-other-bank" name="otherBank"
                        placeholder="Enter bank name" />
                    </div>
                  </div>

                  <div class="form-group" style="margin-bottom:18px">
                    <label class="form-label" for="inter-amount">Amount</label>
                    <div class="amount-input-wrap">
                      <span class="amount-currency-prefix" style="color:var(--info);background:var(--info-dim)"><%= user.basecurrencysymbol || '$' %></span>
                      <input type="number" class="form-control" id="inter-amount" name="amount"
                        placeholder="0.00" min="1" step="0.01" required
                        oninput="updateInterHero(this.value); updateInterSummary()" />
                    </div>
                    <div class="balance-hint">
                      <span class="avail">
                        <i class="fa-solid fa-circle-check"></i>
                        Available: <strong id="inter-avail-bal"><%= user.basecurrencysymbol || '$' %><%= allaccounts.length ? parseFloat(allaccounts[0].accountWallet).toLocaleString(undefined,{minimumFractionDigits:2}) : '0.00' %></strong>
                      </span>
                      <button type="button" class="use-all-btn" onclick="useInterMaxBal()">Use max</button>
                    </div>
                  </div>

                  <div class="form-group">
                    <label class="form-label" for="inter-description">Narration <span style="color:var(--text-muted);font-weight:400">(optional)</span></label>
                    <input type="text" class="form-control" id="inter-description" name="description"
                      placeholder="e.g. Loan repayment" maxlength="120"
                      oninput="updateInterSummary()" />
                  </div>

                  <!-- Summary -->
                  <div class="transfer-summary">
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-solid fa-user"></i> Recipient</span>
                      <span class="summary-value" id="inter-sum-name">—</span>
                    </div>
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-solid fa-hashtag"></i> Account</span>
                      <span class="summary-value" id="inter-sum-acct">—</span>
                    </div>
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-solid fa-building-columns"></i> Destination bank</span>
                      <span class="summary-value" id="inter-sum-bank">—</span>
                    </div>
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-solid fa-clock"></i> Settlement</span>
                      <span class="summary-value" style="color:var(--info)">1–2 business days</span>
                    </div>
                    <div class="summary-row">
                      <span class="summary-label"><i class="fa-solid fa-dollar-sign"></i> Amount</span>
                      <span class="summary-value amount" id="inter-sum-amount" style="color:var(--info)">—</span>
                    </div>
                  </div>

                  <div class="transfer-submit-row">
                    <a href="/user/transactions" class="btn btn-ghost btn-sm">
                      <i class="fa-solid fa-arrow-left"></i> Back
                    </a>
                    <button type="button" class="btn btn-primary" style="background:var(--info)"
                      onclick="openInterPinModal()">
                      <i class="fa-solid fa-shield-halved"></i> Authorise & Send
                    </button>
                  </div>
                </form>

              </div>
            </div>

          </div>

          <!-- ASIDE -->
          <div class="transfer-aside">
            <div class="widget">
              <div class="widget-head">
                <span class="widget-title"><i class="fa-solid fa-circle-info"></i> Transfer Type</span>
              </div>
              <div class="widget-body">
                <div class="transfer-type-badge" style="border-color:var(--info);background:var(--info-dim)">
                  <div class="ttb-icon" style="background:rgba(77,159,255,0.15);color:var(--info)"><i class="fa-solid fa-right-left"></i></div>
                  <div class="ttb-info">
                    <div class="ttb-name">Inter-Bank</div>
                    <div class="ttb-desc">Transfer to another local bank. Reviewed and processed by our team.</div>
                  </div>
                </div>
                <div class="tip-list">
                  <div class="tip-item"><i class="fa-solid fa-clock" style="color:var(--info)"></i>Processed within 1–2 business days.</div>
                  <div class="tip-item"><i class="fa-solid fa-shield-halved" style="color:var(--info)"></i>PIN authorisation required for every transfer.</div>
                  <div class="tip-item"><i class="fa-solid fa-triangle-exclamation"></i>Double-check bank and account number before submitting.</div>
                  <div class="tip-item"><i class="fa-solid fa-hourglass-half"></i>Funds are locked until transfer is approved.</div>
                </div>
              </div>
            </div>

            <div class="widget">
              <div class="widget-head">
                <span class="widget-title"><i class="fa-solid fa-wallet"></i> My Accounts</span>
              </div>
              <div class="widget-body">
                <div class="balance-account-list">
                  <% allaccounts.forEach(function(acct) { %>
                    <div class="balance-account-item">
                      <span class="bal-acct-name"><span class="bal-acct-dot" style="background:var(--info)"></span><%= acct.displayName || acct.accountType %></span>
                      <span class="bal-acct-value"><%= user.basecurrencysymbol || '$' %><%= parseFloat(acct.accountWallet).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
                    </div>
                  <% }); %>
                </div>
              </div>
            </div>

            <div class="widget">
              <div class="widget-head">
                <span class="widget-title"><i class="fa-solid fa-clock-rotate-left"></i> Recent</span>
                <a href="/user/transaction-history" style="font-size:0.75rem;color:var(--accent);text-decoration:none;font-weight:600">All →</a>
              </div>
              <div class="tx-list">
                <% const interTx = transactions.filter(t => t.transferType === 'Inter-Bank').slice(0,4); %>
                <% if (interTx.length > 0) { %>
                  <% interTx.forEach(function(tx) { %>
                    <a href="/user/transaction/<%= tx._id %>/receipt" class="tx-item">
                      <div class="tx-icon <%= tx.status === 'Pending' ? 'pending' : 'transfer' %>"><i class="fa-solid fa-right-left"></i></div>
                      <div class="tx-info">
                        <div class="tx-name"><%= (tx.receiverAccountName || '—').substring(0,20) %></div>
                        <div class="tx-meta">
                          <span class="badge badge-<%= tx.status === 'Successful' ? 'success' : tx.status === 'Pending' ? 'warning' : 'danger' %>" style="padding:1px 5px;font-size:0.6rem"><%= tx.status %></span>
                          <% if(tx.bankTo) { %><span>· <%= tx.bankTo %></span><% } %>
                        </div>
                      </div>
                      <div class="tx-right">
                        <div class="tx-amount">-<%= user.basecurrencysymbol || '$' %><%= parseFloat(tx.amount).toLocaleString(undefined,{minimumFractionDigits:2}) %></div>
                        <div class="tx-date"><%= new Date(tx.date).toLocaleDateString('en-US',{month:'short',day:'numeric'}) %></div>
                      </div>
                    </a>
                  <% }); %>
                <% } else { %>
                  <div class="tx-empty"><i class="fa-solid fa-right-left"></i>No inter-bank transfers</div>
                <% } %>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- PIN MODAL -->
  <div class="custom-modal-overlay" id="interPinModal" onclick="if(event.target===this)closeInterPinModal()">
    <div class="pin-modal">
      <div class="pin-modal-header">
        <div class="pin-modal-title">
          <span class="pin-modal-icon" style="background:var(--info-dim);color:var(--info)"><i class="fa-solid fa-lock"></i></span>
          Confirm Transfer
        </div>
        <button class="pin-modal-close" onclick="closeInterPinModal()"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="pin-modal-body">
        <div class="pin-confirm-summary">
          <div class="pin-confirm-row">
            <span class="pcr-label">To</span>
            <span class="pcr-value" id="ipin-sum-name">—</span>
          </div>
          <div class="pin-confirm-row">
            <span class="pcr-label">Bank</span>
            <span class="pcr-value" id="ipin-sum-bank">—</span>
          </div>
          <div class="pin-confirm-row">
            <span class="pcr-label">Amount</span>
            <span class="pcr-value highlight" id="ipin-sum-amount" style="color:var(--info)">—</span>
          </div>
        </div>

        <div class="pin-dots-wrap" id="interPinDots">
          <% for(let i=0;i<4;i++) { %>
            <div class="pin-dot" id="interPinDot<%= i %>" style="border-color:rgba(77,159,255,0.3)"></div>
          <% } %>
        </div>

        <div class="pin-input-wrap">
          <input type="password" class="form-control" id="interPinInput"
            placeholder="Enter your transaction PIN"
            maxlength="4" inputmode="numeric" autocomplete="off"
            oninput="onInterPinInput(this.value)" />
          <button type="button" class="pin-input-toggle" onclick="toggleInterPinVisibility()">
            <i class="fa-solid fa-eye" id="interPinEyeIcon"></i>
          </button>
        </div>
        <div class="pin-error-msg" id="interPinErrorMsg">Incorrect PIN. Please try again.</div>
      </div>
      <div class="pin-modal-footer">
        <button type="button" class="btn btn-ghost" onclick="closeInterPinModal()">Cancel</button>
        <button type="button" class="btn btn-primary" style="background:var(--info)" onclick="submitInterTransfer()">
          <i class="fa-solid fa-paper-plane"></i> Confirm
        </button>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
  <script>
    let interSelectedBalance = <%= allaccounts.length ? parseFloat(allaccounts[0].accountWallet) : 0 %>;

    document.querySelectorAll('#inter-account-selector .account-option').forEach(function(opt) {
      opt.addEventListener('click', function() {
        document.querySelectorAll('#inter-account-selector .account-option').forEach(o => {
          o.classList.remove('selected');
          o.style.borderColor = '';
          o.style.background  = '';
        });
        this.classList.add('selected');
        this.style.borderColor = 'var(--info)';
        this.style.background  = 'var(--info-dim)';
      });
    });

    function selectInterAccount(radio) {
      interSelectedBalance = parseFloat(radio.dataset.balance) || 0;
      document.getElementById('inter-account-hidden').value = radio.value;
      document.getElementById('inter-avail-bal').textContent =
        '<%= user.basecurrencysymbol || "$" %>' + interSelectedBalance.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2});
    }

    function useInterMaxBal() {
      document.getElementById('inter-amount').value = interSelectedBalance.toFixed(2);
      updateInterHero(interSelectedBalance);
      updateInterSummary();
    }

    function updateInterHero(val) {
      const n = parseFloat(val) || 0;
      document.getElementById('inter-hero-amount').textContent =
        n.toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2});
    }

    function handleInterBankChange(sel) {
      const wrap = document.getElementById('inter-other-bank-wrap');
      const other = document.getElementById('inter-other-bank');
      if (sel.value === 'others') {
        wrap.classList.add('visible');
        other.required = true;
      } else {
        wrap.classList.remove('visible');
        other.required = false;
        other.value = '';
      }
      updateInterSummary();
    }

    function updateInterSummary() {
      const name   = document.getElementById('inter-receiver-name').value || '—';
      const acct   = document.getElementById('inter-receiver-acct').value || '—';
      const bankEl = document.getElementById('inter-bank-to');
      let bank = bankEl.options[bankEl.selectedIndex]?.text || '—';
      if (bankEl.value === 'others') bank = document.getElementById('inter-other-bank').value || '—';
      const amount = parseFloat(document.getElementById('inter-amount').value) || 0;
      const sym    = '<%= user.basecurrencysymbol || "$" %>';

      document.getElementById('inter-sum-name').textContent   = name;
      document.getElementById('inter-sum-acct').textContent   = acct;
      document.getElementById('inter-sum-bank').textContent   = bank;
      document.getElementById('inter-sum-amount').textContent = amount > 0 ? sym + amount.toLocaleString(undefined,{minimumFractionDigits:2}) : '—';
    }

    function openInterPinModal() {
      const form = document.getElementById('interTransferForm');
      if (!form.checkValidity()) { form.reportValidity(); return; }

      const name   = document.getElementById('inter-receiver-name').value;
      const bankEl = document.getElementById('inter-bank-to');
      let bank = bankEl.options[bankEl.selectedIndex]?.text || '—';
      if (bankEl.value === 'others') bank = document.getElementById('inter-other-bank').value || '—';
      const amount = parseFloat(document.getElementById('inter-amount').value) || 0;
      const sym    = '<%= user.basecurrencysymbol || "$" %>';

      document.getElementById('ipin-sum-name').textContent   = name || '—';
      document.getElementById('ipin-sum-bank').textContent   = bank;
      document.getElementById('ipin-sum-amount').textContent = sym + amount.toLocaleString(undefined,{minimumFractionDigits:2});
      document.getElementById('interPinInput').value = '';
      document.getElementById('interPinErrorMsg').classList.remove('visible');
      resetInterPinDots();
      document.getElementById('interPinModal').classList.add('open');
      document.body.style.overflow = 'hidden';
      setTimeout(() => document.getElementById('interPinInput').focus(), 200);
    }

    function closeInterPinModal() {
      document.getElementById('interPinModal').classList.remove('open');
      document.body.style.overflow = '';
      document.getElementById('interPinInput').value = '';
      resetInterPinDots();
    }

    function onInterPinInput(val) {
      for (let i = 0; i < 4; i++) {
        const dot = document.getElementById('interPinDot' + i);
        dot.classList.toggle('filled', i < val.length);
        if (i < val.length) dot.style.background = 'var(--info)';
        else dot.style.background = '';
      }
      document.getElementById('interPinErrorMsg').classList.remove('visible');
    }

    function resetInterPinDots() {
      for (let i = 0; i < 4; i++) {
        const dot = document.getElementById('interPinDot' + i);
        dot.classList.remove('filled');
        dot.style.background = '';
      }
    }

    function toggleInterPinVisibility() {
      const input = document.getElementById('interPinInput');
      const icon  = document.getElementById('interPinEyeIcon');
      input.type  = input.type === 'password' ? 'text' : 'password';
      icon.className = input.type === 'password' ? 'fa-solid fa-eye' : 'fa-solid fa-eye-slash';
    }

    function submitInterTransfer() {
      const pin = document.getElementById('interPinInput').value.trim();
      if (!pin) {
        document.getElementById('interPinErrorMsg').textContent = 'Please enter your PIN.';
        document.getElementById('interPinErrorMsg').classList.add('visible');
        document.getElementById('interPinDots').classList.add('pin-shake');
        setTimeout(() => document.getElementById('interPinDots').classList.remove('pin-shake'), 500);
        return;
      }
      document.getElementById('inter-pin-hidden').value = pin;
      document.getElementById('interTransferForm').submit();
    }

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeInterPinModal();
      if (e.key === 'Enter' && document.getElementById('interPinModal').classList.contains('open')) submitInterTransfer();
    });
  </script>
</body>
</html>
