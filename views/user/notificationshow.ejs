<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Notification | <%= websiteName %></title>

  <link rel="icon" type="image/png" href="/images/logo.png" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="/stylesheets/partials/theme.css" />
  <link rel="stylesheet" href="/stylesheets/partials/navbar.css" />
  <link rel="stylesheet" href="/stylesheets/partials/flash.css" />
  <link rel="stylesheet" href="/stylesheets/user/notifications.css" />
</head>
<body>

  <%
    locals.currentPath = '/user/notification';
  %>

  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="main-content" id="mainContent">
    <div class="page-inner">
      <div class="notif-page fade-in">

        <!-- Back nav -->
        <a href="/user/notification" class="notif-back">
          <i class="fa-solid fa-arrow-left-long"></i>
          Back to Notifications
        </a>

        <!-- Notification Card -->
        <div class="notif-detail-card card">
          <div class="notif-detail-header">
            <div class="notif-detail-icon">
              <i class="fa-regular fa-bell"></i>
            </div>
            <div class="notif-detail-meta">
              <h2 class="notif-detail-title"><%= notification.title %></h2>
              <div class="notif-detail-info">
                <span class="notif-detail-date">
                  <i class="fa-regular fa-clock"></i>
                  <%= new Date(notification.notificationdate).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                  &nbsp;·&nbsp;
                  <%= new Date(notification.notificationdate).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %>
                </span>
                <span class="badge <%= notification.status === 'Unread' ? 'badge-accent' : 'badge-info' %>">
                  <%= notification.status %>
                </span>
              </div>
            </div>
          </div>

          <div class="notif-detail-divider"></div>

          <div class="notif-detail-body">
            <p class="notif-detail-message"><%= notification.message %></p>
          </div>

          <div class="notif-detail-footer">
            <a href="/user/notification" class="btn btn-ghost btn-sm">
              <i class="fa-solid fa-arrow-left"></i>
              All Notifications
            </a>
            <form action="/user/notification/<%= notification._id %>/delete?_method=DELETE" method="POST" onsubmit="return confirm('Delete this notification?')">
              <button type="submit" class="btn btn-danger btn-sm">
                <i class="fa-regular fa-trash-can"></i>
                Delete
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
  <script src="/script/partials/navbar.js"></script>
</body>
</html>
