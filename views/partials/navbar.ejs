<%
/*
  NAVBAR + SIDEBAR PARTIAL — views/partials/navbar.ejs
  All logout links now trigger the logout confirmation modal instead of
  navigating directly. The modal itself lives in each page that includes
  this partial (dashboard, my-accounts, etc.). For pages that DON'T have
  the modal inlined, a fallback <div> is injected by this partial so the
  openLogoutModal() call never errors.
*/

const _initials = user
  ? (user.firstname ? user.firstname[0].toUpperCase() : '')
  + (user.lastname  ? user.lastname[0].toUpperCase()  : '')
  : 'U';

const _unread = (typeof unreadmsg !== 'undefined' && Array.isArray(unreadmsg))
  ? unreadmsg.length : 0;

let _statusLabel = 'Unverified';
let _statusClass = 'unverified';
if (user && user.verificationstatus === 'Verified' && user.accountStatus === 'Active') {
  _statusLabel = 'Verified';    _statusClass = 'verified';
} else if (user && user.verificationstatus === 'Pending') {
  _statusLabel = 'Pending KYC'; _statusClass = 'pending';
} else if (user && user.accountStatus === 'Suspended') {
  _statusLabel = 'Suspended';   _statusClass = 'suspended';
}

const _path   = locals.currentPath || '';
const _active = (p) => _path === p ? 'active' : '';
%>

<!-- ═══════════════════════════════════════════════════════════
     TOP NAVBAR
════════════════════════════════════════════════════════════ -->
<nav class="navbar" id="mainNavbar">

  <div class="navbar-left">
    <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
      <a href="/dashboard" class="navbar-logo">
        <img src="/images/logo.png" alt="Logo" onerror="this.style.display='none'" />
        <span class="logo-text">SCU</span>
      </a>
      <div class="hamburger-icon">
        <span></span><span></span><span></span>
      </div>
    </button>
  </div>

  <div class="navbar-right">

    <!-- Notifications -->
    <a href="/user/notification" class="nav-notif" title="Notifications">
      <i class="fa-regular fa-bell"></i>
      <% if (_unread > 0) { %>
        <span class="notif-badge"><%= _unread > 9 ? '9+' : _unread %></span>
      <% } %>
    </a>

    <!-- Theme toggle -->
    <div class="theme-toggle" id="themeToggleWrap">
      <button class="theme-toggle-btn" id="themeToggleBtn" aria-label="Toggle theme">
        <i class="fa-solid fa-moon theme-icon" id="themeIcon"></i>
        <span id="themeLabel">Dark</span>
        <i class="fa-solid fa-chevron-down" style="font-size:0.65rem; color:var(--text-muted)"></i>
      </button>
      <div class="dropdown-panel theme-dropdown" id="themeDropdown">
        <button class="theme-option active" data-theme-opt="dark"   onclick="setTheme('dark')">
          <i class="fa-solid fa-moon"></i> Dark
        </button>
        <button class="theme-option"        data-theme-opt="light"  onclick="setTheme('light')">
          <i class="fa-solid fa-sun"></i> Light
        </button>
        <button class="theme-option"        data-theme-opt="system" onclick="setTheme('system')">
          <i class="fa-solid fa-circle-half-stroke"></i> System
        </button>
      </div>
    </div>

    <!-- User dropdown -->
    <div class="nav-user" id="navUser">
      <button class="nav-user-btn" id="navUserBtn" aria-label="User menu">
        <div class="nav-avatar">
          <% if (user && user.profilepicture && user.profilepicture.length > 0) { %>
            <img src="<%= user.profilepicture[0].url %>" alt="avatar" />
          <% } else { %>
            <%= _initials %>
          <% } %>
        </div>
        <div class="nav-user-info">
          <span class="nav-user-name"><%= user ? user.firstname : 'User' %></span>
          <span class="nav-user-status <%= _statusClass %>"><%= _statusLabel %></span>
        </div>
        <i class="fa-solid fa-chevron-down nav-caret"></i>
      </button>

      <div class="dropdown-panel" id="userDropdown">
        <div class="dropdown-header">
          <div class="dh-name"><%= user ? user.firstname + ' ' + user.lastname : '' %></div>
          <div class="dh-email"><%= user ? user.email : '' %></div>
          <div class="dh-meta">
            <span class="badge badge-<%= _statusClass === 'verified' ? 'success' : _statusClass === 'pending' ? 'warning' : 'danger' %>">
              <i class="fa-solid fa-<%= _statusClass === 'verified' ? 'circle-check' : _statusClass === 'pending' ? 'clock' : 'triangle-exclamation' %>"></i>
              <%= _statusLabel %>
            </span>
          </div>
        </div>

        <a href="/user/profile"    class="dropdown-item"><i class="fa-regular fa-user"></i> My Profile</a>
        <!-- <a href="/user/account"    class="dropdown-item"><i class="fa-solid fa-gear"></i> Account Settings</a> -->
        <a href="/user/security"   class="dropdown-item"><i class="fa-solid fa-shield-halved"></i> Security</a>
        <a href="/user/kyc"        class="dropdown-item"><i class="fa-solid fa-id-card"></i> KYC Verification</a>
        <div class="dropdown-divider"></div>
        <a href="/user/statement/download" class="dropdown-item"><i class="fa-solid fa-file-pdf"></i> Download Statement</a>
        <div class="dropdown-divider"></div>
        <!-- Logout now triggers confirmation modal -->
        <button type="button" class="dropdown-item danger" onclick="openLogoutModal()">
          <i class="fa-solid fa-arrow-right-from-bracket"></i> Sign Out
        </button>
      </div>
    </div>

  </div>
</nav>

<!-- ═══════════════════════════════════════════════════════════
     SIDEBAR
════════════════════════════════════════════════════════════ -->


<aside class="sidebar" id="sidebar">

  <!-- SCROLLABLE MIDDLE — all nav items go here -->
  <div class="sidebar-scroll">
    <div class="sidebar-scroll-inner">

      <div class="sidebar-section-label">Overview</div>

      <a href="/dashboard" class="sidebar-item <%= _active('/dashboard') %>" data-tooltip="Dashboard">
        <i class="fa-solid fa-gauge-high"></i>
        <span class="item-label">Dashboard</span>
      </a>

      <a href="/user/transaction-history" class="sidebar-item <%= _active('/user/transaction-history') %>" data-tooltip="Transactions">
        <i class="fa-solid fa-arrow-right-arrow-left"></i>
        <span class="item-label">Transaction History</span>
      </a>

      <a href="/user/notification" class="sidebar-item <%= _active('/user/notification') %>" data-tooltip="Notifications">
        <i class="fa-regular fa-bell"></i>
        <span class="item-label">Notifications</span>
        <% if (_unread > 0) { %>
          <span class="item-badge"><%= _unread > 9 ? '9+' : _unread %></span>
        <% } %>
      </a>

      <div class="sidebar-section-label">Transfers</div>

      <a href="/user/transactions" class="sidebar-item <%= _active('/user/transactions') %>" data-tooltip="All Transfers">
        <i class="fa-solid fa-paper-plane"></i>
        <span class="item-label">All Transfers</span>
      </a>

      <div class="sidebar-group">
        <button class="sidebar-group-toggle" id="transferGroupToggle" data-tooltip="Transfer Types">
          <i class="fa-solid fa-money-bill-transfer"></i>
          <span class="toggle-label">Transfer Types</span>
          <i class="fa-solid fa-chevron-right toggle-caret"></i>
        </button>
        <div class="sidebar-sub" id="transferSub">
          <a href="/user/intrabank-transfer" class="sidebar-item <%= _active('/user/intrabank-transfer') %>" data-tooltip="Intra-Bank">
            <i class="fa-solid fa-building-columns"></i><span class="item-label">Intra-Bank</span>
          </a>
          <a href="/user/interbank-transfer" class="sidebar-item <%= _active('/user/interbank-transfer') %>" data-tooltip="Inter-Bank">
            <i class="fa-solid fa-right-left"></i><span class="item-label">Inter-Bank</span>
          </a>
          <a href="/user/international-transfer" class="sidebar-item <%= _active('/user/international-transfer') %>" data-tooltip="International">
            <i class="fa-solid fa-earth-americas"></i><span class="item-label">International Wire</span>
          </a>
        </div>
      </div>

      <div class="sidebar-section-label">Banking</div>

      <a href="/user/deposit"        class="sidebar-item <%= _active('/user/deposit') %>"        data-tooltip="Deposit">
        <i class="fa-solid fa-circle-down"></i><span class="item-label">Deposit (Bank)</span>
      </a>
      <a href="/user/deposit-crypto" class="sidebar-item <%= _active('/user/deposit-crypto') %>" data-tooltip="Crypto Deposit">
        <i class="fa-brands fa-bitcoin"></i><span class="item-label">Crypto Deposit</span>
      </a>
      <a href="/user/my-accounts"    class="sidebar-item <%= _active('/user/my-accounts') %>"    data-tooltip="My Accounts">
        <i class="fa-solid fa-building-columns"></i><span class="item-label">My Accounts</span>
      </a>
      <a href="/user/cards"          class="sidebar-item <%= _active('/user/cards') %>"          data-tooltip="Cards">
        <i class="fa-regular fa-credit-card"></i><span class="item-label">My Cards</span>
      </a>
      <a href="/user/pay-bills"      class="sidebar-item <%= _active('/user/pay-bills') %>"      data-tooltip="Pay Bills">
        <i class="fa-solid fa-file-invoice-dollar"></i><span class="item-label">Pay Bills</span>
      </a>

      <div class="sidebar-section-label">Grow</div>

      <a href="/user/investments"     class="sidebar-item <%= _active('/user/investments') %>"     data-tooltip="Investments">
        <i class="fa-solid fa-chart-line"></i><span class="item-label">Investments</span>
      </a>
      <a href="/user/loan"            class="sidebar-item <%= _active('/user/loan') %>"            data-tooltip="Loans">
        <i class="fa-solid fa-hand-holding-dollar"></i><span class="item-label">Loans</span>
      </a>
      <a href="/user/upgrade-account" class="sidebar-item <%= _active('/user/upgrade-account') %>" data-tooltip="Upgrade">
        <i class="fa-solid fa-star"></i><span class="item-label">Upgrade Account</span>
      </a>

      <div class="sidebar-section-label">Account</div>

      <a href="/user/profile"  class="sidebar-item <%= _active('/user/profile') %>"  data-tooltip="Profile">
        <i class="fa-regular fa-user"></i><span class="item-label">Profile</span>
      </a>
      <a href="/user/security" class="sidebar-item <%= _active('/user/security') %>" data-tooltip="Security">
        <i class="fa-solid fa-shield-halved"></i><span class="item-label">Security</span>
      </a>
      <a href="/user/support"  class="sidebar-item <%= _active('/user/support') %>"  data-tooltip="Support">
        <i class="fa-regular fa-circle-question"></i><span class="item-label">Support</span>
      </a>

    </div><!-- /.sidebar-scroll-inner -->
  </div><!-- /.sidebar-scroll -->

  <!-- PINNED FOOTER — outside the scroll area, always visible -->
  <div class="sidebar-footer">
    <button type="button" class="sidebar-item" data-tooltip="Sign Out"
      style="color:var(--danger); border:none; background:transparent; width:100%; text-align:left; cursor:pointer;"
      onclick="openLogoutModal()">
      <i class="fa-solid fa-arrow-right-from-bracket"></i>
      <span class="item-label">Sign Out</span>
    </button>
  </div>

</aside>

<!-- Mobile overlay -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<!--
  Shared logout confirmation modal.
  Injected here so it's available on every page that includes this partial.
  Pages that define their own #logoutModal will have it overwritten — that's fine,
  they're identical. openLogoutModal() targets whichever #logoutModal is in the DOM.
-->
<div class="custom-modal-overlay logout-modal" id="logoutModal" onclick="if(event.target===this)closeLogoutModal()">
  <div class="custom-modal" style="max-width:400px">
    <div class="custom-modal-header">
      <div class="custom-modal-title" style="gap:10px">
        <span style="width:32px;height:32px;border-radius:var(--radius-md);background:var(--danger-dim);color:var(--danger);display:flex;align-items:center;justify-content:center;font-size:0.85rem;flex-shrink:0">
          <i class="fa-solid fa-arrow-right-from-bracket"></i>
        </span>
        Sign Out
      </div>
      <button class="custom-modal-close" onclick="closeLogoutModal()">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <div class="custom-modal-body" style="text-align:center; padding:28px 24px 20px;">
      <div style="width:64px;height:64px;border-radius:50%;background:var(--danger-dim);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:1.6rem;color:var(--danger)">
        <i class="fa-solid fa-arrow-right-from-bracket"></i>
      </div>
      <p style="font-size:0.97rem;font-weight:700;color:var(--text-primary);margin-bottom:6px">Sign out of your account?</p>
      <p style="font-size:0.82rem;color:var(--text-secondary)">You'll need your credentials to log back in.</p>
    </div>
    <div class="custom-modal-footer">
      <button type="button" class="btn btn-ghost btn-sm" onclick="closeLogoutModal()">Stay Logged In</button>
      <a href="/logout" class="btn btn-danger btn-sm">
        <i class="fa-solid fa-arrow-right-from-bracket"></i> Yes, Sign Out
      </a>
    </div>
  </div>
</div>

<style>
/* Shared modal styles — injected once via navbar partial so all pages get them */
.custom-modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(4px);
  z-index: 9000;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.custom-modal-overlay.open { display: flex; }
.custom-modal {
  background: var(--bg-card);
  border: 1px solid var(--border-strong);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-lg);
  width: 100%;
  max-width: 480px;
  animation: fadeIn 0.22s ease both;
}
.custom-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 22px 14px;
  border-bottom: 1px solid var(--border);
}
.custom-modal-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 10px;
}
.custom-modal-close {
  width: 30px; height: 30px;
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  background: transparent;
  color: var(--text-muted);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.8rem;
  transition: var(--transition);
}
.custom-modal-close:hover { background: var(--danger-dim); color: var(--danger); border-color: var(--danger); }
.custom-modal-body  { padding: 18px 22px; }
.custom-modal-footer {
  padding: 12px 22px 18px;
  display: flex;
  gap: 10px;
  justify-content: flex-end;
  border-top: 1px solid var(--border);
}
</style>

<script>
/* Logout modal helpers — globally available on every page */
function openLogoutModal() {
  var m = document.getElementById('logoutModal');
  if (m) { m.classList.add('open'); document.body.style.overflow = 'hidden'; }
}
function closeLogoutModal() {
  var m = document.getElementById('logoutModal');
  if (m) { m.classList.remove('open'); document.body.style.overflow = ''; }
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeLogoutModal();
});

/* Generic modal helpers for page-level modals */
if (typeof openModal === 'undefined') {
  window.openModal = function(id) {
    var el = document.getElementById(id);
    if (el) { el.classList.add('open'); document.body.style.overflow = 'hidden'; }
  };
  window.closeModal = function(id) {
    var el = document.getElementById(id);
    if (el) { el.classList.remove('open'); document.body.style.overflow = ''; }
  };
  window.handleOverlayClick = function(e, id) {
    if (e.target === e.currentTarget) window.closeModal(id);
  };
}
</script>
