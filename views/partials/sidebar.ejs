<!-- user -->
 <aside class="sidebar" id="sidebar">

  <div class="sidebar-section-label">Overview</div>

  <a href="/dashboard"                class="sidebar-item <%= _active('/dashboard') %>"                data-tooltip="Dashboard">
    <i class="fa-solid fa-gauge-high"></i>
    <span class="item-label">Dashboard</span>
  </a>

  <a href="/user/transaction-history" class="sidebar-item <%= _active('/user/transaction-history') %>" data-tooltip="Transactions">
    <i class="fa-solid fa-arrow-right-arrow-left"></i>
    <span class="item-label">Transaction History</span>
  </a>

  <a href="/user/notification"        class="sidebar-item <%= _active('/user/notification') %>"        data-tooltip="Notifications">
    <i class="fa-regular fa-bell"></i>
    <span class="item-label">Notifications</span>
    <% if (_unread > 0) { %>
      <span class="item-badge"><%= _unread > 9 ? '9+' : _unread %></span>
    <% } %>
  </a>

  <div class="sidebar-section-label">Transfers</div>

  <a href="/user/transactions"        class="sidebar-item <%= _active('/user/transactions') %>"        data-tooltip="All Transfers">
    <i class="fa-solid fa-paper-plane"></i>
    <span class="item-label">All Transfers</span>
  </a>

  <div class="sidebar-group">
    <button class="sidebar-group-toggle" id="transferGroupToggle" data-tooltip="Transfer Types">
      <i class="fa-solid fa-money-bill-transfer"></i>
      <span class="toggle-label">Transfer Types</span>
      <i class="fa-solid fa-chevron-right toggle-caret"></i>
    </button>
    <div class="sidebar-sub" id="transferSub">
      <a href="/user/intrabank-transfer"     class="sidebar-item <%= _active('/user/intrabank-transfer') %>"    data-tooltip="Intra-Bank">
        <i class="fa-solid fa-building-columns"></i><span class="item-label">Intra-Bank</span>
      </a>
      <a href="/user/interbank-transfer"     class="sidebar-item <%= _active('/user/interbank-transfer') %>"    data-tooltip="Inter-Bank">
        <i class="fa-solid fa-right-left"></i><span class="item-label">Inter-Bank</span>
      </a>
      <a href="/user/international-transfer" class="sidebar-item <%= _active('/user/international-transfer') %>" data-tooltip="International">
        <i class="fa-solid fa-earth-americas"></i><span class="item-label">International Wire</span>
      </a>
    </div>
  </div>

  <div class="sidebar-section-label">Banking</div>

  <a href="/user/deposit"        class="sidebar-item <%= _active('/user/deposit') %>"        data-tooltip="Deposit">
    <i class="fa-solid fa-circle-down"></i><span class="item-label">Deposit (Bank)</span>
  </a>
  <a href="/user/deposit-crypto" class="sidebar-item <%= _active('/user/deposit-crypto') %>" data-tooltip="Crypto Deposit">
    <i class="fa-brands fa-bitcoin"></i><span class="item-label">Crypto Deposit</span>
  </a>
  <a href="/user/my-accounts"    class="sidebar-item <%= _active('/user/my-accounts') %>"    data-tooltip="My Accounts">
    <i class="fa-solid fa-building-columns"></i><span class="item-label">My Accounts</span>
  </a>
  <a href="/user/cards"          class="sidebar-item <%= _active('/user/cards') %>"          data-tooltip="Cards">
    <i class="fa-regular fa-credit-card"></i><span class="item-label">My Cards</span>
  </a>
  <a href="/user/pay-bills"      class="sidebar-item <%= _active('/user/pay-bills') %>"      data-tooltip="Pay Bills">
    <i class="fa-solid fa-file-invoice-dollar"></i><span class="item-label">Pay Bills</span>
  </a>

  <div class="sidebar-section-label">Grow</div>

  <a href="/user/investments"     class="sidebar-item <%= _active('/user/investments') %>"     data-tooltip="Investments">
    <i class="fa-solid fa-chart-line"></i><span class="item-label">Investments</span>
  </a>
  <a href="/user/loan"            class="sidebar-item <%= _active('/user/loan') %>"            data-tooltip="Loans">
    <i class="fa-solid fa-hand-holding-dollar"></i><span class="item-label">Loans</span>
  </a>
  <a href="/user/upgrade-account" class="sidebar-item <%= _active('/user/upgrade-account') %>" data-tooltip="Upgrade">
    <i class="fa-solid fa-star"></i><span class="item-label">Upgrade Account</span>
  </a>

  <div class="sidebar-section-label">Account</div>

  <a href="/user/profile"  class="sidebar-item <%= _active('/user/profile') %>"  data-tooltip="Profile">
    <i class="fa-regular fa-user"></i><span class="item-label">Profile</span>
  </a>
  <a href="/user/security" class="sidebar-item <%= _active('/user/security') %>" data-tooltip="Security">
    <i class="fa-solid fa-shield-halved"></i><span class="item-label">Security</span>
  </a>
  <a href="/user/support"  class="sidebar-item <%= _active('/user/support') %>"  data-tooltip="Support">
    <i class="fa-regular fa-circle-question"></i><span class="item-label">Support</span>
  </a>

  <div class="sidebar-footer">
    <!-- Logout triggers confirmation modal -->
    <button type="button" class="sidebar-item" data-tooltip="Sign Out"
      style="color:var(--danger); border:none; background:transparent; width:100%; text-align:left; cursor:pointer;"
      onclick="openLogoutModal()">
      <i class="fa-solid fa-arrow-right-from-bracket"></i>
      <span class="item-label">Sign Out</span>
    </button>
  </div>

</aside>


<!-- Admin -->
 <aside class="sidebar" id="sidebar">

  <!-- ── Overview ── -->
  <div class="sidebar-section-label">Overview</div>

  <a href="/admin/admin.dashboard"
     class="sidebar-item <%= _active('/admin/admin.dashboard') %>"
     data-tooltip="Dashboard">
    <i class="fa-solid fa-gauge-high"></i>
    <span class="item-label">Dashboard</span>
  </a>

  <!-- ── Users ── -->
  <div class="sidebar-section-label">Users</div>

  <a href="/admin/admin.users"
     class="sidebar-item <%= _active('/admin/admin.users') %>"
     data-tooltip="All Users">
    <i class="fa-solid fa-users"></i>
    <span class="item-label">All Users</span>
  </a>

  <a href="/admin/admin.verification-requests"
     class="sidebar-item <%= _active('/admin/admin.verification-requests') %>"
     data-tooltip="Verification Requests">
    <i class="fa-solid fa-id-card"></i>
    <span class="item-label">Verification Requests</span>
  </a>

  <!-- ── Transactions ── -->
  <div class="sidebar-section-label">Transactions</div>

  <div class="sidebar-group">
    <button class="sidebar-group-toggle" id="transGroupToggle" data-tooltip="Transactions">
      <i class="fa-solid fa-arrow-right-arrow-left"></i>
      <span class="toggle-label">Transactions</span>
      <i class="fa-solid fa-chevron-right toggle-caret"></i>
    </button>
    <div class="sidebar-sub" id="transSub">
      <a href="/admin/admin.pending-transactions"
         class="sidebar-item <%= _active('/admin/admin.pending-transactions') %>"
         data-tooltip="Pending">
        <i class="fa-solid fa-hourglass-half"></i>
        <span class="item-label">Pending</span>
      </a>
      <a href="/admin/admin.approved-transactions"
         class="sidebar-item <%= _active('/admin/admin.approved-transactions') %>"
         data-tooltip="Approved">
        <i class="fa-solid fa-circle-check"></i>
        <span class="item-label">Approved</span>
      </a>
      <a href="/admin/admin.declined-transactions"
         class="sidebar-item <%= _active('/admin/admin.declined-transactions') %>"
         data-tooltip="Declined">
        <i class="fa-solid fa-circle-xmark"></i>
        <span class="item-label">Declined</span>
      </a>
      <a href="/admin/admin.delete-transactions"
         class="sidebar-item <%= _active('/admin/admin.delete-transactions') %>"
         data-tooltip="Delete">
        <i class="fa-solid fa-trash"></i>
        <span class="item-label">Delete Transactions</span>
      </a>
    </div>
  </div>

  <!-- ── Deposits ── -->
  <div class="sidebar-section-label">Deposits</div>

  <a href="/admin/admin.deposit-requests"
     class="sidebar-item <%= _active('/admin/admin.deposit-requests') %>"
     data-tooltip="Deposit Requests">
    <i class="fa-solid fa-inbox"></i>
    <span class="item-label">Deposit Requests</span>
  </a>

  <a href="/admin/admin.deposit-history"
     class="sidebar-item <%= _active('/admin/admin.deposit-history') %>"
     data-tooltip="Deposit History">
    <i class="fa-solid fa-clock-rotate-left"></i>
    <span class="item-label">Deposit History</span>
  </a>

  <a href="/admin/admin.depositmethods"
     class="sidebar-item <%= _active('/admin/admin.depositmethods') %>"
     data-tooltip="Deposit Methods">
    <i class="fa-brands fa-bitcoin"></i>
    <span class="item-label">Deposit Methods</span>
  </a>

  <!-- ── Cards ── -->
  <div class="sidebar-section-label">Cards</div>

  <a href="/admin/admin.cards"
     class="sidebar-item <%= _active('/admin/admin.cards') %>"
     data-tooltip="All Cards">
    <i class="fa-regular fa-credit-card"></i>
    <span class="item-label">All Cards</span>
  </a>

  <!-- ── Investments ── -->
  <div class="sidebar-section-label">Investments</div>

  <a href="/admin/admin.active-investments"
     class="sidebar-item <%= _active('/admin/admin.active-investments') %>"
     data-tooltip="Active Investments">
    <i class="fa-solid fa-chart-line"></i>
    <span class="item-label">Active Investments</span>
  </a>

  <a href="/admin/admin.inactive-investments"
     class="sidebar-item <%= _active('/admin/admin.inactive-investments') %>"
     data-tooltip="Closed Investments">
    <i class="fa-solid fa-chart-bar"></i>
    <span class="item-label">Closed Investments</span>
  </a>

  <!-- ── Plans ── -->
  <div class="sidebar-section-label">Plans</div>

  <a href="/admin/admin.upgrade-plans"
     class="sidebar-item <%= _active('/admin/admin.upgrade-plans') %>"
     data-tooltip="Upgrade Plans">
    <i class="fa-solid fa-star"></i>
    <span class="item-label">Upgrade Plans</span>
  </a>

  <a href="/admin/admin.investment-plans"
     class="sidebar-item <%= _active('/admin/admin.investment-plans') %>"
     data-tooltip="Investment Plans">
    <i class="fa-solid fa-seedling"></i>
    <span class="item-label">Investment Plans</span>
  </a>

  <!-- ── Communication ── -->
  <div class="sidebar-section-label">Communication</div>

  <a href="/admin/admin.send-mail"
     class="sidebar-item <%= _active('/admin/admin.send-mail') %>"
     data-tooltip="Send Mail">
    <i class="fa-regular fa-envelope"></i>
    <span class="item-label">Send Mail</span>
  </a>

  <!-- ── Admin Account ── -->
  <div class="sidebar-section-label">Account</div>

  <a href="/admin/admin.profile"
     class="sidebar-item <%= _active('/admin/admin.profile') %>"
     data-tooltip="My Profile">
    <i class="fa-regular fa-user"></i>
    <span class="item-label">My Profile</span>
  </a>

  <div class="sidebar-footer">
    <button type="button" class="sidebar-item" data-tooltip="Sign Out"
      style="color:var(--danger); border:none; background:transparent; width:100%; text-align:left; cursor:pointer;"
      onclick="openLogoutModal()">
      <i class="fa-solid fa-arrow-right-from-bracket"></i>
      <span class="item-label">Sign Out</span>
    </button>
  </div>

</aside>
